# =============================================================================
# Fly.io Environment Variables - Copy this file and fill in real values
#
# Usage:
#   1. cp .env.fly.example .env.fly
#   2. Fill in the real values
#   3. Use `fly secrets set` commands (see FLY_DEPLOY.md) or load via other means
#
# NEVER commit real secrets. This file is safe to commit as an example.
# =============================================================================

# --- Application Identity ---
APP_HOST=scrumcoid.fly.dev
# For custom domain later: APP_HOST=scrumcoid.com

MAILER_FROM=no-reply@scrumcoid.fly.dev
# When using a verified custom domain in Mailtrap:
# MAILER_FROM="ScrumAI Training <no-reply@scrumcoid.com>"

# --- Rails / Logging ---
RAILS_ENV=production
RAILS_LOG_LEVEL=info
# RAILS_LOG_LEVEL=debug   # Only for troubleshooting

# --- Database (set automatically by `fly postgres attach`) ---
# DATABASE_URL=postgres://...   # Usually injected as a secret by Fly

# --- Mailtrap (REQUIRED for password reset emails) ---
MAILTRAP_USERNAME=your_mailtrap_username_here
MAILTRAP_PASSWORD=your_mailtrap_password_here

# Use sandbox for testing, live for production emails
MAILTRAP_HOST=live.smtp.mailtrap.io
# MAILTRAP_HOST=sandbox.smtp.mailtrap.io

MAILTRAP_PORT=587

# --- Solid Queue Mode ---
# true  = run Solid Queue inside the web Puma process (simple, single machine)
# false = run Solid Queue on a dedicated worker process (recommended at scale)
SOLID_QUEUE_IN_PUMA=true

# --- Stripe (if you use paid enrollments) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Performance / Concurrency (optional) ---
# WEB_CONCURRENCY=2
# RAILS_MAX_THREADS=5

# --- Future / Advanced ---
# RAILS_SERVE_STATIC_FILES=true
# RAILS_LOG_TO_STDOUT=true
