<%
  def sort_link_params(column, current_sort, current_dir)
    new_dir = (current_sort == column && current_dir == "asc") ? "desc" : "asc"
    { sort: column, direction: new_dir }
  end

  table_extra_params = {
    query: params[:query].presence,
    course_id: params[:course_id].presence,
    starts_on_from: params[:starts_on_from].presence,
    starts_on_to: params[:starts_on_to].presence,
    sort: params[:sort].presence,
    direction: params[:direction].presence
  }.compact
  filters_active = params[:query].present? || params[:course_id].present? ||
    params[:starts_on_from].present? || params[:starts_on_to].present?
  students_return_to = admin_students_path(table_extra_params)
%>
<section class="px-8 py-10 max-w-7xl space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">CRM / Student Management</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Browse all enrolled participants, their company affiliations, and class schedules.</p>
    </div>
  </div>

  <%= render "admin/customers/crm_tabs" %>

  <!-- Search Filter Container -->
  <!-- Search Filter Container -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= form_tag admin_students_path, method: :get, class: "w-full space-y-6" do %>
      <% if params[:sort].present? %>
        <%= hidden_field_tag :sort, params[:sort] %>
        <%= hidden_field_tag :direction, params[:direction] %>
      <% end %>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Search Input -->
        <div>
          <%= label_tag :query, "Search Student", class: "block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2" %>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
            </div>
            <%= text_field_tag :query, params[:query], placeholder: "Name, email, company...", class: "block w-full pl-9 pr-4 py-2.5 rounded-xl border border-slate-300 bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm shadow-sm" %>
          </div>
        </div>

        <!-- Course Dropdown -->
        <div>
          <%= label_tag :course_id, "Course Filter", class: "block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2" %>
          <%= select_tag :course_id,
            options_from_collection_for_select(@courses, :id, :title, params[:course_id]),
            include_blank: "All courses",
            class: "block w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" %>
        </div>

        <!-- Date From -->
        <div>
          <%= label_tag :starts_on_from, "Starts From", class: "block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2" %>
          <%= date_field_tag :starts_on_from, params[:starts_on_from], class: "block w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" %>
        </div>

        <!-- Date To -->
        <div>
          <%= label_tag :starts_on_to, "Starts To", class: "block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2" %>
          <%= date_field_tag :starts_on_to, params[:starts_on_to], class: "block w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500" %>
        </div>
      </div>

      <div class="flex flex-col gap-4 border-t border-slate-100 pt-5 sm:flex-row sm:items-center sm:justify-between">
        <!-- Active Filter Badges -->
        <div class="flex flex-wrap gap-2 items-center">
          <% if filters_active %>
            <span class="text-xs font-bold uppercase tracking-wider text-slate-400 mr-1">Active Filters:</span>
            
            <% if params[:query].present? %>
              <span class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-50 pl-2.5 pr-1 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                Keyword: "<%= params[:query] %>"
                <%= link_to admin_students_path(table_extra_params.except(:query)), title: "Remove keyword filter", class: "group p-0.5 rounded-md hover:bg-indigo-100 transition-colors" do %>
                  <svg class="h-3 w-3 text-indigo-400 group-hover:text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                <% end %>
              </span>
            <% end %>

            <% if params[:course_id].present? && (course = @courses.find { |c| c.id.to_s == params[:course_id].to_s }) %>
              <span class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-50 pl-2.5 pr-1 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                Course: <%= course.title %>
                <%= link_to admin_students_path(table_extra_params.except(:course_id)), title: "Remove course filter", class: "group p-0.5 rounded-md hover:bg-indigo-100 transition-colors" do %>
                  <svg class="h-3 w-3 text-indigo-400 group-hover:text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                <% end %>
              </span>
            <% end %>

            <% if params[:starts_on_from].present? %>
              <span class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-50 pl-2.5 pr-1 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                From: <%= params[:starts_on_from] %>
                <%= link_to admin_students_path(table_extra_params.except(:starts_on_from)), title: "Remove start date filter", class: "group p-0.5 rounded-md hover:bg-indigo-100 transition-colors" do %>
                  <svg class="h-3 w-3 text-indigo-400 group-hover:text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                <% end %>
              </span>
            <% end %>

            <% if params[:starts_on_to].present? %>
              <span class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-50 pl-2.5 pr-1 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                To: <%= params[:starts_on_to] %>
                <%= link_to admin_students_path(table_extra_params.except(:starts_on_to)), title: "Remove end date filter", class: "group p-0.5 rounded-md hover:bg-indigo-100 transition-colors" do %>
                  <svg class="h-3 w-3 text-indigo-400 group-hover:text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                <% end %>
              </span>
            <% end %>
          <% else %>
            <span class="text-xs font-medium text-slate-400">Use fields above to filter the student list.</span>
          <% end %>
        </div>

        <!-- Action Buttons -->
        <div class="flex items-center gap-2.5 ml-auto w-full sm:w-auto">
          <% if filters_active %>
            <%= link_to "Clear Filters", admin_students_path, class: "w-1/2 sm:w-auto inline-flex items-center justify-center rounded-xl bg-slate-100 hover:bg-slate-200/80 px-5 py-2.5 text-sm font-bold text-slate-700 transition-colors" %>
          <% end %>
          <%= submit_tag "Apply Filters", class: "w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-indigo-500 shadow-md shadow-indigo-600/10 hover:shadow-indigo-600/20 transition-all cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Table Container Card -->
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @enrollments.any? %>
      <div class="flex flex-col gap-3 border-b border-slate-100 bg-slate-50/50 px-6 py-3 sm:flex-row sm:items-center sm:justify-between">
        <%= render "shared/per_page_selector",
          paginated: @enrollments,
          url: admin_students_path,
          extra_params: table_extra_params %>
        <% if @enrollments.total_pages > 1 %>
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@enrollments, entry_name: "student") %>
          </p>
        <% end %>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold">
              <th class="px-6 py-4" scope="col">
                <%
                  s_active = @sort_column == "student"
                  s_asc    = s_active && @sort_direction == "asc"
                  s_params = sort_link_params("student", @sort_column, @sort_direction)
                %>
                <%= link_to admin_students_path(s_params.merge(per_page: params[:per_page], query: params[:query].presence, course_id: params[:course_id].presence, starts_on_from: params[:starts_on_from].presence, starts_on_to: params[:starts_on_to].presence).compact),
                    class: "group inline-flex items-center gap-1.5 rounded-md px-2 py-1 -ml-2 transition-all #{s_active ? 'text-indigo-600 bg-indigo-50 ring-1 ring-inset ring-indigo-100' : 'text-slate-500 hover:text-slate-700 hover:bg-slate-100'}" do %>
                  <span>Student</span>
                  <% if s_active %>
                    <svg class="h-3.5 w-3.5 <%= s_asc ? '' : 'rotate-180' %> transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
                    </svg>
                  <% else %>
                    <svg class="h-3.5 w-3.5 opacity-40 group-hover:opacity-70 transition-opacity" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                    </svg>
                  <% end %>
                <% end %>
              </th>
              <th class="px-6 py-4" scope="col">
                <%
                  c_active = @sort_column == "company"
                  c_asc    = c_active && @sort_direction == "asc"
                  c_params = sort_link_params("company", @sort_column, @sort_direction)
                %>
                <%= link_to admin_students_path(c_params.merge(per_page: params[:per_page], query: params[:query].presence, course_id: params[:course_id].presence, starts_on_from: params[:starts_on_from].presence, starts_on_to: params[:starts_on_to].presence).compact),
                    class: "group inline-flex items-center gap-1.5 rounded-md px-2 py-1 -ml-2 transition-all #{c_active ? 'text-indigo-600 bg-indigo-50 ring-1 ring-inset ring-indigo-100' : 'text-slate-500 hover:text-slate-700 hover:bg-slate-100'}" do %>
                  <span>Company</span>
                  <% if c_active %>
                    <svg class="h-3.5 w-3.5 <%= c_asc ? '' : 'rotate-180' %> transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
                    </svg>
                  <% else %>
                    <svg class="h-3.5 w-3.5 opacity-40 group-hover:opacity-70 transition-opacity" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                    </svg>
                  <% end %>
                <% end %>
              </th>
              <th class="px-6 py-4" scope="col">
                <%
                  t_active = @sort_column == "training_schedule"
                  t_asc    = t_active && @sort_direction == "asc"
                  t_params = sort_link_params("training_schedule", @sort_column, @sort_direction)
                %>
                <%= link_to admin_students_path(t_params.merge(per_page: params[:per_page], query: params[:query].presence, course_id: params[:course_id].presence, starts_on_from: params[:starts_on_from].presence, starts_on_to: params[:starts_on_to].presence).compact),
                    class: "group inline-flex items-center gap-1.5 rounded-md px-2 py-1 -ml-2 transition-all #{t_active ? 'text-indigo-600 bg-indigo-50 ring-1 ring-inset ring-indigo-100' : 'text-slate-500 hover:text-slate-700 hover:bg-slate-100'}" do %>
                  <span>Training Schedule</span>
                  <% if t_active %>
                    <svg class="h-3.5 w-3.5 <%= t_asc ? '' : 'rotate-180' %> transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
                    </svg>
                  <% else %>
                    <svg class="h-3.5 w-3.5 opacity-40 group-hover:opacity-70 transition-opacity" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                    </svg>
                  <% end %>
                <% end %>
              </th>
              <th class="px-6 py-4">Status</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @enrollments.each do |enrollment| %>
              <% company_name = enrollment.registration&.customer&.company_name.presence || enrollment.registration&.company_name.presence || enrollment.company_name %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4">
                  <p class="font-semibold text-slate-900 leading-tight">
                    <%= link_to enrollment.attendee_name, admin_enrollment_path(enrollment, return_to: students_return_to), class: "hover:text-indigo-600 transition-colors" %>
                  </p>
                  <p class="text-xs text-slate-400 mt-1 font-medium"><%= enrollment.attendee_email %></p>
                </td>
                <td class="px-6 py-4">
                  <% if enrollment.registration&.customer.present? %>
                    <%= link_to company_name, admin_customer_path(enrollment.registration.customer), class: "font-semibold text-slate-700 hover:text-indigo-600 transition-colors" %>
                  <% elsif company_name.present? %>
                    <p class="font-semibold text-slate-700"><%= company_name %></p>
                  <% else %>
                    <p class="text-slate-300 italic text-xs">No company recorded</p>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <% if enrollment.class_schedule.present? %>
                    <%= link_to enrollment.class_schedule.course.title, admin_class_schedule_path(enrollment.class_schedule), class: "font-semibold text-indigo-600 hover:text-indigo-500 transition-colors" %>
                    <p class="text-xs text-slate-500 mt-0.5">
                      <%= enrollment.class_schedule.starts_at.strftime("%d %b") %> – <%= enrollment.class_schedule.ends_at.strftime("%d %b %Y") %>
                    </p>
                  <% else %>
                    <span class="text-slate-400 italic">No schedule</span>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <% if enrollment.active? %>
                    <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Active</span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-rose-50 px-2.5 py-0.5 text-xs font-semibold text-rose-700 ring-1 ring-inset ring-rose-500/20">Cancelled</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="inline-flex gap-2">
                    <%= link_to "View", admin_enrollment_path(enrollment, return_to: students_return_to), class: "inline-flex items-center gap-1 text-xs font-bold text-slate-600 hover:text-slate-900 bg-slate-50 px-2.5 py-1.5 rounded-lg border border-slate-200 transition-colors" %>
                    <%= link_to "Edit", edit_admin_enrollment_path(enrollment, return_to: students_return_to), class: "inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 bg-indigo-50/50 px-2.5 py-1.5 rounded-lg border border-indigo-100 transition-colors" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @enrollments.total_pages > 1 || filters_active %>
        <div class="flex flex-col gap-3 border-t border-slate-100 bg-slate-50/50 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@enrollments, entry_name: "student") %>
          </p>
          <% if @enrollments.total_pages > 1 %>
            <%= render "shared/pagination",
              paginated: @enrollments,
              path: method(:admin_students_path),
              extra_params: table_extra_params %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="px-6 py-16 text-center text-slate-400">
        <svg class="mx-auto h-16 w-16 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
        </svg>
        <p class="mt-4 font-semibold text-base">No students found</p>
        <p class="text-xs text-slate-400 mt-1">Either no enrollments exist yet, or the search filter returned no results.</p>
      </div>
    <% end %>
  </div>
</section>