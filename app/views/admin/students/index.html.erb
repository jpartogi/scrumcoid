<section class="px-8 py-10 max-w-7xl space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">CRM / Student Management</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Browse all enrolled participants, their company affiliations, and class schedules.</p>
    </div>
  </div>

  <%= render "admin/customers/crm_tabs" %>

  <!-- Search Filter Container -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col sm:flex-row items-center gap-4">
    <%= form_tag admin_students_path, method: :get, class: "w-full flex flex-col sm:flex-row items-center gap-4" do %>
      <div class="relative flex-grow w-full">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
        </div>
        <%= text_field_tag :query, params[:query], placeholder: "Search by first name, last name, email, or company...", class: "block w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-300 bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm shadow-sm" %>
      </div>
      <div class="flex gap-2 w-full sm:w-auto">
        <%= submit_tag "Search", class: "w-full sm:w-auto inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-indigo-500 shadow-sm transition-colors cursor-pointer" %>
        <% if params[:query].present? %>
          <%= link_to "Clear", admin_students_path, class: "w-full sm:w-auto inline-flex items-center justify-center rounded-lg bg-slate-50 border border-slate-300 px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-100 shadow-sm transition-colors" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Table Container Card -->
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @enrollments.any? %>
      <div class="flex flex-col gap-3 border-b border-slate-100 bg-slate-50/50 px-6 py-3 sm:flex-row sm:items-center sm:justify-between">
        <%= render "shared/per_page_selector",
          paginated: @enrollments,
          url: admin_students_path,
          extra_params: { query: params[:query].presence } %>
        <% if @enrollments.total_pages > 1 %>
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@enrollments, entry_name: "student") %>
          </p>
        <% end %>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold">
              <th class="px-6 py-4">Student</th>
              <th class="px-6 py-4">Company</th>
              <th class="px-6 py-4">Training Schedule</th>
              <th class="px-6 py-4">Status</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @enrollments.each do |enrollment| %>
              <% company_name = enrollment.registration&.customer&.company_name.presence || enrollment.registration&.company_name.presence || enrollment.company_name %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4">
                  <p class="font-semibold text-slate-900 leading-tight">
                    <%= link_to enrollment.attendee_name, admin_enrollment_path(enrollment), class: "hover:text-indigo-600 transition-colors" %>
                  </p>
                  <p class="text-xs text-slate-400 mt-1 font-medium"><%= enrollment.attendee_email %></p>
                </td>
                <td class="px-6 py-4">
                  <% if enrollment.registration&.customer.present? %>
                    <%= link_to company_name, admin_customer_path(enrollment.registration.customer), class: "font-semibold text-slate-700 hover:text-indigo-600 transition-colors" %>
                  <% elsif company_name.present? %>
                    <p class="font-semibold text-slate-700"><%= company_name %></p>
                  <% else %>
                    <p class="text-slate-300 italic text-xs">No company recorded</p>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <% if enrollment.class_schedule.present? %>
                    <%= link_to enrollment.class_schedule.course.title, admin_class_schedule_path(enrollment.class_schedule), class: "font-semibold text-indigo-600 hover:text-indigo-500 transition-colors" %>
                    <p class="text-xs text-slate-500 mt-0.5">
                      <%= enrollment.class_schedule.starts_at.strftime("%d %b") %> – <%= enrollment.class_schedule.ends_at.strftime("%d %b %Y") %>
                    </p>
                  <% else %>
                    <span class="text-slate-400 italic">No schedule</span>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <% if enrollment.active? %>
                    <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Active</span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-rose-50 px-2.5 py-0.5 text-xs font-semibold text-rose-700 ring-1 ring-inset ring-rose-500/20">Cancelled</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="inline-flex gap-2">
                    <%= link_to "View", admin_enrollment_path(enrollment), class: "inline-flex items-center gap-1 text-xs font-bold text-slate-600 hover:text-slate-900 bg-slate-50 px-2.5 py-1.5 rounded-lg border border-slate-200 transition-colors" %>
                    <%= link_to "Edit", edit_admin_enrollment_path(enrollment), class: "inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 bg-indigo-50/50 px-2.5 py-1.5 rounded-lg border border-indigo-100 transition-colors" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @enrollments.total_pages > 1 %>
        <div class="flex flex-col gap-3 border-t border-slate-100 bg-slate-50/50 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@enrollments, entry_name: "student") %>
          </p>
          <%= render "shared/pagination",
            paginated: @enrollments,
            path: method(:admin_students_path),
            extra_params: { query: params[:query].presence } %>
        </div>
      <% end %>
    <% else %>
      <div class="px-6 py-16 text-center text-slate-400">
        <svg class="mx-auto h-16 w-16 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
        </svg>
        <p class="mt-4 font-semibold text-base">No students found</p>
        <p class="text-xs text-slate-400 mt-1">Either no enrollments exist yet, or the search filter returned no results.</p>
      </div>
    <% end %>
  </div>
</section>