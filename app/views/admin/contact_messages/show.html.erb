<section class="px-8 py-10 max-w-7xl mx-auto space-y-6">
  <!-- Back Link & Action Header -->
  <div class="flex items-center justify-between border-b border-slate-200 pb-5">
    <div class="flex items-center gap-3">
      <%= link_to admin_contact_messages_path, class: "p-2 rounded-lg border border-slate-200 bg-white text-slate-500 hover:text-slate-700 shadow-sm hover:shadow transition-all" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      <% end %>
      <div>
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-3xl font-extrabold tracking-tight text-slate-900"><%= @contact_message.subject %></h1>
          <%= render "shared/status_badge", status: @contact_message.status %>
        </div>
        <p class="text-xs text-slate-400 font-medium mt-1">Contact Inquiry Detail</p>
      </div>
    </div>
  </div>

  <!-- Split Grid -->
  <div class="grid gap-8 lg:grid-cols-[1fr_320px] items-start">
    <!-- Left Column: Content Card -->
    <div class="space-y-8">
      <!-- Message Body Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Message Body</h2>
        <div class="mt-6 whitespace-pre-line text-sm leading-7 text-slate-700 font-medium font-sans">
          <%= @contact_message.message %>
        </div>
      </div>
    </div>

    <!-- Right Column: Sidebar metadata & Actions -->
    <div class="space-y-6">
      <!-- Sender Metadata Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Sender properties</p>
        <dl class="grid gap-3 text-xs text-slate-700">
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Name</dt>
            <dd class="mt-1 text-slate-600 font-semibold"><%= @contact_message.name %></dd>
          </div>
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Email</dt>
            <dd class="mt-1 font-semibold">
              <%= mail_to @contact_message.email, @contact_message.email, class: "text-indigo-600 hover:text-indigo-500 hover:underline transition-all break-all" %>
            </dd>
          </div>
          <% if @contact_message.company.present? %>
            <div>
              <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Company</dt>
              <dd class="mt-1 text-slate-600 font-semibold"><%= @contact_message.company %></dd>
            </div>
          <% end %>
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Received At</dt>
            <dd class="mt-1 text-slate-600 font-semibold"><%= @contact_message.created_at.to_fs(:long) %></dd>
          </div>
        </dl>
      </div>

      <!-- Operations Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-3">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Operations</p>
        
        <%= button_to "Mark Read", mark_read_admin_contact_message_path(@contact_message), method: :patch, disabled: @contact_message.read?, class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 disabled:opacity-50 disabled:pointer-events-none transition-all cursor-pointer shadow-sm", form_class: "w-full" %>

        <%= button_to "Archive Message", archive_admin_contact_message_path(@contact_message), method: :patch, disabled: @contact_message.archived?, class: "w-full rounded-lg bg-teal-700 px-4 py-2.5 text-sm font-bold text-white hover:bg-teal-800 disabled:opacity-50 disabled:pointer-events-none transition-all cursor-pointer shadow-sm", form_class: "w-full" %>
        
        <%= button_to "Delete Message", admin_contact_message_path(@contact_message), method: :delete, data: { confirm: "Are you sure you want to permanently delete this contact inquiry?" }, class: "w-full rounded-lg border border-rose-200 bg-white px-4 py-2.5 text-sm font-semibold text-rose-600 hover:bg-rose-50 hover:border-rose-300 transition-all cursor-pointer shadow-sm", form_class: "w-full" %>
      </div>
    </div>
  </div>
</section>
