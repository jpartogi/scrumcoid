<section class="px-8 py-10 max-w-7xl mx-auto space-y-10">
  <!-- Header Title -->
  <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Admin dashboard</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Real-time statistics and course schedule management.</p>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
    <!-- Courses Stat -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 duration-200 flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Total Courses</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @course_count %></p>
      </div>
      <div class="h-12 w-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
        </svg>
      </div>
    </div>

    <!-- Published Schedules Stat -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 duration-200 flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Live Classes</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @published_schedule_count %></p>
      </div>
      <div class="h-12 w-12 rounded-xl bg-teal-50 text-teal-600 flex items-center justify-center">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
        </svg>
      </div>
    </div>

    <!-- Active Enrollments Stat -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 duration-200 flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Total Bookings</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @active_enrollment_count %></p>
      </div>
      <div class="h-12 w-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
        </svg>
      </div>
    </div>

    <!-- Draft Posts Stat -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 duration-200 flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Draft Posts</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @draft_blog_post_count %></p>
      </div>
      <div class="h-12 w-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
        </svg>
      </div>
    </div>

    <!-- Unread Messages Stat -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 duration-200 flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Unread Mail</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @unread_contact_message_count %></p>
      </div>
      <div class="h-12 w-12 rounded-xl bg-rose-50 text-rose-600 flex items-center justify-center">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Dashboard Split Grid -->
  <div class="grid gap-8 lg:grid-cols-3">
    <!-- Left Column: Upcoming Class Schedules & Latest Registrations (Wide) -->
    <div class="lg:col-span-2 space-y-8">
      
      <!-- Latest Registrations -->
      <div class="space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
            <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.03 0 1.9.693 2.166 1.638m-7.377 2.24a4.12 4.12 0 0 0-1.53.48m12.452-2.235A4.119 4.119 0 0 1 20.25 6m-16.5 0a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 3.75 21h.75m0-18H6.75m-3 9h.008v.008H3.75V12Zm0 3h.008v.008H3.75V15Zm0 3h.008v.008H3.75V18Z" />
            </svg>
            Latest Registrations
          </h2>
          <%= link_to "View All", admin_registrations_path, class: "text-xs font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
          <% if @latest_registrations.any? %>
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse text-sm">
                <thead>
                  <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold">
                    <th class="px-6 py-4">Company Details</th>
                    <th class="px-6 py-4">Course Training</th>
                    <th class="px-6 py-4 text-center">Participants</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <% @latest_registrations.each do |reg| %>
                    <tr class="hover:bg-slate-50/50 transition-colors">
                      <td class="px-6 py-4 font-semibold text-slate-900">
                        <%= reg.company_name %><br>
                        <span class="text-xs text-slate-400 font-medium"><%= reg.finance_email %></span>
                      </td>
                      <td class="px-6 py-4">
                        <% if reg.class_schedule.present? %>
                          <%= link_to reg.course.title, admin_class_schedule_path(reg.class_schedule), class: "font-semibold text-indigo-600 hover:text-indigo-500 transition-colors" %>
                        <% else %>
                          <span class="text-slate-400 italic">No schedule</span>
                        <% end %>
                      </td>
                      <td class="px-6 py-4 text-center font-bold text-slate-800">
                        <%= reg.total_participants %>
                      </td>
                      <td class="px-6 py-4 text-right">
                        <%= link_to "View", admin_registration_path(reg), class: "inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 bg-indigo-50/30 px-3 py-1.5 rounded-lg border border-indigo-100 hover:bg-indigo-50 transition-colors" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="px-6 py-12 text-center text-slate-400">
              <p class="font-semibold text-sm">No registrations received yet</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Upcoming Classes -->
      <div class="space-y-4">
        <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
          <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008z" />
          </svg>
          Upcoming Classes
        </h2>

        <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
          <% if @upcoming_schedules.any? %>
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse text-sm">
                <thead>
                  <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold">
                    <th class="px-6 py-4">Course</th>
                    <th class="px-6 py-4">Date / Time</th>
                    <th class="px-6 py-4 text-center">Registrations</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <% @upcoming_schedules.each do |schedule| %>
                    <tr class="hover:bg-slate-50/50 transition-colors">
                      <td class="px-6 py-4 font-semibold text-slate-900 max-w-xs truncate">
                        <%= link_to schedule.course.title, admin_class_schedule_path(schedule), class: "hover:text-indigo-600" %>
                      </td>
                      <td class="px-6 py-4 text-slate-500 font-medium">
                        <%= local_class_time(schedule, format: :range) %>
                      </td>
                      <td class="px-6 py-4 text-center">
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-700 ring-1 ring-inset ring-indigo-600/10">
                          <%= schedule.registration_count %> / <%= schedule.capacity %>
                        </span>
                      </td>
                      <td class="px-6 py-4 text-right">
                        <%= link_to "Manage", admin_class_schedule_path(schedule), class: "inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 bg-indigo-50/30 px-3 py-1.5 rounded-lg border border-indigo-100 hover:bg-indigo-50 transition-colors" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="px-6 py-12 text-center text-slate-400">
              <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="mt-4 font-semibold text-sm">No upcoming classes scheduled</p>
              <%= link_to "Schedule a class", new_admin_class_schedule_path, class: "mt-4 inline-flex items-center gap-1 text-xs font-bold text-white bg-indigo-600 px-3.5 py-2 rounded-lg hover:bg-indigo-500 shadow-sm transition-colors" %>
            </div>
          <% end %>
        </div>
      </div>

    </div>

    <!-- Right Column: Shortcuts & Operations (Narrow) -->
    <div class="space-y-4">
      <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
        <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zm-7.518-.267A8.25 8.25 0 1120.25 10.5M8.288 14.212A5.25 5.25 0 1117.25 10.5" />
        </svg>
        Quick Operations
      </h2>

      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Global shortcuts</p>
        
        <div class="flex flex-col gap-2.5">
          <%= link_to new_admin_course_path, class: "flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:border-indigo-100 hover:bg-indigo-50/20 text-slate-700 font-semibold text-sm hover:text-indigo-700 shadow-sm transition-all" do %>
            <div class="h-9 w-9 rounded-lg bg-indigo-50/50 text-indigo-600 flex items-center justify-center shadow-inner">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </div>
            Create New Course
          <% end %>

          <%= link_to new_admin_class_schedule_path, class: "flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:border-teal-100 hover:bg-teal-50/20 text-slate-700 font-semibold text-sm hover:text-teal-700 shadow-sm transition-all" do %>
            <div class="h-9 w-9 rounded-lg bg-teal-50/50 text-teal-600 flex items-center justify-center shadow-inner">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75" />
              </svg>
            </div>
            Schedule New Class
          <% end %>

          <%= link_to new_admin_blog_post_path, class: "flex items-center gap-3 p-3 rounded-xl border border-slate-100 hover:border-amber-100 hover:bg-amber-50/20 text-slate-700 font-semibold text-sm hover:text-amber-700 shadow-sm transition-all" do %>
            <div class="h-9 w-9 rounded-lg bg-amber-50/50 text-amber-600 flex items-center justify-center shadow-inner">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
              </svg>
            </div>
            Write New Blog Post
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
