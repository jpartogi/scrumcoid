<section class="px-8 py-10 max-w-7xl mx-auto space-y-6">
  <!-- Back Link & Action Header -->
  <div class="flex items-center justify-between border-b border-slate-200 pb-5">
    <div class="flex items-center gap-3">
      <%= link_to admin_courses_path, class: "p-2 rounded-lg border border-slate-200 bg-white text-slate-500 hover:text-slate-700 shadow-sm hover:shadow transition-all" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      <% end %>
      <div>
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-3xl font-extrabold tracking-tight text-slate-900"><%= @course.title %></h1>
          <% if @course.published? %>
            <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Published</span>
          <% else %>
            <span class="inline-flex items-center rounded-full bg-slate-50 px-2.5 py-0.5 text-xs font-bold text-slate-500 ring-1 ring-inset ring-slate-500/10">Draft</span>
          <% end %>
        </div>
        <p class="text-xs text-slate-400 font-medium mt-1">Slug: <%= @course.slug %></p>
      </div>
    </div>
  </div>

  <!-- Main Body Grid -->
  <div class="grid gap-8 lg:grid-cols-[1fr_320px] items-start">
    <!-- Left Column: Content Cards -->
    <div class="space-y-8">
      <!-- Excerpt Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Course Excerpt</h2>
        <p class="mt-4 text-base text-slate-600 leading-relaxed font-medium"><%= @course.excerpt %></p>
      </div>

      <!-- Description Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Detailed Curriculum</h2>
        <div class="mt-4 text-sm text-slate-600 leading-relaxed prose max-w-none">
          <%= @course.description %>
        </div>
      </div>


    </div>

    <!-- Right Column: Sidebar Actions -->
    <div class="space-y-6">
      <!-- Logo Display Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Course Logo</p>
        <% if @course.logo.attached? %>
          <%= image_tag @course.logo, alt: "#{@course.title} logo", class: "w-full h-44 rounded-xl border border-slate-100 bg-white object-contain p-4 shadow-sm" %>
        <% else %>
          <div class="w-full h-44 rounded-xl border-2 border-dashed border-slate-200 bg-slate-50 flex flex-col items-center justify-center text-slate-400 p-4 text-center">
            <svg class="mx-auto h-8 w-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
            </svg>
            <p class="mt-2 text-xs font-bold">No logo uploaded</p>
          </div>
        <% end %>
      </div>

      <!-- Pricing Summary Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Base Pricing</p>
        <div class="space-y-3">
          <% if @course.course_prices.any? %>
            <% @course.course_prices.each do |price| %>
              <div class="flex items-center justify-between p-2.5 rounded-lg border border-slate-100 bg-slate-50/50 shadow-inner">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-widest"><%= price.currency %></span>
                <span class="text-sm font-extrabold text-slate-800"><%= price.display_amount %></span>
              </div>
            <% end %>
          <% else %>
            <p class="text-xs text-slate-400">No course pricing configured</p>
          <% end %>
        </div>
      </div>

      <!-- Actions Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-3">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Operations</p>
        
        <%= link_to edit_admin_course_path(@course), class: "flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:border-slate-400 transition-all shadow-sm" do %>
          Edit Details
        <% end %>

        <%= button_to @course.published? ? "Unpublish Course" : "Publish Course", @course.published? ? unpublish_admin_course_path(@course) : publish_admin_course_path(@course), method: :patch, class: "w-full rounded-lg bg-teal-700 px-4 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-all cursor-pointer shadow-sm", form_class: "w-full" %>
        
        <%= button_to "Delete Course", admin_course_path(@course), method: :delete, data: { confirm: "Are you sure you want to delete this course and all associated schedules?" }, class: "w-full rounded-lg border border-rose-200 bg-white px-4 py-2.5 text-sm font-semibold text-rose-600 hover:bg-rose-50 hover:border-rose-300 transition-all cursor-pointer shadow-sm", form_class: "w-full" %>
      </div>
    </div>
  </div>
</section>
