<section class="px-8 py-10 max-w-7xl space-y-6">
  <%# ── Page Header ── %>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Manage Courses</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Add, update, and monitor training curricula offered by the site.</p>
    </div>
    <%= link_to new_admin_course_path,
        class: "inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-2.5 text-sm font-bold text-white shadow-md shadow-indigo-500/20 hover:from-indigo-500 hover:to-violet-500 hover:-translate-y-px transition-all duration-200" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      New Course
    <% end %>
  </div>

  <%# ── Table Card ── %>
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @courses.any? %>
      <div class="flex flex-col gap-3 border-b border-slate-100 bg-slate-50/50 px-6 py-3 sm:flex-row sm:items-center sm:justify-between">
        <%= render "shared/per_page_selector", paginated: @courses, url: admin_courses_path %>
        <% if @courses.total_pages > 1 %>
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@courses, entry_name: "course") %>
          </p>
        <% end %>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-400">
              <th class="px-6 py-3.5 text-slate-400" scope="col">Course</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Excerpt</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Status</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Registrations</th>
              <th class="px-6 py-3.5 text-right text-slate-400" scope="col">Actions</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">
            <% @courses.each do |course| %>
              <tr class="group hover:bg-indigo-50/30 transition-colors">
                <%# Course Details Column %>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-4">
                    <% if course.logo.attached? %>
                      <%= image_tag course.logo, alt: "#{course.title} logo", class: "h-11 w-11 rounded-xl border border-slate-200 bg-white object-contain p-1 shrink-0 shadow-sm" %>
                    <% else %>
                      <div class="h-11 w-11 rounded-xl border border-slate-200 bg-slate-50 text-slate-400 flex items-center justify-center shrink-0 shadow-sm">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
                        </svg>
                      </div>
                    <% end %>
                    <div>
                      <p class="font-semibold text-slate-900 leading-tight group-hover:text-indigo-600 transition-colors">
                        <%= link_to course.title, admin_course_path(course), class: "hover:underline underline-offset-2" %>
                      </p>
                      <p class="text-[11px] text-slate-400 font-mono mt-1">slug: <%= course.slug %></p>
                    </div>
                  </div>
                </td>

                <%# Excerpt Summary Column %>
                <td class="px-6 py-4 text-slate-500 text-xs max-w-xs">
                  <span class="line-clamp-2 leading-relaxed"><%= course.excerpt.presence || "—" %></span>
                </td>

                <%# Status Column %>
                <td class="px-6 py-4">
                  <% if course.published? %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                      Published
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-500/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                      Draft
                    </span>
                  <% end %>
                </td>

                <%# Registrations Column %>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-0.5 text-[10px] font-bold text-indigo-700 ring-1 ring-inset ring-indigo-600/10">
                    <%= course.active_enrollment_count %> Active
                  </span>
                </td>

                <%# Action Buttons Column %>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to admin_course_path(course),
                        class: "inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-bold text-slate-600 hover:text-slate-900 hover:border-slate-300 hover:bg-slate-50 transition-all shadow-xs" do %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      View
                    <% end %>
                    <%= link_to edit_admin_course_path(course),
                        class: "inline-flex items-center gap-1 rounded-lg border border-indigo-100 bg-indigo-50 px-2.5 py-1.5 text-xs font-bold text-indigo-600 hover:bg-indigo-100 hover:border-indigo-200 hover:text-indigo-700 transition-all shadow-xs" do %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                      </svg>
                      Edit
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @courses.total_pages > 1 %>
        <div class="flex flex-col gap-3 border-t border-slate-100 bg-slate-50/50 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@courses, entry_name: "course") %>
          </p>
          <%= render "shared/pagination", paginated: @courses, path: method(:admin_courses_path) %>
        </div>
      <% end %>
    <% else %>
      <div class="px-6 py-20 text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100">
          <svg class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <p class="mt-4 text-base font-bold text-slate-700">No courses created yet</p>
        <p class="mt-1 text-sm text-slate-400">Get started by creating your first professional course training model.</p>
        <%= link_to "Create Course", new_admin_course_path,
            class: "mt-5 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-5 py-2.5 text-sm font-bold text-white shadow-md hover:from-indigo-500 hover:to-violet-500 transition-all" %>
      </div>
    <% end %>
  </div>
</section>
