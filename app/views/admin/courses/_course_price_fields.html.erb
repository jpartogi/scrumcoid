<div data-price-row class="rounded-xl border border-slate-200 bg-slate-50/50 p-4 relative shadow-sm hover:shadow transition-all">
  <%= price_form.hidden_field :id if price_form.object.persisted? %>
  <%= price_form.hidden_field :_destroy, value: "0" %>
  <div class="grid gap-4 md:grid-cols-[140px_180px_auto] md:items-end">
    <div>
      <%= price_form.label :currency, class: "block text-xs font-bold uppercase tracking-wider text-slate-400" %>
      <%= price_form.text_field :currency, placeholder: "USD", maxlength: 3, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold uppercase focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-300" %>
    </div>
    
    <div>
      <%= price_form.label :amount, "Amount", class: "block text-xs font-bold uppercase tracking-wider text-slate-400" %>
      <%= price_form.number_field :amount, placeholder: "1295.00", min: 0, step: "0.01", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-300" %>
    </div>
    
    <div class="flex justify-end md:justify-start">
      <button type="button" data-action="nested-prices#remove" class="inline-flex items-center gap-1 rounded-lg border border-rose-200 bg-white px-4 py-2.5 text-xs font-bold text-rose-600 hover:bg-rose-50 hover:border-rose-300 transition-colors shadow-sm cursor-pointer">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
        Remove Row
      </button>
    </div>
  </div>
</div>
