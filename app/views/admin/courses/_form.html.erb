<%= form_with model: [:admin, course], html: { multipart: true }, class: "space-y-6" do |form| %>
  <% if course.errors.any? %>
    <div class="rounded-xl border border-rose-100 bg-rose-50/70 p-4 text-sm font-semibold text-rose-800 shadow-sm flex items-center gap-2">
      <svg class="h-5 w-5 text-rose-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      <span><%= course.errors.full_messages.to_sentence %></span>
    </div>
  <% end %>

  <!-- Text Input Group -->
  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <%= form.label :title, class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :title, placeholder: "e.g., Scrum.org Professional Scrum Master", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>
    
    <div>
      <%= form.label :slug, class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :slug, placeholder: "e.g., professional-scrum-master", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>
  </div>

  <div>
    <%= form.label :excerpt, class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_area :excerpt, rows: 2, placeholder: "Brief 1-2 sentence description summarizing the course...", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :meta_keywords, "Meta Keywords (SEO)", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :meta_keywords, placeholder: "e.g., scrum, professional scrum master, agile training", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :tags, "Tags", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :tags, placeholder: "e.g., scrum, agile, product management", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    <p class="mt-1.5 text-xs text-slate-500">Comma-separated tags used to surface related blog articles on the course page.</p>
  </div>

  <!-- Logo Upload Zone -->
  <div class="rounded-2xl border border-slate-200 bg-slate-50/50 p-5 space-y-3">
    <%= form.label :logo, class: "block text-sm font-bold text-slate-700" %>
    <div class="flex flex-wrap items-center gap-5">
      <% if course.logo.attached? && course.logo.attachment&.persisted? %>
        <%= image_tag course.logo, alt: "#{course.title} logo", class: "h-16 w-16 rounded-xl border border-slate-200 bg-white object-contain p-2 shadow-sm shrink-0" %>
        <div class="text-xs font-semibold text-slate-500">
          <p class="text-slate-900 leading-none">Current Logo</p>
          <p class="mt-1 font-medium"><%= course.logo.filename %></p>
        </div>
      <% else %>
        <div class="h-16 w-16 rounded-xl border border-slate-200 bg-white text-slate-400 flex items-center justify-center shrink-0 shadow-inner">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
          </svg>
        </div>
      <% end %>
      
      <%= form.file_field :logo, accept: "image/png,image/jpeg,image/webp,image/svg+xml", class: "block w-full max-w-xs text-xs text-slate-500 file:mr-4 file:rounded-lg file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-xs file:font-bold file:text-white hover:file:bg-teal-700 file:transition-colors file:cursor-pointer" %>
    </div>
    <p class="text-xs text-slate-400 font-medium">Upload a PNG, JPG, WebP, or SVG logo for the visitor-facing course pages.</p>
  </div>

  <!-- Thumbnail Upload Zone -->
  <div class="rounded-2xl border border-slate-200 bg-slate-50/50 p-5 space-y-3">
    <%= form.label :thumbnail, "Course Thumbnail (Banner)", class: "block text-sm font-bold text-slate-700" %>
    <div class="flex flex-wrap items-center gap-5">
      <% if course.thumbnail.attached? && course.thumbnail.attachment&.persisted? %>
        <%= image_tag course.thumbnail, alt: "#{course.title} thumbnail", class: "h-16 w-28 rounded-xl border border-slate-200 bg-white object-cover shadow-sm shrink-0" %>
        <div class="text-xs font-semibold text-slate-500">
          <p class="text-slate-900 leading-none">Current Thumbnail</p>
          <p class="mt-1 font-medium"><%= course.thumbnail.filename %></p>
        </div>
      <% else %>
        <div class="h-16 w-28 rounded-xl border border-slate-200 bg-white text-slate-400 flex items-center justify-center shrink-0 shadow-inner">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
          </svg>
        </div>
      <% end %>
      
      <%= form.file_field :thumbnail, accept: "image/png,image/jpeg,image/webp", class: "block w-full max-w-xs text-xs text-slate-500 file:mr-4 file:rounded-lg file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-xs file:font-bold file:text-white hover:file:bg-teal-700 file:transition-colors file:cursor-pointer" %>
    </div>
    <p class="text-xs text-slate-400 font-medium">Upload a wide banner image to be displayed at the top of invitation emails.</p>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-bold text-slate-700" %>
    <div class="mt-1.5 block rounded-lg border border-slate-300 bg-white shadow-sm overflow-hidden focus-within:ring-2 focus-within:ring-teal-600/10 focus-within:border-teal-600 transition-all">
      <%= form.rich_text_area :description, class: "rich-text-editor-tall p-3 min-h-[16rem] focus:outline-none" %>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <%= form.label :status, class: "block text-sm font-bold text-slate-700" %>
      <%= form.select :status, Course.statuses.keys.map { |k| [k.capitalize, k] }, {}, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all" %>
    </div>
  </div>

  <!-- Dynamic Prices Panel -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-4" data-controller="nested-prices">
    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-100 pb-4">
      <div>
        <h2 class="text-base font-bold text-slate-900">Configure Pricing</h2>
        <p class="text-xs font-medium text-slate-400 mt-1">Specify localized price records across multiple base currencies.</p>
      </div>
      <button type="button" data-action="nested-prices#add" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 hover:border-slate-400 shadow-sm transition-all cursor-pointer">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Add Price Row
      </button>
    </div>

    <div class="space-y-4" data-nested-prices-target="rows">
      <%= form.fields_for :course_prices do |price_form| %>
        <%= render "course_price_fields", price_form: price_form %>
      <% end %>
    </div>

    <template data-nested-prices-target="template">
      <%= form.fields_for :course_prices, CoursePrice.new, child_index: "NEW_RECORD" do |price_form| %>
        <%= render "course_price_fields", price_form: price_form %>
      <% end %>
    </template>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center gap-4 border-t border-slate-100 pt-5">
    <%= form.submit class: "rounded-lg bg-teal-700 px-5 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-colors shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", course.persisted? ? admin_course_path(course) : admin_courses_path, class: "rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm" %>
  </div>
<% end %>
