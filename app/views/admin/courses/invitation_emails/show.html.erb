<section class="px-8 py-10 max-w-3xl space-y-6">
  <!-- Back Link & Action Header -->
  <div class="flex items-center justify-between border-b border-slate-200 pb-5">
    <div class="flex items-center gap-3">
      <%= link_to admin_course_path(@course), class: "p-2 rounded-lg border border-slate-200 bg-white text-slate-500 hover:text-slate-700 shadow-sm hover:shadow transition-all" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      <% end %>
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Invitation Email Template</h1>
        <p class="text-sm font-medium text-slate-500 mt-1"><%= @course.title %></p>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to edit_admin_course_invitation_email_path(@course), class: "rounded-lg bg-teal-700 px-4 py-2 text-sm font-bold text-white hover:bg-teal-800 transition-all shadow-sm cursor-pointer active:scale-95" do %>
        Edit Template
      <% end %>
    </div>
  </div>

  <!-- Main Card -->
  <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm space-y-6">
    <div class="space-y-2">
      <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Template Content</h2>
      <% if @course.invitation_email.present? %>
        <div class="text-sm text-slate-700 leading-relaxed prose max-w-none pt-2">
          <%= @course.invitation_email %>
        </div>
      <% else %>
        <div class="py-8 text-center text-slate-400">
          <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <p class="mt-4 font-semibold text-sm">No template content configured yet</p>
          <p class="text-xs mt-1 text-slate-400">Click Edit Template above to get started.</p>
        </div>
      <% end %>
    </div>

    <!-- Placeholders list -->
    <div class="rounded-xl border border-slate-150 bg-slate-50/50 p-4 space-y-3">
      <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider">Available Placeholders</h3>
      <p class="text-xs text-slate-500 leading-relaxed">
        You can use the following tags in your invitation template. They will be automatically replaced with the corresponding values when the email is sent:
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
        <% [
          ["{{first_name}}", "Student's first name"],
          ["{{last_name}}", "Student's last name"],
          ["{{full_name}}", "Student's full name"],
          ["{{email}}", "Student's email address"],
          ["{{course_title}}", "Name of the course"],
          ["{{class_date}}", "Class schedule date"],
          ["{{class_time}}", "Class schedule time"],
          ["{{class_location}}", "Class schedule location"],
          ["{{venue_name}}", "Class schedule venue name"],
          ["{{venue_address}}", "Class schedule venue address"],
          ["{{class_schedule_url}}", "Link to schedule detail"]
        ].each do |tag, desc| %>
          <div class="p-2 rounded bg-white border border-slate-200/60 shadow-sm flex flex-col gap-0.5">
            <code class="text-[10px] font-bold text-indigo-600"><%= tag %></code>
            <span class="text-[10px] text-slate-400 font-medium"><%= desc %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
