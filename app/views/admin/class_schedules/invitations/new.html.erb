<section class="px-8 py-10 max-w-4xl space-y-6">
  <div class="flex items-center gap-3 border-b border-slate-200 pb-5">
    <%= link_to admin_class_schedule_path(@class_schedule), class: "p-2 rounded-lg border border-slate-200 bg-white text-slate-500 hover:text-slate-700 shadow-sm hover:shadow transition-all" do %>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
    <% end %>
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Send Invitation Emails</h1>
      <p class="text-sm font-medium text-slate-500 mt-1"><%= @course.title %></p>
    </div>
  </div>

  <% if @course.invitation_email.blank? %>
    <div class="rounded-2xl border border-amber-200 bg-amber-50/70 p-5 text-sm text-amber-900 shadow-sm">
      <p class="font-semibold">Invitation email template is not configured for this course.</p>
      <p class="mt-2 text-amber-800">Add the template on the course before sending invitations.</p>
      <%= link_to "Edit Invitation Email Template", edit_admin_course_invitation_email_path(@course), class: "inline-flex mt-4 rounded-lg bg-amber-700 px-4 py-2 text-xs font-bold text-white hover:bg-amber-800 transition-colors" %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-4">
      <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Template Preview</h2>
      <% if @sample_body_html.present? %>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700 prose max-w-none"><%= @sample_body_html.html_safe %></div>
      <% else %>
        <p class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-500">No students on the roster yet. The preview uses sample data when the roster is empty.</p>
      <% end %>
      <p class="text-xs text-slate-500">
        Template from <%= link_to @course.title, admin_course_path(@course), class: "font-semibold text-indigo-600 hover:text-indigo-500" %>.
        Placeholders: <code class="text-slate-700">{{first_name}}</code>, <code class="text-slate-700">{{last_name}}</code>, <code class="text-slate-700">{{full_name}}</code>, <code class="text-slate-700">{{email}}</code>, <code class="text-slate-700">{{course_title}}</code>, <code class="text-slate-700">{{class_date}}</code>, <code class="text-slate-700">{{class_time}}</code>, <code class="text-slate-700">{{class_location}}</code>, <code class="text-slate-700">{{venue_name}}</code>, <code class="text-slate-700">{{venue_address}}</code>, <code class="text-slate-700">{{class_schedule_url}}</code>
      </p>
    </div>

    <%= form_with url: admin_class_schedule_invitations_path(@class_schedule), class: "rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6" do |form| %>
      <div>
        <%= form.label :subject, "Email Subject", class: "block text-sm font-bold text-slate-700" %>
        <%= form.text_field :subject, value: @subject, required: true, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all" %>
      </div>

      <div class="space-y-3">
        <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Recipients</h2>

        <% if @enrollments.any? %>
          <div class="space-y-2">
            <% @enrollments.each do |enrollment| %>
              <label class="flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 cursor-pointer hover:bg-slate-50 transition-colors">
                <%= check_box_tag "enrollment_ids[]", enrollment.id, true, class: "h-4 w-4 rounded border-slate-300 text-teal-600 focus:ring-teal-500" %>
                <span class="min-w-0">
                  <span class="block text-sm font-semibold text-slate-900"><%= enrollment.attendee_name %></span>
                  <span class="block text-xs text-slate-500"><%= enrollment.attendee_email %></span>
                </span>
              </label>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">No active students on the roster yet.</p>
        <% end %>
      </div>

      <div class="flex items-center gap-4 border-t border-slate-100 pt-5">
        <%= form.submit "Send Invitation Emails", disabled: @enrollments.empty?, class: "rounded-lg bg-teal-700 px-5 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-colors shadow-sm cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" %>
        <%= link_to "Cancel", admin_class_schedule_path(@class_schedule), class: "rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm" %>
      </div>
    <% end %>
  <% end %>
</section>