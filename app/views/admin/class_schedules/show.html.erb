<section class="px-8 py-10 max-w-7xl space-y-6">
  <!-- Back Link & Action Header -->
  <div class="flex items-center justify-between border-b border-slate-200 pb-5">
    <div class="flex items-center gap-3">
      <%= link_to admin_class_schedules_path, class: "p-2 rounded-lg border border-slate-200 bg-white text-slate-500 hover:text-slate-700 shadow-sm hover:shadow transition-all" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      <% end %>
      <div>
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-3xl font-extrabold tracking-tight text-slate-900"><%= @class_schedule.course.title %></h1>
          <% if @class_schedule.published? %>
            <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Published</span>
          <% elsif @class_schedule.unpublished? %>
            <span class="inline-flex items-center rounded-full bg-slate-50 px-2.5 py-0.5 text-xs font-bold text-slate-500 ring-1 ring-inset ring-slate-500/10">Draft</span>
          <% else %>
            <span class="inline-flex items-center rounded-full bg-rose-50 px-2.5 py-0.5 text-xs font-bold text-rose-700 ring-1 ring-inset ring-rose-500/20">Cancelled</span>
          <% end %>
        </div>
        <p class="text-xs text-slate-400 font-medium mt-1">Class Schedule Detail</p>
      </div>
    </div>
  </div>

  <%= render "admin/shared/page_view_stats", stats: @page_view_stats %>

  <!-- Stats Grid -->
  <div class="grid gap-6 sm:grid-cols-3">
    <!-- Active Registrations Stat -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Total Bookings</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @class_schedule.registration_count %></p>
      </div>
      <div class="h-12 w-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
        </svg>
      </div>
    </div>

    <!-- Remaining Seats Stat -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Remaining Seats</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @class_schedule.remaining_seats %></p>
      </div>
      <div class="h-12 w-12 rounded-xl bg-teal-50 text-teal-600 flex items-center justify-center">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0112 15c2.207 0 4.208.576 5.963 1.584zm-10.051-.18l-.001-.031c0-.225.012-.447.037-.666A11.944 11.944 0 0112 3c2.17 0 4.207.576 5.963 1.584A6.062 6.062 0 0112 9c-2.207 0-4.208-.576-5.963-1.584z" />
        </svg>
      </div>
    </div>

    <!-- Prices Stat -->
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex items-center justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Course Pricing</p>
        <p class="mt-2 text-lg font-extrabold text-slate-800 leading-tight">
          <%= @class_schedule.course.course_prices.any? ? @class_schedule.course.course_prices.map(&:display_amount).join(", ") : "Price unavailable" %>
        </p>
      </div>
      <div class="h-12 w-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.214.172a3.007 3.007 0 004.121 0l.214-.172m-3-6.425l.214.172a3.007 3.007 0 004.121 0l.214-.172m0-.251V18" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Split Grid -->
  <div class="grid gap-8 lg:grid-cols-[1fr_320px] items-start">
    <!-- Left Column: Registered Students & Traffic -->
    <div class="space-y-8">
      <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-150 bg-slate-50/50 flex items-center justify-between gap-4">
        <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
          <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
          </svg>
          Registered Student Roster
        </h2>
      </div>
      
      <!-- Control Bar for Adding Students -->
      <div class="px-6 py-4 border-b border-slate-150 bg-slate-50/30 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <span class="text-sm font-semibold text-slate-600">How many students do you want to add?</span>
        <%= form_with url: new_admin_class_schedule_enrollment_path(@class_schedule), method: :get, class: "flex items-center shrink-0" do |form| %>
          <div class="flex items-center rounded-xl border border-slate-300 bg-white shadow-sm focus-within:ring-2 focus-within:ring-teal-600/10 focus-within:border-teal-600 transition-all overflow-hidden pl-3 py-1 pr-1 gap-2">
            <%= form.number_field :count, value: 1, min: 1, max: @max_batch_size, required: true, class: "w-12 bg-transparent border-0 p-0 text-sm font-semibold text-slate-800 focus:ring-0 focus:outline-none text-center" %>
            <span class="text-xs font-semibold text-slate-400 mr-2">students</span>
            <%= form.submit "Add Students", class: "rounded-lg bg-teal-700 px-4 py-2 text-xs font-bold text-white hover:bg-teal-800 transition-all cursor-pointer whitespace-nowrap shadow-sm active:scale-95" %>
          </div>
        <% end %>
      </div>
      <% if @class_schedule.enrollments.any? %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200/60 text-slate-400 font-bold uppercase tracking-wider text-[10px]">
                <th class="px-6 py-4">Student</th>
                <th class="px-6 py-4">Country</th>
                <th class="px-6 py-4 text-center">Status</th>
                <th class="px-6 py-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @class_schedule.enrollments.includes(:user).each do |enrollment| %>
                <tr class="hover:bg-slate-50/50 transition-colors">
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <% initials = enrollment.attendee_name.presence&.split&.map(&:first)&.join&.upcase&.first(2) || "U" %>
                      <div class="h-9 w-9 rounded-full bg-indigo-50/80 text-indigo-700 font-bold text-xs flex items-center justify-center border border-indigo-100/50 uppercase shrink-0 shadow-sm">
                        <%= initials %>
                      </div>
                      <div>
                        <p class="font-semibold text-slate-900 leading-none"><%= enrollment.attendee_name %></p>
                        <p class="text-xs text-slate-400 mt-1.5 font-medium"><%= enrollment.attendee_email %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-slate-600 font-medium"><%= enrollment.country.presence || "—" %></td>
                  <td class="px-6 py-4 text-center">
                    <% if enrollment.active? %>
                      <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20 shadow-sm">Active</span>
                    <% else %>
                      <span class="inline-flex items-center rounded-full bg-rose-50 px-2.5 py-0.5 text-xs font-bold text-rose-700 ring-1 ring-inset ring-rose-500/20 shadow-sm">Cancelled</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <div class="inline-flex gap-2">
                      <%= link_to admin_enrollment_path(enrollment), class: "inline-flex items-center justify-center gap-1.5 text-xs font-bold text-slate-600 hover:text-slate-900 bg-slate-50 hover:bg-slate-100/80 px-2.5 py-1.5 rounded-lg border border-slate-200 transition-all shadow-sm active:scale-95" do %>
                        <svg class="h-3.5 w-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                        View
                      <% end %>
                      <%= link_to edit_admin_enrollment_path(enrollment), class: "inline-flex items-center justify-center gap-1.5 text-xs font-bold text-indigo-600 hover:text-indigo-500 bg-indigo-50/50 hover:bg-indigo-50 px-2.5 py-1.5 rounded-lg border border-indigo-100 transition-all shadow-sm active:scale-95" do %>
                        <svg class="h-3.5 w-3.5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
                        </svg>
                        Edit
                      <% end %>
                      <%= button_to admin_enrollment_path(enrollment), method: :delete, data: { confirm: "Are you sure you want to permanently delete this student registration?" }, class: "inline-flex items-center justify-center gap-1.5 text-xs font-bold text-rose-600 hover:text-rose-700 bg-rose-50/50 hover:bg-rose-50 px-2.5 py-1.5 rounded-lg border border-rose-100 transition-all cursor-pointer shadow-sm active:scale-95", form_class: "inline-flex" do %>
                        <svg class="h-3.5 w-3.5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                        </svg>
                        Delete
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-12 text-center text-slate-400">
          <p class="font-semibold text-sm">No students registered yet for this schedule</p>
        </div>
      <% end %>
      </div>

      <%= render "admin/shared/page_traffic_panel", stats: @page_view_stats, title: "Schedule Page Traffic (7 Days)", gradient_id: "class-schedule-chart-gradient" %>
    </div>

    <!-- Right Column: Sidebar metadata -->
    <div class="space-y-6">
      <!-- Course Logo Display Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Associated Course Logo</p>
        <% if @class_schedule.course.logo.attached? %>
          <%= image_tag @class_schedule.course.logo, alt: "#{@class_schedule.course.title} logo", class: "w-full h-44 rounded-xl border border-slate-100 bg-white object-contain p-4 shadow-sm" %>
        <% else %>
          <div class="w-full h-44 rounded-xl border-2 border-dashed border-slate-200 bg-slate-50 flex flex-col items-center justify-center text-slate-400 p-4 text-center">
            <svg class="mx-auto h-8 w-8 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
            </svg>
            <p class="mt-2 text-xs font-bold">No logo uploaded</p>
          </div>
        <% end %>
      </div>

      <!-- Schedule Meta Details Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Class details</p>
        <dl class="grid gap-3 text-xs text-slate-700">
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Date / Time</dt>
            <dd class="mt-1.5 text-slate-600 font-semibold space-y-1">
              <span class="flex items-center gap-1.5">
                <svg class="h-3.5 w-3.5 text-indigo-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
                <%= class_schedule_date_part(@class_schedule) %>
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="h-3.5 w-3.5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <%= class_schedule_time_part(@class_schedule) %>
              </span>
            </dd>
          </div>
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Format</dt>
            <dd class="mt-1 text-slate-600 font-semibold"><%= @class_schedule.online? ? "Live online" : @class_schedule.location %></dd>
          </div>
          <% unless @class_schedule.online? %>
            <div>
              <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Venue Name</dt>
              <dd class="mt-1 text-slate-600 font-semibold"><%= @class_schedule.venue_name %></dd>
            </div>
            <div>
              <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Venue Address</dt>
              <dd class="mt-1 text-slate-600 font-semibold"><%= @class_schedule.venue_address %></dd>
            </div>
          <% end %>
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Deadline</dt>
            <dd class="mt-1 text-slate-600 font-semibold"><%= @class_schedule.registration_deadline.to_fs(:long) %></dd>
          </div>
        </dl>
      </div>

      <!-- Operations Card -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-3">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Operations</p>
        
        <%= link_to class_schedule_path(@class_schedule), target: "_blank", class: "flex items-center justify-center gap-1.5 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:border-slate-400 transition-all shadow-sm" do %>
          View In Site
          <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        <% end %>

        <%= link_to edit_admin_class_schedule_path(@class_schedule), class: "flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:border-slate-400 transition-all shadow-sm" do %>
          Edit Details
        <% end %>

        <%= link_to new_admin_class_schedule_invitations_path(@class_schedule), class: "flex items-center justify-center rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-2.5 text-sm font-semibold text-indigo-700 hover:bg-indigo-100 hover:border-indigo-300 transition-all shadow-sm" do %>
          Send Invitation Emails
        <% end %>

        <%= button_to @class_schedule.published? ? "Unpublish Schedule" : "Publish Schedule", @class_schedule.published? ? unpublish_admin_class_schedule_path(@class_schedule) : publish_admin_class_schedule_path(@class_schedule), method: :patch, class: "w-full rounded-lg bg-teal-700 px-4 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-all cursor-pointer shadow-sm", form_class: "w-full" %>
        
        <%= button_to "Delete Schedule", admin_class_schedule_path(@class_schedule), method: :delete, data: { confirm: "Are you sure you want to delete this schedule?" }, class: "w-full rounded-lg border border-rose-200 bg-white px-4 py-2.5 text-sm font-semibold text-rose-600 hover:bg-rose-50 hover:border-rose-300 transition-all cursor-pointer shadow-sm", form_class: "w-full" %>
      </div>
    </div>
  </div>
</section>
