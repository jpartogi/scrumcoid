<div class="rounded-xl border border-slate-200 bg-slate-50/50 p-5 space-y-4">
  <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Student <%= index + 1 %></p>

  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <%= form.label :first_name, "First Name", class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :first_name, required: true, placeholder: "e.g., Jane", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>

    <div>
      <%= form.label :last_name, "Last Name", class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :last_name, required: true, placeholder: "e.g., Doe", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>

    <div>
      <%= form.label :email, "Email Address", class: "block text-sm font-bold text-slate-700" %>
      <%= form.email_field :email, required: true, placeholder: "e.g., jane@example.com", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>

    <div>
      <%= form.label :country, "Country", class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :country, placeholder: "e.g., Indonesia", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>

    <div class="md:col-span-2">
      <%= form.label :company_name, "Company Name", class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :company_name, placeholder: "e.g., Acme Corp", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>
  </div>

  <% if enrollment.errors.any? %>
    <p class="text-sm font-semibold text-rose-700"><%= enrollment.errors.full_messages.to_sentence %></p>
  <% end %>
</div>