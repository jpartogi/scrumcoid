<section class="px-8 py-10 max-w-7xl space-y-6">
  <%# ── Page Header ── %>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">
        <%= @showing_past ? "Past Class Schedules" : "Class Schedules" %>
      </h1>
      <p class="text-sm font-medium text-slate-500 mt-1">
        <% if @showing_past %>
          Review completed class events and their registration history.
        <% else %>
          Schedule new classes, track active student rosters, and publish/unpublish class records.
        <% end %>
      </p>
    </div>
    <%= link_to new_admin_class_schedule_path,
        class: "inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-2.5 text-sm font-bold text-white shadow-md shadow-indigo-500/20 hover:from-indigo-500 hover:to-violet-500 hover:-translate-y-px transition-all duration-200" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      New Schedule
    <% end %>
  </div>

  <%# ── Tabs Navigation ── %>
  <div class="border-b border-slate-200 pb-px">
    <nav class="-mb-px flex gap-6" aria-label="Tabs">
      <%= link_to admin_class_schedules_path,
          class: "group relative inline-flex items-center gap-2 px-1 pb-4 text-sm font-bold transition-all duration-200 #{!@showing_past ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-slate-500 hover:text-slate-700 border-b-2 border-transparent'}" do %>
        <svg class="h-4 w-4 shrink-0 #{!@showing_past ? 'text-indigo-600' : 'text-slate-400 group-hover:text-slate-500'}" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
        </svg>
        <span>Upcoming Schedules</span>
        <span class="rounded-full px-2 py-0.5 text-xs font-bold ring-1 ring-inset #{!@showing_past ? 'bg-indigo-50 text-indigo-700 ring-indigo-600/10' : 'bg-slate-100 text-slate-600 ring-slate-200'}">
          <%= @upcoming_schedules_count %>
        </span>
      <% end %>

      <%= link_to admin_class_schedules_path(past: 1),
          class: "group relative inline-flex items-center gap-2 px-1 pb-4 text-sm font-bold transition-all duration-200 #{@showing_past ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-slate-500 hover:text-slate-700 border-b-2 border-transparent'}" do %>
        <svg class="h-4 w-4 shrink-0 #{@showing_past ? 'text-indigo-600' : 'text-slate-400 group-hover:text-slate-500'}" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Past Schedules</span>
        <span class="rounded-full px-2 py-0.5 text-xs font-bold ring-1 ring-inset #{@showing_past ? 'bg-indigo-50 text-indigo-700 ring-indigo-600/10' : 'bg-slate-100 text-slate-600 ring-slate-200'}">
          <%= @past_schedules_count %>
        </span>
      <% end %>
    </nav>
  </div>

  <%# ── Table Card ── %>
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @class_schedules.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-400">
              <th class="px-6 py-3.5 text-slate-400" scope="col">Course</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Date / Time Range</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Format / Location</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Registrations</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Views</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Status</th>
              <th class="px-6 py-3.5 text-right text-slate-400" scope="col">Actions</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">
            <% @class_schedules.each do |schedule| %>
              <tr class="group hover:bg-indigo-50/30 transition-colors">
                <%# Course Column %>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <% if schedule.course.logo.attached? %>
                      <%= image_tag schedule.course.logo, alt: "#{schedule.course.title} logo", class: "h-9 w-9 rounded-xl border border-slate-100 bg-slate-50 object-contain p-1 shrink-0 shadow-sm" %>
                    <% else %>
                      <div class="h-9 w-9 rounded-xl border border-slate-100 bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0 shadow-sm">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                        </svg>
                      </div>
                    <% end %>
                    <div>
                      <p class="font-semibold text-slate-900 leading-tight group-hover:text-indigo-600 transition-colors">
                        <%= link_to schedule.course.title, admin_class_schedule_path(schedule), class: "hover:underline underline-offset-2" %>
                      </p>
                      <p class="text-[11px] text-slate-400 font-mono mt-0.5">Capacity: <%= schedule.capacity %> seats</p>
                    </div>
                  </div>
                </td>

                <%# Date / Time Column %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <p class="text-sm font-semibold text-slate-700"><%= class_schedule_date_part(schedule) %></p>
                  <p class="text-[11px] text-slate-400 mt-0.5"><%= class_schedule_time_part(schedule) %></p>
                </td>

                <%# Format / Location Column %>
                <td class="px-6 py-4 text-slate-500 text-xs max-w-[200px]">
                  <% if schedule.online? %>
                    <span class="inline-flex items-center gap-1 font-bold text-indigo-600 bg-indigo-50 ring-1 ring-indigo-500/10 px-2 py-0.5 rounded-md text-[10px]">
                      <span class="h-1.5 w-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
                      Live Online
                    </span>
                  <% else %>
                    <span class="line-clamp-2 leading-relaxed font-semibold text-slate-700"><%= schedule.location %></span>
                  <% end %>
                </td>

                <%# Registrations Column %>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-1.5">
                    <span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-0.5 text-[10px] font-bold text-slate-500 ring-1 ring-inset ring-slate-200">
                      <%= schedule.registration_count %> Booked
                    </span>
                    <span class="inline-flex items-center rounded-md bg-slate-50 px-2 py-0.5 text-[10px] font-bold text-slate-400">
                      <%= schedule.remaining_seats %> Left
                    </span>
                  </div>
                </td>

                <%# Page views Column %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center gap-1 rounded-md bg-purple-50 px-2.5 py-1 text-xs font-bold text-purple-700 ring-1 ring-inset ring-purple-600/10">
                    <%= @page_view_counts[schedule.id] || 0 %>
                  </span>
                  <p class="text-[10px] text-slate-400 mt-1 font-medium">unique views</p>
                </td>

                <%# Status Column %>
                <td class="px-6 py-4">
                  <% if schedule.published? %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                      Published
                    </span>
                  <% elsif schedule.unpublished? %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-500/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                      Draft
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-slate-50 px-2.5 py-1 text-xs font-bold text-slate-500 ring-1 ring-inset ring-slate-500/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span>
                      Cancelled
                    </span>
                  <% end %>
                </td>

                <%# Action Buttons Column %>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to admin_class_schedule_path(schedule),
                        class: "inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-bold text-slate-600 hover:text-slate-900 hover:border-slate-300 hover:bg-slate-50 transition-all shadow-xs" do %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      View
                    <% end %>
                    <%= link_to edit_admin_class_schedule_path(schedule),
                        class: "inline-flex items-center gap-1 rounded-lg border border-indigo-100 bg-indigo-50 px-2.5 py-1.5 text-xs font-bold text-indigo-600 hover:bg-indigo-100 hover:border-indigo-200 hover:text-indigo-700 transition-all shadow-xs" do %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                      </svg>
                      Edit
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-20 text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100">
          <svg class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75" />
          </svg>
        </div>
        <% if @showing_past %>
          <p class="mt-4 text-base font-bold text-slate-700">No past class schedules</p>
          <p class="mt-1 text-sm text-slate-400">Completed classes will appear here once their start date has passed.</p>
          <%= link_to "Back to upcoming schedules", admin_class_schedules_path,
              class: "mt-5 inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-5 py-2.5 text-sm font-bold text-slate-700 shadow-sm hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700 transition-all" %>
        <% else %>
          <p class="mt-4 text-base font-bold text-slate-700">No upcoming class schedules</p>
          <p class="mt-1 text-sm text-slate-400">Get started by creating your first scheduled class event.</p>
          <%= link_to "Schedule a Class", new_admin_class_schedule_path,
              class: "mt-5 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-5 py-2.5 text-sm font-bold text-white shadow-md hover:from-indigo-500 hover:to-violet-500 transition-all" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
