<%= form_with model: [:admin, venue], class: "space-y-6" do |form| %>
  <% if venue.errors.any? %>
    <div class="rounded-xl border border-rose-100 bg-rose-50/70 p-4 text-sm font-semibold text-rose-800 shadow-sm flex items-center gap-2">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      <span><%= venue.errors.full_messages.to_sentence %></span>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Venue Name", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :name, placeholder: "e.g., Hotel Santika Slipi", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :address, "Full Address", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :address, placeholder: "e.g., Jl. Aipda KS Tubun No.7, Jakarta Pusat 10260", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center gap-4 border-t border-slate-100 pt-5">
    <%= form.submit class: "rounded-lg bg-teal-700 px-5 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-colors shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", venue.persisted? ? admin_venue_path(venue) : admin_venues_path, class: "rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm" %>
  </div>
<% end %>
