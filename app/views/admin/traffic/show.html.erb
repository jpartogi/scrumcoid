<% content_for :title, "Traffic Breakdown" %>

<section class="px-8 py-10 max-w-7xl space-y-8">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Traffic Breakdown</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">
        See which pages visitors open and where they come from.
        Reporting window uses <%= @report.reporting_timezone %> (<%= @report.reporting_timezone_abbr %>).
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <% @period_options.each do |days| %>
        <%= link_to admin_traffic_path(days: days),
            class: "inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all #{@report.days == days ? 'bg-indigo-600 text-white shadow-md shadow-indigo-500/20' : 'border border-slate-200 bg-white text-slate-600 hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700'}" do %>
          Last <%= days %> days
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-3">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Unique Visitors</p>
      <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @report.total_unique_visitors %></p>
      <p class="mt-1 text-xs font-semibold text-slate-500">
        <%= @report.period_start_on.strftime("%d %b %Y") %> – <%= @report.period_end_on.strftime("%d %b %Y") %>
      </p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Tracked Pages</p>
      <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @report.tracked_page_count %></p>
      <p class="mt-1 text-xs font-semibold text-slate-500">Top pages in this period</p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Countries Detected</p>
      <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @report.top_countries.size %></p>
      <% if @report.unknown_country_visitors.positive? %>
        <p class="mt-1 text-xs font-semibold text-slate-500"><%= @report.unknown_country_visitors %> visitors without country data</p>
      <% else %>
        <p class="mt-1 text-xs font-semibold text-slate-500">Based on CDN geo headers</p>
      <% end %>
    </div>
  </div>

  <div class="grid gap-8 xl:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
      <div class="border-b border-slate-100 px-6 py-4">
        <h2 class="text-lg font-bold text-slate-900">Top Pages</h2>
        <p class="text-sm text-slate-500 mt-0.5">Unique visitors per page path</p>
      </div>

      <% if @report.top_pages.any? %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-400">
                <th class="px-6 py-3.5" scope="col">Page</th>
                <th class="px-6 py-3.5" scope="col">Path</th>
                <th class="px-6 py-3.5 text-right" scope="col">Visitors</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @report.top_pages.each do |row| %>
                <tr class="hover:bg-indigo-50/30 transition-colors">
                  <td class="px-6 py-4 font-semibold text-slate-900"><%= row.label %></td>
                  <td class="px-6 py-4 font-mono text-xs text-slate-500"><%= row.path %></td>
                  <td class="px-6 py-4 text-right">
                    <span class="inline-flex items-center rounded-md bg-purple-50 px-2.5 py-1 text-xs font-bold text-purple-700 ring-1 ring-inset ring-purple-600/10">
                      <%= row.unique_views %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-16 text-center">
          <p class="text-base font-bold text-slate-700">No page traffic yet</p>
          <p class="mt-1 text-sm text-slate-400">Visitor page views will appear here once traffic is recorded.</p>
        </div>
      <% end %>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
      <div class="border-b border-slate-100 px-6 py-4">
        <h2 class="text-lg font-bold text-slate-900">Visitors by Country</h2>
        <p class="text-sm text-slate-500 mt-0.5">Unique visitors grouped by detected country</p>
      </div>

      <% if @report.top_countries.any? %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-400">
                <th class="px-6 py-3.5" scope="col">Country</th>
                <th class="px-6 py-3.5" scope="col">Code</th>
                <th class="px-6 py-3.5 text-right" scope="col">Visitors</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @report.top_countries.each do |row| %>
                <tr class="hover:bg-indigo-50/30 transition-colors">
                  <td class="px-6 py-4 font-semibold text-slate-900"><%= row.country_name %></td>
                  <td class="px-6 py-4 font-mono text-xs text-slate-500"><%= row.country_code %></td>
                  <td class="px-6 py-4 text-right">
                    <span class="inline-flex items-center rounded-md bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/10">
                      <%= row.unique_visitors %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-16 text-center">
          <p class="text-base font-bold text-slate-700">No country data yet</p>
          <p class="mt-1 text-sm text-slate-400">Country is detected from CDN headers such as CF-IPCountry.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>