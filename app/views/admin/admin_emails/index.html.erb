<section class="px-8 py-10 max-w-7xl mx-auto space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Manage Admin Emails</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Configure email recipients for PDF quotations generated during user registration.</p>
    </div>
    <div>
      <%= link_to new_admin_admin_email_path, class: "inline-flex items-center gap-1.5 rounded-lg bg-teal-700 px-4 py-2.5 text-sm font-bold text-white hover:bg-teal-800 shadow-sm transition-colors" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Add Admin Email
      <% end %>
    </div>
  </div>

  <!-- Table Container Card -->
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @admin_emails.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold">
              <th class="px-6 py-4">Email Address</th>
              <th class="px-6 py-4">Notification List</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @admin_emails.each do |admin_email| %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4 font-semibold text-slate-900 leading-tight">
                  <%= admin_email.email %>
                </td>
                <td class="px-6 py-4">
                  <% if admin_email.main? %>
                    <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Main Recipient (To)</span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-slate-50 px-2.5 py-0.5 text-xs font-bold text-slate-500 ring-1 ring-inset ring-slate-500/10">CC Recipient (Cc)</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="inline-flex gap-2 justify-end">
                    <%= link_to "Edit", edit_admin_admin_email_path(admin_email), class: "inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 bg-indigo-50/50 px-2.5 py-1.5 rounded-lg border border-indigo-100 transition-colors" %>
                    <%= button_to "Delete", admin_admin_email_path(admin_email), method: :delete, data: { confirm: "Are you sure you want to delete this email configuration?" }, class: "inline-flex items-center gap-1 text-xs font-bold text-rose-600 hover:text-rose-500 bg-rose-50/50 px-2.5 py-1.5 rounded-lg border border-rose-100 transition-colors cursor-pointer" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center text-slate-400">
        <svg class="mx-auto h-16 w-16 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <p class="mt-4 font-semibold text-base">No admin emails configured yet</p>
        <p class="text-xs text-slate-400 mt-1">Add emails to receive PDF quotation notices for new course registrations.</p>
        <%= link_to "Add Admin Email", new_admin_admin_email_path, class: "mt-4 inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-bold text-white hover:bg-indigo-500 shadow-sm transition-colors" %>
      </div>
    <% end %>
  </div>
</section>
