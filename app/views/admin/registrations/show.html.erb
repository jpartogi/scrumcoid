<div class="max-w-4xl mx-auto p-8">
  <div class="flex justify-between items-start mb-8">
    <div>
      <h1 class="text-2xl font-bold">Registration #<%= @registration.id %></h1>
      <p class="text-slate-500"><%= @registration.company_name %></p>
    </div>
    <%= link_to "Back to List", admin_registrations_path, class: "text-sm font-bold text-slate-600 hover:text-slate-900" %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Training Schedule Info -->
    <div class="bg-white border border-slate-200 rounded-3xl p-6 lg:col-span-2 shadow-sm">
      <h3 class="font-bold mb-4 text-slate-900">Training Schedule</h3>
      <% if @registration.class_schedule.present? %>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <p class="text-lg font-extrabold text-slate-900"><%= @registration.class_schedule.course.title %></p>
            <p class="text-sm font-semibold text-indigo-600 mt-1">
              <%= @registration.class_schedule.starts_at.strftime("%d %b") %> - <%= @registration.class_schedule.ends_at.strftime("%d %b %Y") %>
            </p>
            <p class="text-xs text-slate-500 mt-1">Location: <%= @registration.class_schedule.location %></p>
          </div>
          <div>
            <%= link_to admin_class_schedule_path(@registration.class_schedule), class: "inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-bold text-white hover:bg-indigo-500 shadow-sm transition-colors" do %>
              View Class Schedule
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            <% end %>
          </div>
        </div>
      <% else %>
        <p class="text-sm text-slate-500 italic">No associated class schedule found.</p>
      <% end %>
    </div>
    <!-- Finance Info -->
    <div class="bg-white border border-slate-200 rounded-3xl p-6">
      <h3 class="font-bold mb-4">Finance / Billing Contact</h3>
      <dl class="space-y-3 text-sm">
        <div><dt class="text-slate-500">Name</dt><dd class="font-medium"><%= @registration.finance_name %></dd></div>
        <div><dt class="text-slate-500">Email</dt><dd><%= @registration.finance_email %></dd></div>
        <div><dt class="text-slate-500">Company</dt><dd><%= @registration.company_name %></dd></div>
        <div><dt class="text-slate-500">Address</dt><dd class="whitespace-pre-line"><%= @registration.company_address %></dd></div>
        <div><dt class="text-slate-500">Phone</dt><dd><%= @registration.company_phone %></dd></div>
      </dl>
    </div>

    <!-- Participants -->
    <div class="bg-white border border-slate-200 rounded-3xl p-6">
      <h3 class="font-bold mb-4">Participants (<%= @registration.total_participants %>)</h3>
      <ul class="space-y-3 text-sm">
        <% @registration.enrollments.each do |enrollment| %>
          <li class="border-b pb-3 last:border-0">
            <div class="font-medium"><%= enrollment.visitor_name || enrollment.attendee_name %></div>
            <div class="text-slate-500"><%= enrollment.visitor_email || enrollment.attendee_email %></div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="mt-8 text-sm text-slate-500">
    Status: <span class="font-semibold text-slate-900"><%= @registration.status.humanize %></span><br>
    Requested on: <%= @registration.created_at.strftime("%d %b %Y %H:%M") %>
  </div>
</div>
