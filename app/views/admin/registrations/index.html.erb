<section class="px-8 py-10 max-w-7xl mx-auto space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Company Registrations & Quotations</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Monitor company registrations, billing profiles, and participant counts.</p>
    </div>
  </div>

  <!-- Table Container Card -->
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @registrations.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold">
              <th class="px-6 py-4">Company</th>
              <th class="px-6 py-4">Training Schedule</th>
              <th class="px-6 py-4">Finance Contact</th>
              <th class="px-6 py-4 text-center">Participants</th>
              <th class="px-6 py-4">Status</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @registrations.each do |reg| %>
              <%# Per-row delete dialog %>
              <dialog id="delete-reg-<%= reg.id %>-dialog"
                      class="rounded-2xl shadow-2xl border border-rose-100 p-0 w-full max-w-md backdrop:bg-slate-900/50 backdrop:backdrop-blur-sm">
                <div class="p-8">
                  <div class="flex items-center justify-center h-14 w-14 rounded-full bg-rose-50 ring-8 ring-rose-50/40 mx-auto">
                    <svg class="h-7 w-7 text-rose-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                    </svg>
                  </div>
                  <div class="mt-5 text-center">
                    <h2 class="text-lg font-extrabold text-slate-900">Delete Registration?</h2>
                    <p class="mt-2 text-sm text-slate-500 leading-relaxed">
                      Permanently delete Registration <span class="font-bold text-slate-800">#<%= reg.id %></span>
                      for <span class="font-bold text-slate-800"><%= reg.company_name %></span>?
                    </p>
                    <div class="mt-3 inline-flex items-center gap-2 rounded-lg bg-rose-50 border border-rose-100 px-4 py-2.5 text-sm font-semibold text-rose-700">
                      <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                      </svg>
                      <span><%= reg.total_participants %> enrollment<%= reg.total_participants == 1 ? "" : "s" %> will also be deleted.</span>
                    </div>
                    <p class="mt-4 text-xs text-slate-400">This action is <strong>irreversible</strong>.</p>
                  </div>
                  <div class="mt-6 flex items-center gap-3">
                    <button type="button"
                            onclick="document.getElementById('delete-reg-<%= reg.id %>-dialog').close()"
                            class="flex-1 rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-all shadow-sm">
                      Cancel
                    </button>
                    <%= button_to admin_registration_path(reg), method: :delete,
                        form_class: "flex-1",
                        class: "w-full rounded-lg bg-rose-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-rose-700 transition-all shadow-sm cursor-pointer" do %>
                      Yes, Delete Permanently
                    <% end %>
                  </div>
                </div>
              </dialog>

              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4 font-semibold text-slate-900"><%= reg.company_name %></td>
                <td class="px-6 py-4">
                  <% if reg.class_schedule.present? %>
                    <%= link_to reg.course.title, admin_class_schedule_path(reg.class_schedule), class: "font-semibold text-indigo-600 hover:text-indigo-500 transition-colors" %><br>
                    <span class="text-xs text-slate-500 mt-0.5 block">
                      <%= reg.class_schedule.starts_at.strftime("%d %b") %> – <%= reg.class_schedule.ends_at.strftime("%d %b %Y") %>
                    </span>
                  <% else %>
                    <span class="text-slate-400 italic">No schedule</span>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <p class="font-medium text-slate-800"><%= reg.finance_name %></p>
                  <p class="text-xs text-slate-400 font-medium mt-0.5"><%= reg.finance_email %></p>
                </td>
                <td class="px-6 py-4 text-center font-bold text-slate-800"><%= reg.total_participants %></td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-semibold text-amber-700 ring-1 ring-inset ring-amber-600/20">
                    <%= reg.status.humanize %>
                  </span>
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to "View", admin_registration_path(reg), class: "inline-flex items-center gap-1 text-xs font-bold text-slate-600 hover:text-slate-900 bg-slate-50 px-2.5 py-1.5 rounded-lg border border-slate-200 transition-colors" %>
                    <button type="button"
                            onclick="document.getElementById('delete-reg-<%= reg.id %>-dialog').showModal()"
                            title="Delete registration"
                            class="inline-flex items-center gap-1 text-xs font-bold text-rose-500 hover:text-rose-700 bg-rose-50 hover:bg-rose-100 px-2.5 py-1.5 rounded-lg border border-rose-100 hover:border-rose-200 transition-colors">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center text-slate-400">
        <svg class="mx-auto h-16 w-16 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25" />
        </svg>
        <p class="mt-4 font-semibold text-base">No registrations received yet</p>
      </div>
    <% end %>
  </div>
</section>
