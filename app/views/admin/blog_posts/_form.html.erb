<%= form_with model: [:admin, blog_post], class: "space-y-6" do |form| %>
  <% if blog_post.errors.any? %>
    <div class="rounded-xl border border-rose-105 bg-rose-50/70 p-4 text-sm font-semibold text-rose-800 shadow-sm flex items-center gap-2">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      <span><%= blog_post.errors.full_messages.to_sentence %></span>
    </div>
  <% end %>

  <!-- Grid Row -->
  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <%= form.label :title, class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :title, placeholder: "e.g., Implementing Scrum with AI Tools", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>
    
    <div>
      <%= form.label :slug, class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :slug, placeholder: "e.g., implementing-scrum-with-ai-tools", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>
  </div>

  <div>
    <%= form.label :excerpt, class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_area :excerpt, rows: 2, placeholder: "A brief summary snippet of this blog post...", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :meta_keywords, "Meta Keywords (SEO)", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :meta_keywords, placeholder: "e.g., scrum, agile, software development", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :tags, "Tags", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :tags, placeholder: "e.g., scrum, agile, product management", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    <p class="mt-1.5 text-xs text-slate-500">Comma-separated tags displayed on the blog and used for related articles.</p>
  </div>

  <div>
    <%= form.label :body, class: "block text-sm font-bold text-slate-700" %>
    <div class="mt-1.5 block rounded-lg border border-slate-300 bg-white shadow-sm overflow-hidden focus-within:ring-2 focus-within:ring-teal-600/10 focus-within:border-teal-600 transition-all">
      <%= form.rich_text_area :body, class: "rich-text-editor-tall p-3 min-h-[20rem] focus:outline-none" %>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <%= form.label :published_at, "Publish Date / Time", class: "block text-sm font-bold text-slate-700" %>
      <%= form.datetime_field :published_at, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all" %>
    </div>
    
    <div>
      <%= form.label :status, class: "block text-sm font-bold text-slate-700" %>
      <%= form.select :status, BlogPost.statuses.keys.map { |k| [k.capitalize, k] }, {}, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all" %>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center gap-4 border-t border-slate-100 pt-5">
    <%= form.submit class: "rounded-lg bg-teal-700 px-5 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-colors shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", blog_post.persisted? ? admin_blog_post_path(blog_post) : admin_blog_posts_path, class: "rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm" %>
  </div>
<% end %>
