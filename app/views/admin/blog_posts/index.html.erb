<%
  # Helper: build the sort URL for a column, toggling direction
  def sort_link_params(column, current_sort, current_dir)
    new_dir = (current_sort == column && current_dir == "asc") ? "desc" : "asc"
    { sort: column, direction: new_dir }
  end
%>

<section class="px-8 py-10 max-w-7xl space-y-6">
  <%# ── Page Header ── %>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Blog Posts</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Compose, manage drafts, and publish trainer insights.</p>
    </div>
    <%= link_to new_admin_blog_post_path,
        class: "inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-2.5 text-sm font-bold text-white shadow-md shadow-indigo-500/20 hover:from-indigo-500 hover:to-violet-500 hover:-translate-y-px transition-all duration-200" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      New Post
    <% end %>
  </div>

  <%# ── Table Card ── %>
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @blog_posts.any? %>

      <%# Per-page + count toolbar %>
      <div class="flex flex-col gap-3 border-b border-slate-100 bg-slate-50/60 px-6 py-3 sm:flex-row sm:items-center sm:justify-between">
        <%= render "shared/per_page_selector", paginated: @blog_posts, url: admin_blog_posts_path %>
        <% if @blog_posts.total_pages > 1 %>
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@blog_posts, entry_name: "post") %>
          </p>
        <% end %>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-400">

              <%# ── Title column (sortable) ── %>
              <th class="px-6 py-3.5" scope="col">
                <%
                  t_active = @sort_column == "title"
                  t_asc    = t_active && @sort_direction == "asc"
                  t_params = sort_link_params("title", @sort_column, @sort_direction)
                %>
                <%= link_to admin_blog_posts_path(t_params.merge(per_page: params[:per_page])),
                    class: "group inline-flex items-center gap-1.5 rounded-md px-2 py-1 -ml-2 transition-all #{t_active ? 'text-indigo-600 bg-indigo-50 ring-1 ring-inset ring-indigo-100' : 'text-slate-400 hover:text-slate-700 hover:bg-slate-100'}" do %>
                  <span>Title</span>
                  <% if t_active %>
                    <%# Active: show solid directional chevron %>
                    <svg class="h-3.5 w-3.5 <%= t_asc ? '' : 'rotate-180' %> transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
                    </svg>
                  <% else %>
                    <%# Inactive: show neutral up-down icon %>
                    <svg class="h-3.5 w-3.5 opacity-40 group-hover:opacity-70 transition-opacity" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                    </svg>
                  <% end %>
                <% end %>
              </th>

              <%# Excerpt — not sortable %>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Excerpt</th>

              <%# Tags — not sortable %>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Tags</th>

              <%# ── Published Date column (sortable) ── %>
              <th class="px-6 py-3.5" scope="col">
                <%
                  d_active = @sort_column == "published_at"
                  d_asc    = d_active && @sort_direction == "asc"
                  d_params = sort_link_params("published_at", @sort_column, @sort_direction)
                %>
                <%= link_to admin_blog_posts_path(d_params.merge(per_page: params[:per_page])),
                    class: "group inline-flex items-center gap-1.5 rounded-md px-2 py-1 -ml-2 transition-all #{d_active ? 'text-indigo-600 bg-indigo-50 ring-1 ring-inset ring-indigo-100' : 'text-slate-400 hover:text-slate-700 hover:bg-slate-100'}" do %>
                  <span>Published</span>
                  <% if d_active %>
                    <svg class="h-3.5 w-3.5 <%= d_asc ? '' : 'rotate-180' %> transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
                    </svg>
                  <% else %>
                    <svg class="h-3.5 w-3.5 opacity-40 group-hover:opacity-70 transition-opacity" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                    </svg>
                  <% end %>
                <% end %>
              </th>

              <%# Page views %>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Views</th>

              <%# Status %>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Status</th>

              <%# Actions %>
              <th class="px-6 py-3.5 text-right text-slate-400" scope="col">Actions</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">
            <% @blog_posts.each do |post| %>
              <tr class="group hover:bg-indigo-50/30 transition-colors">

                <%# Title + slug %>
                <td class="px-6 py-4 max-w-[260px]">
                  <p class="font-semibold text-slate-900 leading-tight group-hover:text-indigo-600 transition-colors">
                    <%= link_to post.title, admin_blog_post_path(post), class: "hover:underline underline-offset-2" %>
                  </p>
                  <p class="text-[11px] text-slate-400 font-mono mt-0.5 truncate">/blog/<%= post.slug %></p>
                </td>

                <%# Excerpt %>
                <td class="px-6 py-4 text-slate-500 text-xs max-w-[240px]">
                  <span class="line-clamp-2 leading-relaxed"><%= post.excerpt.presence || "—" %></span>
                </td>

                <%# Tags %>
                <td class="px-6 py-4">
                  <% if post.tag_list.any? %>
                    <div class="flex flex-wrap gap-1">
                      <% post.tag_list.first(3).each do |tag| %>
                        <span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-0.5 text-[10px] font-bold text-slate-500 ring-1 ring-inset ring-slate-200">
                          #<%= tag %>
                        </span>
                      <% end %>
                      <% if post.tag_list.size > 3 %>
                        <span class="inline-flex items-center rounded-md bg-slate-50 px-2 py-0.5 text-[10px] font-bold text-slate-400">
                          +<%= post.tag_list.size - 3 %>
                        </span>
                      <% end %>
                    </div>
                  <% else %>
                    <span class="text-xs text-slate-300">—</span>
                  <% end %>
                </td>

                <%# Published date %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if post.published_at.present? %>
                    <p class="text-sm font-semibold text-slate-700"><%= post.published_at.to_date.strftime("%d %b %Y") %></p>
                    <p class="text-[11px] text-slate-400 mt-0.5"><%= post.published_at.to_date.strftime("%A") %></p>
                  <% else %>
                    <span class="text-xs text-slate-400 italic">Not set</span>
                  <% end %>
                </td>

                <%# Page views %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center gap-1 rounded-md bg-purple-50 px-2.5 py-1 text-xs font-bold text-purple-700 ring-1 ring-inset ring-purple-600/10">
                    <%= @page_view_counts[post.id] || 0 %>
                  </span>
                  <p class="text-[10px] text-slate-400 mt-1 font-medium">unique views</p>
                </td>

                <%# Status badge %>
                <td class="px-6 py-4">
                  <% if post.published? %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                      Published
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-500/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                      Draft
                    </span>
                  <% end %>
                </td>

                <%# Action buttons %>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to admin_blog_post_path(post),
                        class: "inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-bold text-slate-600 hover:text-slate-900 hover:border-slate-300 hover:bg-slate-50 transition-all shadow-xs" do %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      View
                    <% end %>
                    <%= link_to edit_admin_blog_post_path(post),
                        class: "inline-flex items-center gap-1 rounded-lg border border-indigo-100 bg-indigo-50 px-2.5 py-1.5 text-xs font-bold text-indigo-600 hover:bg-indigo-100 hover:border-indigo-200 hover:text-indigo-700 transition-all shadow-xs" do %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                      </svg>
                      Edit
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# Pagination footer %>
      <% if @blog_posts.total_pages > 1 %>
        <div class="flex flex-col gap-3 border-t border-slate-100 bg-slate-50/60 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@blog_posts, entry_name: "post") %>
          </p>
          <%= render "shared/pagination", paginated: @blog_posts, path: method(:admin_blog_posts_path) %>
        </div>
      <% end %>

    <% else %>
      <%# Empty state %>
      <div class="px-6 py-20 text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100">
          <svg class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <p class="mt-4 text-base font-bold text-slate-700">No blog posts yet</p>
        <p class="mt-1 text-sm text-slate-400">Get started by writing your first post.</p>
        <%= link_to "Write your first post", new_admin_blog_post_path,
            class: "mt-5 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-5 py-2.5 text-sm font-bold text-white shadow-md hover:from-indigo-500 hover:to-violet-500 transition-all" %>
      </div>
    <% end %>
  </div>
</section>