<section class="px-8 py-10 max-w-7xl space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">CRM / Customer Management</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Manage accounts, corporate billing contact details, and their training registration histories.</p>
    </div>
  </div>

  <!-- Search Filter Container -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm flex flex-col sm:flex-row items-center gap-4">
    <%= form_tag admin_customers_path, method: :get, class: "w-full flex flex-col sm:flex-row items-center gap-4" do %>
      <div class="relative flex-grow w-full">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
        </div>
        <%= text_field_tag :query, params[:query], placeholder: "Search by company name, contact person, or email...", class: "block w-full pl-10 pr-4 py-2.5 rounded-lg border border-slate-300 bg-white text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 text-sm shadow-sm" %>
      </div>
      <div class="flex gap-2 w-full sm:w-auto">
        <%= submit_tag "Search", class: "w-full sm:w-auto inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-indigo-500 shadow-sm transition-colors cursor-pointer" %>
        <% if params[:query].present? %>
          <%= link_to "Clear", admin_customers_path, class: "w-full sm:w-auto inline-flex items-center justify-center rounded-lg bg-slate-50 border border-slate-300 px-4 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-100 shadow-sm transition-colors" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Table Container Card -->
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @customers.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold">
              <th class="px-6 py-4">Company Details</th>
              <th class="px-6 py-4">Finance Contact</th>
              <th class="px-6 py-4">Phone / Contact</th>
              <th class="px-6 py-4 text-center">Registrations</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @customers.each do |customer| %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4">
                  <p class="font-semibold text-slate-900 leading-tight">
                    <%= link_to customer.company_name, admin_customer_path(customer), class: "hover:text-indigo-600 transition-colors" %>
                  </p>
                  <% if customer.company_address.present? %>
                    <p class="text-xs text-slate-400 mt-1 truncate max-w-xs font-medium"><%= customer.company_address %></p>
                  <% else %>
                    <p class="text-xs text-slate-300 mt-1 font-medium italic">No address recorded</p>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <p class="font-semibold text-slate-700"><%= customer.finance_name %></p>
                  <p class="text-xs text-slate-400 font-medium mt-0.5"><%= customer.finance_email %></p>
                </td>
                <td class="px-6 py-4 text-slate-600 font-medium">
                  <%= customer.company_phone.presence || "—" %>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-700 ring-1 ring-inset ring-indigo-600/10">
                    <%= customer.respond_to?(:registrations_count) ? customer.registrations_count : customer.registrations.count %> total
                  </span>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="inline-flex gap-2">
                    <%= link_to "View", admin_customer_path(customer), class: "inline-flex items-center gap-1 text-xs font-bold text-slate-600 hover:text-slate-900 bg-slate-50 px-2.5 py-1.5 rounded-lg border border-slate-200 transition-colors" %>
                    <%= link_to "Edit", edit_admin_customer_path(customer), class: "inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 bg-indigo-50/50 px-2.5 py-1.5 rounded-lg border border-indigo-100 transition-colors" %>
                    <%= button_to "Delete", admin_customer_path(customer), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this customer record? This will delete all connected registrations!" }, class: "inline-flex items-center gap-1 text-xs font-bold text-rose-600 hover:text-rose-500 bg-rose-50/50 px-2.5 py-1.5 rounded-lg border border-rose-100 transition-colors cursor-pointer" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center text-slate-400">
        <svg class="mx-auto h-16 w-16 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
        <p class="mt-4 font-semibold text-base">No customers found</p>
        <p class="text-xs text-slate-400 mt-1">Either no registrations exist, or the search filter returned no results.</p>
      </div>
    <% end %>
  </div>
</section>
