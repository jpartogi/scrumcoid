<section class="px-8 py-10 max-w-4xl mx-auto space-y-6">
  <!-- Breadcrumbs & Header -->
  <div class="flex flex-col gap-2">
    <div class="flex items-center gap-2 text-xs font-semibold text-slate-500 uppercase tracking-wider">
      <%= link_to "CRM", admin_customers_path, class: "hover:text-indigo-600 transition-colors" %>
      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
      </svg>
      <%= link_to @customer.company_name, admin_customer_path(@customer), class: "hover:text-indigo-600 transition-colors" %>
      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
      </svg>
      <span>Edit</span>
    </div>
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 mt-2">Edit Customer Profile</h1>
    <p class="text-sm font-medium text-slate-500">Update company profile details, billing contact, or phone number.</p>
  </div>

  <!-- Form Card -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= render "form", customer: @customer %>
  </div>
</section>
