<div class="border-b border-slate-200 pb-px">
  <nav class="-mb-px flex gap-6" aria-label="CRM tabs">
    <%= link_to admin_customers_path,
        class: "group relative inline-flex items-center gap-2 px-1 pb-4 text-sm font-bold transition-all duration-200 #{controller_name == 'customers' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-slate-500 hover:text-slate-700 border-b-2 border-transparent'}" do %>
      <svg class="h-4 w-4 shrink-0 #{controller_name == 'customers' ? 'text-indigo-600' : 'text-slate-400 group-hover:text-slate-500'}" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008H17.25v-.008zm0 3h.008v.008H17.25V15zm0 3h.008v.008H17.25V18z" />
      </svg>
      <span>Customers</span>
      <span class="rounded-full px-2 py-0.5 text-xs font-bold ring-1 ring-inset #{controller_name == 'customers' ? 'bg-indigo-50 text-indigo-700 ring-indigo-600/10' : 'bg-slate-100 text-slate-600 ring-slate-200'}">
        <%= @customers_count %>
      </span>
    <% end %>

    <%= link_to admin_students_path,
        class: "group relative inline-flex items-center gap-2 px-1 pb-4 text-sm font-bold transition-all duration-200 #{controller_name == 'students' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-slate-500 hover:text-slate-700 border-b-2 border-transparent'}" do %>
      <svg class="h-4 w-4 shrink-0 #{controller_name == 'students' ? 'text-indigo-600' : 'text-slate-400 group-hover:text-slate-500'}" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
      </svg>
      <span>Students</span>
      <span class="rounded-full px-2 py-0.5 text-xs font-bold ring-1 ring-inset #{controller_name == 'students' ? 'bg-indigo-50 text-indigo-700 ring-indigo-600/10' : 'bg-slate-100 text-slate-600 ring-slate-200'}">
        <%= @students_count %>
      </span>
    <% end %>
  </nav>
</div>