<%
  stats = local_assigns.fetch(:stats)
  title = local_assigns.fetch(:title, "Page Traffic (7 Days)")
  gradient_id = local_assigns.fetch(:gradient_id, "page-chart-gradient")
%>

<div class="space-y-4">
  <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
    <svg class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
    </svg>
    <%= title %>
  </h2>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
    <%
      chart_days = stats.daily_visits_7_days.reverse
      max_count = [chart_days.map { |d| d[:count] }.max, 1].max

      width = 500
      height = 120
      padding_y = 15
      chart_height = height - (padding_y * 2)

      num_points = chart_days.size
      intervals = [num_points - 1, 1].max
      points = chart_days.each_with_index.map do |day, i|
        x = (i * (width.to_f / intervals)).round(1)
        y = (height - padding_y - (day[:count].to_f / max_count * chart_height)).round(1)
        [x, y]
      end

      line_path = points.each_with_index.map { |p, i| "#{i == 0 ? 'M' : 'L'} #{p[0]} #{p[1]}" }.join(" ")
      area_path = "#{line_path} L #{width} #{height} L 0 #{height} Z"
    %>

    <div class="relative w-full">
      <svg viewBox="0 0 <%= width %> <%= height %>" class="w-full h-auto overflow-visible" preserveAspectRatio="none">
        <defs>
          <linearGradient id="<%= gradient_id %>" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#c084fc" stop-opacity="0.4" />
            <stop offset="100%" stop-color="#c084fc" stop-opacity="0.0" />
          </linearGradient>
        </defs>

        <line x1="0" y1="<%= padding_y %>" x2="<%= width %>" y2="<%= padding_y %>" stroke="#f1f5f9" stroke-width="1" />
        <line x1="0" y1="<%= height / 2 %>" x2="<%= width %>" y2="<%= height / 2 %>" stroke="#f1f5f9" stroke-width="1" />
        <line x1="0" y1="<%= height - padding_y %>" x2="<%= width %>" y2="<%= height - padding_y %>" stroke="#e2e8f0" stroke-width="1" />

        <path d="<%= area_path %>" fill="url(#<%= gradient_id %>)" />
        <path d="<%= line_path %>" fill="none" stroke="#9333ea" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />

        <% points.each_with_index do |p, i| %>
          <g class="group/dot cursor-pointer">
            <circle cx="<%= p[0] %>" cy="<%= p[1] %>" r="5" fill="#ffffff" stroke="#9333ea" stroke-width="2" class="transition-all duration-200 group-hover/dot:r-7 group-hover/dot:stroke-width-3" />
            <title><%= chart_days[i][:date].strftime("%a, %b %d") %>: <%= chart_days[i][:count] %> views</title>
          </g>
        <% end %>
      </svg>

      <div class="flex justify-between mt-2 px-1 text-[10px] font-bold text-slate-400">
        <% chart_days.each do |day| %>
          <span><%= day[:date].strftime("%a") %></span>
        <% end %>
      </div>
    </div>

    <div class="divide-y divide-slate-100 border-t border-slate-100 pt-2">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3 mt-1">Daily unique views</p>
      <% stats.daily_visits_7_days.each do |day| %>
        <div class="flex items-center justify-between py-2.5 hover:bg-slate-50/50 rounded-lg px-2 -mx-2 transition-colors">
          <div class="flex items-center gap-2">
            <span class="text-xs font-semibold px-2 py-1 rounded <%= day[:date] == Date.today ? 'bg-purple-100 text-purple-800 font-bold' : 'bg-slate-100 text-slate-600 font-medium' %>">
              <%= day[:date].strftime("%a, %b %d") %>
            </span>
            <% if day[:date] == Date.today %>
              <span class="text-[10px] uppercase font-bold tracking-wider text-purple-600 animate-pulse">Live</span>
            <% end %>
          </div>
          <div class="flex items-center gap-1">
            <span class="font-extrabold text-slate-800 text-sm"><%= day[:count] %></span>
            <span class="text-xs text-slate-400 font-medium">views</span>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-4 pt-4 border-t border-slate-100">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">30-day snapshot</p>
      <div class="grid grid-cols-3 gap-3 text-center">
        <div>
          <div class="text-[10px] uppercase tracking-wider text-slate-400">Avg / day</div>
          <div class="text-xl font-extrabold text-slate-900"><%= stats.avg_daily_visits_30d %></div>
        </div>
        <div>
          <div class="text-[10px] uppercase tracking-wider text-slate-400">Peak day</div>
          <div class="text-xl font-extrabold text-slate-900"><%= stats.peak_daily_visits_30d %></div>
        </div>
        <div>
          <div class="text-[10px] uppercase tracking-wider text-slate-400">Unique (30d)</div>
          <div class="text-xl font-extrabold text-slate-900"><%= stats.unique_visitors_30d %></div>
        </div>
      </div>
      <p class="mt-2 text-[10px] text-slate-400">
        Total unique views: <span class="font-semibold text-slate-600"><%= stats.total_unique_views %></span>
        (same visitor counts once per day, matching site-wide dashboard metrics)
      </p>
    </div>
  </div>
</div>