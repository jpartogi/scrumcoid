<%= form_with model: [:admin, admin_contact], class: "space-y-6" do |form| %>
  <% if admin_contact.errors.any? %>
    <div class="rounded-xl border border-rose-100 bg-rose-50/70 p-4 text-sm font-semibold text-rose-800 shadow-sm flex items-center gap-2">
      <svg class="h-5 w-5 text-rose-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      <span><%= admin_contact.errors.full_messages.to_sentence %></span>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Contact Name", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :name, placeholder: "e.g., Joshua Partogi", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :email, "Email Address", class: "block text-sm font-bold text-slate-700" %>
    <%= form.email_field :email, placeholder: "e.g., admin@scrumcoid.com", required: true, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :whatsapp_number, "WhatsApp Number", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :whatsapp_number, placeholder: "e.g., +628123456789", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div class="relative flex items-start">
    <div class="flex h-6 items-center">
      <%= form.check_box :main, class: "h-4 w-4 rounded border-slate-300 text-teal-600 focus:ring-teal-600" %>
    </div>
    <div class="ml-3 text-sm leading-6">
      <%= form.label :main, "Main Admin Contact", class: "font-bold text-slate-750 cursor-pointer" %>
      <p class="text-xs text-slate-500 font-medium">Main contacts will be placed in the <strong>To</strong> field in email notifications, while others will be in the <strong>CC</strong> field.</p>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="flex items-center gap-4 border-t border-slate-100 pt-5">
    <%= form.submit admin_contact.new_record? ? "Create Admin contacts" : "Update Admin contacts", class: "rounded-lg bg-teal-700 px-5 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-colors shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", admin_admin_contacts_path, class: "rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm" %>
  </div>
<% end %>
