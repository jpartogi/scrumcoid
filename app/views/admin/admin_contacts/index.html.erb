<section class="px-8 py-10 max-w-7xl space-y-6">
  <!-- Page Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Manage Admin Contacts</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Configure admin emails and WhatsApp numbers to receive notifications and manage customer communications.</p>
    </div>
    <div>
      <%= link_to new_admin_admin_contact_path, class: "inline-flex items-center gap-1.5 rounded-lg bg-teal-700 px-4 py-2.5 text-sm font-bold text-white hover:bg-teal-800 shadow-sm transition-colors" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Add Admin Contact
      <% end %>
    </div>
  </div>

  <!-- Table Container Card -->
  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @admin_contacts.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-bold">
              <th class="px-6 py-4">Name</th>
              <th class="px-6 py-4">Email Address</th>
              <th class="px-6 py-4">WhatsApp</th>
              <th class="px-6 py-4">Notification List</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @admin_contacts.each do |admin_contact| %>
              <tr class="hover:bg-slate-50/50 transition-colors">
                <td class="px-6 py-4 font-semibold text-slate-900 leading-tight">
                  <%= admin_contact.name.presence || "-" %>
                </td>
                <td class="px-6 py-4 text-slate-700 font-medium">
                  <%= admin_contact.email %>
                </td>
                <td class="px-6 py-4 font-medium text-slate-700">
                  <% if admin_contact.whatsapp_number.present? %>
                    <span class="inline-flex items-center gap-1">
                      <svg class="h-4 w-4 text-emerald-600 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12.012 2c-5.506 0-9.988 4.482-9.988 9.988 0 1.761.46 3.473 1.332 4.978l-1.35 4.928 5.043-1.322a9.92 9.92 0 0 0 4.963 1.326c5.506 0 9.988-4.482 9.988-9.988C22 6.482 17.518 2 12.012 2zm0 18.286c-1.576 0-3.12-.422-4.475-1.22l-.32-.19-3.327.872.888-3.242-.208-.33a8.27 8.27 0 0 1-1.267-4.488c0-4.57 3.719-8.289 8.289-8.289s8.289 3.719 8.289 8.289-3.719 8.289-8.289 8.289zm4.553-6.2c-.25-.125-1.477-.73-1.705-.812-.228-.083-.393-.125-.558.125-.165.25-.638.812-.782.977-.144.165-.289.186-.539.062a6.793 6.793 0 0 1-2.001-1.233c-.78-.696-1.306-1.555-1.46-1.815-.152-.26-.016-.4.108-.524.112-.112.25-.292.375-.438.125-.146.166-.25.25-.417.083-.167.042-.313-.021-.438-.063-.125-.558-1.344-.764-1.844-.2-.489-.404-.423-.558-.43-.145-.008-.31-.008-.475-.008t-.433.062c-.165.063-.63.247-.784.57a2.535 2.535 0 0 0-.792 1.884c0 1.11.808 2.181.92 2.333.112.152 1.59 2.428 3.852 3.402.538.232.958.37 1.286.474.54.172 1.03.148 1.417.09.432-.064 1.477-.604 1.684-1.166.206-.563.206-1.041.144-1.146-.062-.105-.227-.167-.477-.292z"/>
                      </svg>
                      <%= admin_contact.whatsapp_number %>
                    </span>
                  <% else %>
                    <span class="text-slate-400 italic">None</span>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <% if admin_contact.main? %>
                    <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Main Recipient (To)</span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-slate-50 px-2.5 py-0.5 text-xs font-bold text-slate-500 ring-1 ring-inset ring-slate-500/10">CC Recipient (Cc)</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="inline-flex gap-2 justify-end">
                    <%= link_to "Edit", edit_admin_admin_contact_path(admin_contact), class: "inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 bg-indigo-50/50 px-2.5 py-1.5 rounded-lg border border-indigo-100 transition-colors" %>
                    <%= button_to "Delete", admin_admin_contact_path(admin_contact), method: :delete, data: { confirm: "Are you sure you want to delete this contact configuration?" }, class: "inline-flex items-center gap-1 text-xs font-bold text-rose-600 hover:text-rose-500 bg-rose-50/50 px-2.5 py-1.5 rounded-lg border border-rose-100 transition-colors cursor-pointer" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-16 text-center text-slate-400">
        <svg class="mx-auto h-16 w-16 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" />
        </svg>
        <p class="mt-4 font-semibold text-base">No admin contacts configured yet</p>
        <p class="text-xs text-slate-400 mt-1">Add admin names, emails, and WhatsApp numbers to receive notifications and manage customer communications.</p>
        <%= link_to "Add Admin Contact", new_admin_admin_contact_path, class: "mt-4 inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-bold text-white hover:bg-indigo-500 shadow-sm transition-colors" %>
      </div>
    <% end %>
  </div>
</section>
