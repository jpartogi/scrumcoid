<%
  def sort_link_params(column, current_sort, current_dir)
    new_dir = (current_sort == column && current_dir == "asc") ? "desc" : "asc"
    { sort: column, direction: new_dir }
  end
%>

<section class="px-8 py-10 max-w-7xl space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Resources</h1>
      <p class="text-sm font-medium text-slate-500 mt-1">Manage softcopy resources, pricing, and file attachments.</p>
    </div>
    <%= link_to new_admin_resource_path,
        class: "inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-2.5 text-sm font-bold text-white shadow-md shadow-indigo-500/20 hover:from-indigo-500 hover:to-violet-500 hover:-translate-y-px transition-all duration-200" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      New Resource
    <% end %>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @resources.any? %>
      <div class="flex flex-col gap-3 border-b border-slate-100 bg-slate-50/60 px-6 py-3 sm:flex-row sm:items-center sm:justify-between">
        <%= render "shared/per_page_selector", paginated: @resources, url: admin_resources_path %>
        <% if @resources.total_pages > 1 %>
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@resources, entry_name: "resource") %>
          </p>
        <% end %>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-400">
              <th class="px-6 py-3.5" scope="col">Cover</th>

              <th class="px-6 py-3.5" scope="col">
                <% t_active = @sort_column == "title"; t_asc = t_active && @sort_direction == "asc"; t_params = sort_link_params("title", @sort_column, @sort_direction) %>
                <%= link_to admin_resources_path(t_params.merge(per_page: params[:per_page])),
                    class: "group inline-flex items-center gap-1.5 rounded-md px-2 py-1 -ml-2 transition-all #{t_active ? 'text-indigo-600 bg-indigo-50 ring-1 ring-inset ring-indigo-100' : 'text-slate-400 hover:text-slate-700 hover:bg-slate-100'}" do %>
                  <span>Title</span>
                  <% if t_active %>
                    <svg class="h-3.5 w-3.5 <%= t_asc ? '' : 'rotate-180' %> transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
                    </svg>
                  <% end %>
                <% end %>
              </th>

              <th class="px-6 py-3.5 text-slate-400" scope="col">Tags</th>

              <th class="px-6 py-3.5" scope="col">
                <% p_active = @sort_column == "price"; p_asc = p_active && @sort_direction == "asc"; p_params = sort_link_params("price", @sort_column, @sort_direction) %>
                <%= link_to admin_resources_path(p_params.merge(per_page: params[:per_page])),
                    class: "group inline-flex items-center gap-1.5 rounded-md px-2 py-1 -ml-2 transition-all #{p_active ? 'text-indigo-600 bg-indigo-50 ring-1 ring-inset ring-indigo-100' : 'text-slate-400 hover:text-slate-700 hover:bg-slate-100'}" do %>
                  <span>Price</span>
                  <% if p_active %>
                    <svg class="h-3.5 w-3.5 <%= p_asc ? '' : 'rotate-180' %> transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
                    </svg>
                  <% end %>
                <% end %>
              </th>

              <th class="px-6 py-3.5" scope="col">
                <% d_active = @sort_column == "published_at"; d_asc = d_active && @sort_direction == "asc"; d_params = sort_link_params("published_at", @sort_column, @sort_direction) %>
                <%= link_to admin_resources_path(d_params.merge(per_page: params[:per_page])),
                    class: "group inline-flex items-center gap-1.5 rounded-md px-2 py-1 -ml-2 transition-all #{d_active ? 'text-indigo-600 bg-indigo-50 ring-1 ring-inset ring-indigo-100' : 'text-slate-400 hover:text-slate-700 hover:bg-slate-100'}" do %>
                  <span>Published</span>
                  <% if d_active %>
                    <svg class="h-3.5 w-3.5 <%= d_asc ? '' : 'rotate-180' %> transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
                    </svg>
                  <% end %>
                <% end %>
              </th>

              <th class="px-6 py-3.5 text-slate-400" scope="col">Klik</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Downloads</th>
              <th class="px-6 py-3.5 text-slate-400" scope="col">Status</th>
              <th class="px-6 py-3.5 text-right text-slate-400" scope="col">Actions</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100">
            <% @resources.each do |resource| %>
              <tr class="group hover:bg-indigo-50/30 transition-colors">
                <td class="px-6 py-4">
                  <% if resource.thumbnail.attached? %>
                    <%= image_tag resource.thumbnail, alt: resource.title, class: "h-12 w-20 rounded-lg border border-slate-200 object-cover" %>
                  <% else %>
                    <div class="h-12 w-20 rounded-lg border border-slate-200 bg-slate-50 flex items-center justify-center text-slate-300">
                      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
                      </svg>
                    </div>
                  <% end %>
                </td>

                <td class="px-6 py-4 max-w-[260px]">
                  <p class="font-semibold text-slate-900 leading-tight group-hover:text-indigo-600 transition-colors">
                    <%= link_to resource.title, admin_resource_path(resource), class: "hover:underline underline-offset-2" %>
                  </p>
                  <p class="text-[11px] text-slate-400 font-mono mt-0.5 truncate">/resources/<%= resource.slug %></p>
                  <% if resource.page_count.present? %>
                    <p class="text-[11px] text-slate-400 mt-0.5"><%= resource.page_count %> pages</p>
                  <% end %>
                </td>

                <td class="px-6 py-4">
                  <% if resource.tag_list.any? %>
                    <div class="flex flex-wrap gap-1">
                      <% resource.tag_list.first(3).each do |tag| %>
                        <span class="inline-flex items-center rounded-md bg-slate-100 px-2 py-0.5 text-[10px] font-bold text-slate-500 ring-1 ring-inset ring-slate-200">#<%= tag %></span>
                      <% end %>
                    </div>
                  <% else %>
                    <span class="text-xs text-slate-300">—</span>
                  <% end %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-bold ring-1 ring-inset <%= resource.free? ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/10' : 'bg-indigo-50 text-indigo-700 ring-indigo-600/10' %>">
                    <%= resource.free? ? "Free" : resource.display_price %>
                  </span>
                </td>

                <td class="px-6 py-4 whitespace-nowrap">
                  <% if resource.published_at.present? %>
                    <p class="text-sm font-semibold text-slate-700"><%= resource.published_at.to_date.strftime("%d %b %Y") %></p>
                  <% else %>
                    <span class="text-xs text-slate-400 italic">Not set</span>
                  <% end %>
                </td>

                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center gap-1 rounded-md bg-purple-50 px-2.5 py-1 text-xs font-bold text-purple-700 ring-1 ring-inset ring-purple-600/10" title="Unique page views">
                    <%= @page_view_counts[resource.id] || 0 %>
                  </span>
                </td>

                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center gap-1 rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-bold text-indigo-700 ring-1 ring-inset ring-indigo-600/10" title="Download form submissions">
                    <%= @download_counts[resource.id] || 0 %>
                  </span>
                </td>

                <td class="px-6 py-4">
                  <% if resource.published? %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                      Published
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-500/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                      Draft
                    </span>
                  <% end %>
                </td>

                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to admin_resource_path(resource), class: "inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-bold text-slate-600 hover:text-slate-900 hover:border-slate-300 hover:bg-slate-50 transition-all shadow-xs" do %>
                      View
                    <% end %>
                    <%= link_to edit_admin_resource_path(resource), class: "inline-flex items-center gap-1 rounded-lg border border-indigo-100 bg-indigo-50 px-2.5 py-1.5 text-xs font-bold text-indigo-600 hover:bg-indigo-100 transition-all shadow-xs" do %>
                      Edit
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @resources.total_pages > 1 %>
        <div class="flex flex-col gap-3 border-t border-slate-100 bg-slate-50/60 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@resources, entry_name: "resource") %>
          </p>
          <%= render "shared/pagination", paginated: @resources, path: method(:admin_resources_path) %>
        </div>
      <% end %>
    <% else %>
      <div class="px-6 py-20 text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100">
          <svg class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <p class="mt-4 text-base font-bold text-slate-700">No resources yet</p>
        <p class="mt-1 text-sm text-slate-400">Upload your first softcopy resource to get started.</p>
        <%= link_to "Create your first resource", new_admin_resource_path,
            class: "mt-5 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-5 py-2.5 text-sm font-bold text-white shadow-md hover:from-indigo-500 hover:to-violet-500 transition-all" %>
      </div>
    <% end %>
  </div>
</section>