<%= form_with model: [:admin, resource], html: { multipart: true }, class: "space-y-6" do |form| %>
  <% if resource.errors.any? %>
    <div class="rounded-xl border border-rose-105 bg-rose-50/70 p-4 text-sm font-semibold text-rose-800 shadow-sm flex items-center gap-2">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      <span><%= resource.errors.full_messages.to_sentence %></span>
    </div>
  <% end %>

  <div class="grid gap-6 md:grid-cols-2" data-controller="slug-generator" data-slug-generator-auto-value="<%= resource.new_record? %>">
    <div>
      <%= form.label :title, class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :title,
          placeholder: "e.g., Scrum Cheat Sheet untuk Product Owner",
          class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400",
          data: { slug_generator_target: "title", action: "input->slug-generator#generateSlug" } %>
    </div>

    <div>
      <%= form.label :slug, class: "block text-sm font-bold text-slate-700" %>
      <%= form.text_field :slug,
          placeholder: resource.new_record? ? "Otomatis dari judul, atau ketik slug sendiri" : "e.g., scrum-cheat-sheet-product-owner",
          class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400",
          data: { slug_generator_target: "slug", action: "input->slug-generator#markSlugManual" } %>
      <p class="mt-1.5 text-xs text-slate-500">
        <% if resource.new_record? %>
          Slug diisi otomatis dari judul. Kosongkan lalu ketik di sini jika ingin menggunakan slug kustom.
        <% else %>
          Ubah slug secara manual jika diperlukan. Mengubah judul tidak akan mengubah slug yang sudah ada.
        <% end %>
      </p>
    </div>
  </div>

  <div>
    <%= form.label :meta_description, "Meta Description (SEO)", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_area :meta_description, rows: 2, placeholder: "Ringkasan singkat untuk mesin pencari...", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :meta_keywords, "Meta Keywords (SEO)", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :meta_keywords, placeholder: "e.g., scrum, agile, product owner", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
  </div>

  <div>
    <%= form.label :tags, "Tags", class: "block text-sm font-bold text-slate-700" %>
    <%= form.text_field :tags, placeholder: "e.g., scrum, agile, product management", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    <p class="mt-1.5 text-xs text-slate-500">Comma-separated tags displayed on the resources page and used for related items.</p>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-bold text-slate-700" %>
    <div class="mt-1.5 block rounded-lg border border-slate-300 bg-white shadow-sm overflow-hidden focus-within:ring-2 focus-within:ring-teal-600/10 focus-within:border-teal-600 transition-all">
      <%= form.rich_text_area :description, class: "rich-text-editor-tall p-3 min-h-[20rem] focus:outline-none" %>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    <div>
      <%= form.label :page_count, "Number of Pages", class: "block text-sm font-bold text-slate-700" %>
      <%= form.number_field :page_count, min: 1, placeholder: "e.g., 24", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
    </div>

    <div>
      <%= form.label :price, class: "block text-sm font-bold text-slate-700" %>
      <%= form.number_field :price, min: 0, step: 0.01, placeholder: "0 for free", class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all placeholder:text-slate-400" %>
      <p class="mt-1.5 text-xs text-slate-500">Set to 0 for free resources.</p>
    </div>

    <div>
      <%= form.label :currency, class: "block text-sm font-bold text-slate-700" %>
      <%= form.select :currency, [["IDR (Indonesian Rupiah)", "IDR"], ["USD (US Dollar)", "USD"], ["AUD (Australian Dollar)", "AUD"], ["SGD (Singapore Dollar)", "SGD"]], {}, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all" %>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-slate-50/50 p-5 space-y-3">
    <%= form.label :thumbnail, "Thumbnail Image", class: "block text-sm font-bold text-slate-700" %>
    <div class="flex flex-wrap items-center gap-5">
      <% if resource.thumbnail.attached? && resource.thumbnail.attachment&.persisted? %>
        <%= image_tag resource.thumbnail, alt: "#{resource.title} thumbnail", class: "h-16 w-28 rounded-xl border border-slate-200 bg-white object-cover shadow-sm shrink-0" %>
        <div class="text-xs font-semibold text-slate-500">
          <p class="text-slate-900 leading-none">Current Thumbnail</p>
          <p class="mt-1 font-medium"><%= resource.thumbnail.filename %></p>
        </div>
      <% else %>
        <div class="h-16 w-28 rounded-xl border border-slate-200 bg-white text-slate-400 flex items-center justify-center shrink-0 shadow-inner">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
          </svg>
        </div>
      <% end %>

      <%= form.file_field :thumbnail, accept: "image/png,image/jpeg,image/webp,image/svg+xml", class: "block w-full max-w-xs text-xs text-slate-500 file:mr-4 file:rounded-lg file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-xs file:font-bold file:text-white hover:file:bg-teal-700 file:transition-colors file:cursor-pointer" %>
    </div>
    <p class="text-xs text-slate-400 font-medium">Upload a cover image for the resource listing and detail page.</p>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-slate-50/50 p-5 space-y-3">
    <%= form.label :file_attachment, "File Attachment (PDF / Excel)", class: "block text-sm font-bold text-slate-700" %>
    <div class="flex flex-wrap items-center gap-5">
      <% if resource.file_attachment.attached? && resource.file_attachment.attachment&.persisted? %>
        <div class="h-16 w-16 rounded-xl border border-slate-200 bg-white text-indigo-600 flex items-center justify-center shrink-0 shadow-sm">
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <div class="text-xs font-semibold text-slate-500">
          <p class="text-slate-900 leading-none">Current File</p>
          <p class="mt-1 font-medium"><%= resource.file_attachment.filename %></p>
          <p class="mt-0.5 text-slate-400"><%= resource.file_attachment.content_type %></p>
        </div>
      <% else %>
        <div class="h-16 w-16 rounded-xl border border-slate-200 bg-white text-slate-400 flex items-center justify-center shrink-0 shadow-inner">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
      <% end %>

      <%= form.file_field :file_attachment, accept: "application/pdf,.xlsx,.xls,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel", class: "block w-full max-w-md text-xs text-slate-500 file:mr-4 file:rounded-lg file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-xs file:font-bold file:text-white hover:file:bg-teal-700 file:transition-colors file:cursor-pointer" %>
    </div>
    <p class="text-xs text-slate-400 font-medium">Upload the softcopy file (PDF or Excel) that will be delivered to customers.</p>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <%= form.label :published_at, "Publish Date / Time", class: "block text-sm font-bold text-slate-700" %>
      <%= form.datetime_field :published_at, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all" %>
    </div>

    <div>
      <%= form.label :status, class: "block text-sm font-bold text-slate-700" %>
      <%= form.select :status, Resource.statuses.keys.map { |k| [k.capitalize, k] }, {}, class: "mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all" %>
    </div>
  </div>

  <div class="flex items-center gap-4 border-t border-slate-100 pt-5">
    <%= form.submit class: "rounded-lg bg-teal-700 px-5 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-colors shadow-sm cursor-pointer" %>
    <%= link_to "Cancel", resource.persisted? ? admin_resource_path(resource) : admin_resources_path, class: "rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm" %>
  </div>
<% end %>