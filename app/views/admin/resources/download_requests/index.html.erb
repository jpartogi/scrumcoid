<section class="px-8 py-10 max-w-7xl space-y-6">
  <div class="flex items-center justify-between border-b border-slate-200 pb-5">
    <div class="flex items-center gap-3">
      <%= link_to admin_resource_path(@resource), class: "p-2 rounded-lg border border-slate-200 bg-white text-slate-500 hover:text-slate-700 shadow-sm hover:shadow transition-all" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      <% end %>
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Download Requests</h1>
        <p class="text-xs text-slate-400 font-medium mt-1">
          People who requested <span class="font-semibold text-slate-600"><%= @resource.title %></span>
        </p>
      </div>
    </div>
    <span class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-700 ring-1 ring-inset ring-indigo-600/10">
      <%= @download_requests.total_count %> total
    </span>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
    <% if @download_requests.any? %>
      <div class="flex flex-col gap-3 border-b border-slate-100 bg-slate-50/60 px-6 py-3 sm:flex-row sm:items-center sm:justify-between">
        <%= render "shared/per_page_selector", paginated: @download_requests, url: admin_resource_download_requests_path(@resource) %>
        <% if @download_requests.total_pages > 1 %>
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@download_requests, entry_name: "request") %>
          </p>
        <% end %>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50 text-xs font-bold uppercase tracking-wider text-slate-400">
              <th class="px-6 py-3.5" scope="col">Name</th>
              <th class="px-6 py-3.5" scope="col">Email</th>
              <th class="px-6 py-3.5" scope="col">Job Title</th>
              <th class="px-6 py-3.5" scope="col">Requested At</th>
              <th class="px-6 py-3.5" scope="col">Email Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @download_requests.each do |request| %>
              <tr class="hover:bg-indigo-50/30 transition-colors">
                <td class="px-6 py-4 font-semibold text-slate-900"><%= request.visitor_name %></td>
                <td class="px-6 py-4">
                  <a href="mailto:<%= request.visitor_email %>" class="text-slate-600 font-medium hover:text-indigo-600 transition-colors">
                    <%= request.visitor_email %>
                  </a>
                </td>
                <td class="px-6 py-4 text-slate-600 font-medium"><%= request.job_title_label %></td>
                <td class="px-6 py-4 whitespace-nowrap text-slate-600 font-medium">
                  <%= request.created_at.to_fs(:long) %>
                </td>
                <td class="px-6 py-4">
                  <% if request.email_sent_at.present? %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                      Sent <%= request.email_sent_at.to_fs(:short) %>
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-500/20">
                      <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                      Pending
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @download_requests.total_pages > 1 %>
        <div class="flex flex-col gap-3 border-t border-slate-100 bg-slate-50/60 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs font-medium text-slate-500">
            <%= page_entries_info_for(@download_requests, entry_name: "request") %>
          </p>
          <%= render "shared/pagination", paginated: @download_requests, path: ->(**params) { admin_resource_download_requests_path(@resource, **params) } %>
        </div>
      <% end %>
    <% else %>
      <div class="px-6 py-20 text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100">
          <svg class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </div>
        <p class="mt-4 text-base font-bold text-slate-700">No download requests yet</p>
        <p class="mt-1 text-sm text-slate-400">When visitors submit the download form, their details will appear here.</p>
      </div>
    <% end %>
  </div>
</section>