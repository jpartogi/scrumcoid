<section class="px-8 py-10 max-w-7xl space-y-6">
  <div class="flex items-center justify-between border-b border-slate-200 pb-5">
    <div class="flex items-center gap-3">
      <%= link_to admin_resources_path, class: "p-2 rounded-lg border border-slate-200 bg-white text-slate-500 hover:text-slate-700 shadow-sm hover:shadow transition-all" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
      <% end %>
      <div>
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-3xl font-extrabold tracking-tight text-slate-900"><%= @resource.title %></h1>
          <% if @resource.published? %>
            <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Published</span>
          <% else %>
            <span class="inline-flex items-center rounded-full bg-slate-50 px-2.5 py-0.5 text-xs font-bold text-slate-500 ring-1 ring-inset ring-slate-500/10">Draft</span>
          <% end %>
        </div>
        <p class="text-xs text-slate-400 font-medium mt-1">Resource Details</p>
      </div>
    </div>
  </div>

  <%= render "stats_cards", stats: @page_view_stats, download_count: @download_count %>

  <div class="grid gap-8 lg:grid-cols-[1fr_320px] items-start">
    <div class="space-y-8">
      <% if @resource.thumbnail.attached? %>
        <div class="rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
          <%= image_tag @resource.thumbnail, alt: @resource.title, class: "w-full max-h-72 object-cover" %>
        </div>
      <% end %>

      <% if @resource.meta_description.present? %>
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Meta Description</h2>
          <p class="mt-4 text-base text-slate-600 leading-relaxed font-medium"><%= @resource.meta_description %></p>
        </div>
      <% end %>

      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Description</h2>
        <div class="mt-4 text-sm text-slate-700 leading-relaxed prose max-w-none">
          <%= @resource.description %>
        </div>
      </div>

      <%= render "admin/shared/page_traffic_panel", stats: @page_view_stats, title: "Resource Traffic (7 Days)", gradient_id: "resource-chart-gradient" %>
    </div>

    <div class="space-y-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-4">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-3">Resource properties</p>
        <dl class="grid gap-3 text-xs text-slate-700">
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Slug path</dt>
            <dd class="mt-1 text-slate-600 font-semibold">/resources/<%= @resource.slug %></dd>
          </div>
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Price</dt>
            <dd class="mt-1 text-slate-600 font-semibold"><%= @resource.free? ? "Free" : @resource.display_price %></dd>
          </div>
          <% if @resource.page_count.present? %>
            <div>
              <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Pages</dt>
              <dd class="mt-1 text-slate-600 font-semibold"><%= @resource.page_count %></dd>
            </div>
          <% end %>
          <div>
            <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Published At</dt>
            <dd class="mt-1 text-slate-600 font-semibold"><%= @resource.published_at&.to_date&.to_fs(:long) || "Not published" %></dd>
          </div>
          <% if @resource.meta_keywords.present? %>
            <div>
              <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Meta Keywords</dt>
              <dd class="mt-1 text-slate-600 font-semibold"><%= @resource.meta_keywords %></dd>
            </div>
          <% end %>
          <% if @resource.tags.present? %>
            <div>
              <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">Tags</dt>
              <dd class="mt-1 text-slate-600 font-semibold"><%= @resource.tags %></dd>
            </div>
          <% end %>
          <% if @resource.file_attachment.attached? %>
            <div>
              <dt class="font-bold text-slate-900 uppercase tracking-wider text-[10px]">File Attachment</dt>
              <dd class="mt-1 text-slate-600 font-semibold"><%= @resource.file_attachment.filename %></dd>
              <dd class="mt-0.5 text-slate-400"><%= @resource.file_attachment.content_type %></dd>
            </div>
          <% end %>
        </dl>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-3">
        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Operations</p>

        <%= link_to resource_path(@resource), target: "_blank", class: "flex items-center justify-center gap-1.5 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:border-slate-400 transition-all shadow-sm" do %>
          View In Site
          <svg class="h-4 w-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        <% end %>

        <%= link_to edit_admin_resource_path(@resource), class: "flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:border-slate-400 transition-all shadow-sm" do %>
          Edit Resource
        <% end %>

        <%= link_to admin_resource_download_requests_path(@resource), class: "flex items-center justify-center gap-2 rounded-lg border border-indigo-200 bg-indigo-50 px-4 py-2.5 text-sm font-semibold text-indigo-700 hover:bg-indigo-100 hover:border-indigo-300 transition-all shadow-sm" do %>
          View Downloaders
          <span class="inline-flex items-center rounded-full bg-indigo-100 px-2 py-0.5 text-[11px] font-bold text-indigo-800 ring-1 ring-inset ring-indigo-200">
            <%= @download_count %>
          </span>
        <% end %>

        <%= button_to @resource.published? ? "Unpublish Resource" : "Publish Resource", @resource.published? ? unpublish_admin_resource_path(@resource) : publish_admin_resource_path(@resource), method: :patch, class: "w-full rounded-lg bg-teal-700 px-4 py-2.5 text-sm font-bold text-white hover:bg-teal-800 transition-all cursor-pointer shadow-sm", form_class: "w-full" %>

        <%= button_to "Delete Resource", admin_resource_path(@resource), method: :delete, data: { confirm: "Are you sure you want to delete this resource?" }, class: "w-full rounded-lg border border-rose-200 bg-white px-4 py-2.5 text-sm font-semibold text-rose-600 hover:bg-rose-50 hover:border-rose-300 transition-all cursor-pointer shadow-sm", form_class: "w-full" %>
      </div>
    </div>
  </div>
</section>