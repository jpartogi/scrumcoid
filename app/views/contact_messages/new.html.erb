<% content_for :title, "Hubungi Kami | Pelatihan, Konsultasi & Sertifikasi Scrum Indonesia" %>
<section class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-82 w-82 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl lg:mx-0">
      <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
        Hubungi Kami
      </span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        Diskusikan Kebutuhan <br class="hidden sm:inline" />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-teal-300">Pelatihan Scrum</span> Anda
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-400">
        Gunakan formulir ini untuk permintaan kelas publik, pelatihan privat perusahaan, atau bimbingan konsultasi. Kami biasanya membalas dalam 2 hari kerja.
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      
      <!-- Kolom Kiri: Formulir Kontak -->
      <div class="lg:col-span-2 rounded-3xl border border-slate-200 bg-white p-8 sm:p-12 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-900 border-b border-slate-100 pb-4 mb-6">Kirim Pesan</h2>
        
        <%= form_with model: @contact_message, url: contact_path, class: "space-y-6" do |form| %>
          <% if @contact_message.errors.any? %>
            <div class="rounded-2xl bg-rose-50 border border-rose-100 p-4 text-sm text-rose-800 font-medium">
              <%= @contact_message.errors.full_messages.to_sentence %>
            </div>
          <% end %>

          <div class="grid gap-6 md:grid-cols-2">
            <div>
              <%= form.label :name, "Nama Lengkap", class: "block text-sm font-bold text-slate-700" %>
              <%= form.text_field :name, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
            </div>
            <div>
              <%= form.label :email, "Alamat Email", class: "block text-sm font-bold text-slate-700" %>
              <%= form.email_field :email, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
            </div>
          </div>

          <div>
            <%= form.label :company, "Nama Perusahaan / Organisasi", class: "block text-sm font-bold text-slate-700" %>
            <%= form.text_field :company, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            <div>
              <%= form.label :jenis_inkuiri, "Jenis Inkuiri", class: "block text-sm font-bold text-slate-700" %>
              <%= form.select :jenis_inkuiri, [
                ["Quotation Pelatihan Privat", "Quotation Pelatihan Privat"],
                ["Waiting List Pelatihan Publik", "Waiting List Pelatihan Publik"],
                ["Lainnya", "Lainnya"]
              ], {}, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
            </div>
            <div>
              <%= form.label :pelatihan, "Pilihan Pelatihan", class: "block text-sm font-bold text-slate-700" %>
              <%= form.select :pelatihan, Course.published.order(:title).pluck(:title, :title) + [["Lainnya (Other)", "Lainnya"]], {}, class: "mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
            </div>
          </div>

          <div>
            <%= form.label :message, "Pesan Anda", class: "block text-sm font-bold text-slate-700" %>
            <%= form.text_area :message, rows: 6, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
          </div>

          <div>
            <%= form.submit "Kirim Pesan", class: "w-full sm:w-auto inline-flex justify-center items-center rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-4.5 text-sm font-bold text-white hover:shadow-lg hover:shadow-indigo-500/15 hover:scale-[1.02] active:scale-[0.98] transition-all cursor-pointer" %>
          </div>
        <% end %>
      </div>

      <!-- Kolom Kanan: Sidebar Informasi Kontak -->
      <div class="space-y-6">
        <% if @main_contact.present? %>
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <h3 class="text-lg font-bold text-slate-900 border-b border-slate-100 pb-4 mb-6">Informasi Kontak</h3>
            
            <% if @main_contact.whatsapp_number.present? %>
              <% clean_wa = @main_contact.whatsapp_number.gsub(/[^0-9]/, '') %>
              <% clean_wa = "62" + clean_wa[1..-1] if clean_wa.start_with?("0") %>
              
              <div class="mb-6">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/10 mb-3">
                  Respon Cepat via WhatsApp
                </span>
                
                <div class="flex items-start gap-3.5 mb-4">
                  <div class="rounded-xl bg-emerald-500/10 p-2.5 text-emerald-600 shrink-0">
                    <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.739-1.456L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.963C16.48 2.012 14.005.992 11.37.992c-5.447 0-9.87 4.37-9.874 9.8.001 1.95.518 3.854 1.502 5.561l-.987 3.606 3.702-.97c1.644.896 3.23 1.365 4.834 1.365zm10.638-7.468c-.287-.143-1.696-.838-1.959-.933-.262-.095-.453-.143-.644.143-.19.287-.738.933-.905 1.124-.167.19-.333.214-.62.071-.287-.143-1.21-.446-2.305-1.424-.853-.76-1.428-1.7-1.595-1.986-.167-.286-.018-.44.125-.581.129-.127.287-.333.43-.5.143-.167.19-.286.287-.476.095-.19.047-.357-.024-.5-.071-.143-.644-1.547-.882-2.12-.232-.559-.467-.483-.644-.492-.167-.008-.358-.01-.55-.01-.19 0-.5.071-.762.357-.262.287-1 .977-1 2.38 0 1.405 1.023 2.762 1.166 2.953.143.19 2.013 3.074 4.877 4.31.681.294 1.213.47 1.627.601.684.218 1.307.187 1.8.114.55-.082 1.696-.692 1.935-1.36.239-.667.239-1.24.167-1.36-.072-.119-.262-.19-.549-.333z"/>
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-slate-800">WhatsApp</h4>
                    <p class="text-sm text-slate-500 mt-0.5">
                      <% if @main_contact.name.present? %>
                        Hubungi <strong><%= @main_contact.name %></strong>
                      <% else %>
                        Admin Kontak Utama
                      <% end %>
                    </p>
                    <p class="text-xs text-slate-400 mt-0.5"><%= @main_contact.whatsapp_number %></p>
                  </div>
                </div>

                <%= link_to "Chat Sekarang", "https://wa.me/#{clean_wa}", target: "_blank", rel: "noopener", class: "w-full inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-sm font-bold text-white hover:bg-emerald-700 shadow-sm hover:shadow-emerald-500/10 active:scale-[0.98] transition-all" %>
              </div>
            <% end %>

            
          </div>
        <% end %>

        <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-bold text-slate-900 mb-4">Jam Operasional</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            Senin - Jumat: 09:00 - 17:00 WIB<br>
            Sabtu, Minggu & Hari Libur Nasional: Tutup
          </p>
          <p class="text-xs text-slate-400 mt-4 leading-relaxed">
            Untuk permintaan pelatihan privat atau konsultasi luar kota, tim kami akan menghubungi Anda sesuai jadwal yang disepakati.
          </p>
        </div>
      </div>

    </div>
  </div>
</div>
