<section class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-82 w-82 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl lg:mx-0">
      <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
        Hubungi Kami
      </span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        Diskusikan Kebutuhan <br class="hidden sm:inline" />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-teal-300">Pelatihan Scrum</span> Anda
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-400">
        Gunakan formulir ini untuk pendaftaran kelas publik, pelatihan privat perusahaan, atau pertanyaan konsultasi. Kami biasanya membalas dalam 2 hari kerja.
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-3xl px-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-8 sm:p-12 shadow-sm">
      <h2 class="text-2xl font-bold text-slate-900 border-b border-slate-100 pb-4 mb-6">Kirim Pesan</h2>
      
      <%= form_with model: @contact_message, url: contact_path, class: "space-y-6" do |form| %>
        <% if @contact_message.errors.any? %>
          <div class="rounded-2xl bg-rose-50 border border-rose-100 p-4 text-sm text-rose-800 font-medium">
            <%= @contact_message.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <%= form.label :name, "Nama Lengkap", class: "block text-sm font-bold text-slate-700" %>
            <%= form.text_field :name, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
          </div>
          <div>
            <%= form.label :email, "Alamat Email", class: "block text-sm font-bold text-slate-700" %>
            <%= form.email_field :email, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
          </div>
        </div>

        <div>
          <%= form.label :company, "Nama Perusahaan / Organisasi", class: "block text-sm font-bold text-slate-700" %>
          <%= form.text_field :company, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
        </div>

        <div>
          <%= form.label :subject, "Subjek", class: "block text-sm font-bold text-slate-700" %>
          <%= form.text_field :subject, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
        </div>

        <div>
          <%= form.label :message, "Pesan Anda", class: "block text-sm font-bold text-slate-700" %>
          <%= form.text_area :message, rows: 6, class: "mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 text-sm shadow-sm transition-colors" %>
        </div>

        <div>
          <%= form.submit "Kirim Pesan", class: "w-full sm:w-auto inline-flex justify-center items-center rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-4.5 text-sm font-bold text-white hover:shadow-lg hover:shadow-indigo-500/15 hover:scale-[1.02] active:scale-[0.98] transition-all cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
