<% content_for :title, "Jadwal Kelas Scrum — Daftar Sekarang untuk Pelatihan Berikutnya" %>
<% content_for :description, "Lihat jadwal kelas Scrum terbaru dan daftarkan tim Anda. Pelatihan PSM, PSPO, dan Agile Leadership tersedia dalam format online maupun tatap muka di Indonesia." %>

<section class="relative isolate overflow-hidden bg-slate-950 py-16 sm:py-20">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-20 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-82 w-82 rounded-full bg-violet-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl lg:mx-0">
      <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30 shadow-[0_0_15px_rgba(99,102,241,0.1)]">
        Jadwal Kelas Langsung
      </span>
      <h1 class="mt-6 text-4xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        Kelas Publik <br class="hidden sm:inline" />
        Terbuka untuk <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-purple-400">Pendaftaran</span>
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-350">
        Pengalaman belajar interaktif yang dipandu langsung oleh Professional Scrum Trainer resmi dari Scrum.org untuk memvalidasi pemahaman profesional Anda di Indonesia.
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <% if @class_schedules.any? %>
      <div class="grid gap-6 md:grid-cols-2">
        <% @class_schedules.each do |schedule| %>
          <%= render "card", schedule: schedule, logo_padding_class: "p-[2px]" %>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-2xl border-2 border-dashed border-slate-200 bg-white py-12 px-4 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <h3 class="mt-4 text-sm font-bold text-slate-900">Belum ada kelas publik yang dijadwalkan</h3>
        <p class="mt-1 text-sm text-slate-500">Hubungi kami untuk meminta tanggal khusus atau merancang kelas privat perusahaan.</p>
        <div class="mt-6">
          <%= link_to "Tanyakan tentang jadwal kelas →", new_contact_path(subject: "Tanya jadwal kelas publik"), class: "inline-flex items-center rounded-xl bg-indigo-50 px-4 py-2.5 text-sm font-bold text-indigo-700 hover:bg-indigo-100 transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
