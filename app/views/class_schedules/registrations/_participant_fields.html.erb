<div data-participant-wrapper class="mb-4 border border-slate-200 rounded-2xl p-5 bg-slate-50">
  <div class="flex justify-between items-center mb-4">
    <span class="text-sm font-semibold text-slate-700">Data Peserta</span>
    <button type="button" 
            data-action="participants#remove"
            class="text-rose-500 hover:text-rose-600 text-xs font-bold">Hapus</button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :visitor_name, "Nama Lengkap Peserta", class: "block text-xs font-semibold text-slate-600 mb-1" %>
      <%= f.text_field :visitor_name, required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm" %>
    </div>

    <div>
      <%= f.label :visitor_email, "Email Peserta", class: "block text-xs font-semibold text-slate-600 mb-1" %>
      <%= f.email_field :visitor_email, required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm" %>
    </div>
  </div>

  <%= f.hidden_field :_destroy %>
</div>
