<section class="relative isolate overflow-hidden bg-slate-950 py-12 sm:py-16">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-3xl px-6">
    <div class="flex flex-col sm:flex-row sm:items-center gap-6">
      <div class="relative shrink-0 w-20 h-20 rounded-2xl bg-slate-900/80 border border-slate-800 p-4 shadow-xl flex items-center justify-center backdrop-blur-md">
        <div class="absolute inset-0 rounded-2xl bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent opacity-60"></div>
        <% if @class_schedule.course.logo.attached? %>
          <%= image_tag @class_schedule.course.logo, alt: "#{@class_schedule.course.title} logo", class: "h-full w-full object-contain relative z-10" %>
        <% else %>
          <div class="text-indigo-400 relative z-10">
            <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
        <% end %>
      </div>
      <div>
        <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
          Pendaftaran Pelatihan
        </span>
        <h1 class="mt-2 text-2xl sm:text-3xl font-black tracking-tight text-white leading-tight">
          <%= @class_schedule.course.title %>
        </h1>
        <p class="mt-1 text-sm text-slate-400">
          Jadwal: <%= local_class_time(@class_schedule, format: :range) %>
        </p>
      </div>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-12">
  <div class="max-w-3xl mx-auto px-6">
    <% if @registration.errors.any? %>
      <div class="mb-6 rounded-2xl border border-rose-100 bg-rose-50/70 p-4 text-sm font-semibold text-rose-800 shadow-sm flex items-center gap-2">
        <svg class="h-5 w-5 text-rose-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        <span><%= @registration.errors.full_messages.to_sentence %></span>
      </div>
    <% end %>

    <%= form_with model: [@class_schedule, @registration], local: true, data: { controller: "participants" } do |f| %>
      <!-- Section 1: Person Registering (Finance / Billing Contact) -->
      <div class="bg-white border border-slate-200 rounded-3xl p-8 mb-8 shadow-sm">
        <h2 class="text-xl font-bold text-slate-900 mb-6">1. Data Penanggung Jawab / Keuangan</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :finance_name, "Nama Lengkap Penanggung Jawab", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
            <%= f.text_field :finance_name, required: true, 
                             data: { participants_target: "financeName", action: "input->participants#syncSameAsBilling" },
                             class: "w-full rounded-xl border border-slate-300 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </div>

          <div>
            <%= f.label :finance_email, "Email Penanggung Jawab (untuk quotation)", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
            <%= f.email_field :finance_email, required: true, 
                              data: { participants_target: "financeEmail", action: "input->participants#syncSameAsBilling" },
                              class: "w-full rounded-xl border border-slate-300 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </div>

          <div class="md:col-span-2">
            <%= f.label :company_name, "Nama Perusahaan / Institusi", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
            <%= f.text_field :company_name, required: true, class: "w-full rounded-xl border border-slate-300 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </div>

          <div class="md:col-span-2">
            <%= f.label :company_phone, "Nomor Telepon Perusahaan", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
            <%= f.text_field :company_phone, class: "w-full rounded-xl border border-slate-300 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </div>

          <div class="md:col-span-2">
            <%= f.label :company_address, "Alamat Perusahaan", class: "block text-sm font-semibold text-slate-700 mb-1.5" %>
            <%= f.text_area :company_address, rows: 3, class: "w-full rounded-xl border border-slate-300 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
          </div>
        </div>
      </div>

      <!-- Section 2: Participants -->
      <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-bold text-slate-900">2. Data Peserta</h2>
          <button type="button"
                  data-action="participants#add"
                  class="inline-flex items-center gap-2 text-sm font-semibold text-indigo-600 hover:text-indigo-700">
            + Tambah Peserta
          </button>
        </div>

        <div data-participants-target="participants">
          <%= f.fields_for :enrollments, @registration.enrollments.build do |pf| %>
            <%= render "participant_fields", f: pf %>
          <% end %>
        </div>

        <!-- Template for new participant row -->
        <template data-participants-target="template">
          <%= f.fields_for :enrollments, Enrollment.new, child_index: "NEW_RECORD" do |pf| %>
            <%= render "participant_fields", f: pf %>
          <% end %>
        </template>

        <div class="mt-4 pt-4 border-t border-slate-100">
          <div class="flex items-center gap-3">
            <%= check_box_tag :same_as_billing, "1", false,
                              id: "same_as_billing_checkbox",
                              data: {
                                action: "change->participants#toggleSameAsBilling",
                                participants_target: "sameAsBilling"
                              },
                              class: "h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer" %>
            <%= label_tag :same_as_billing, "Saya sendiri yang akan mengikuti pelatihan", 
                          class: "text-sm font-bold text-slate-700 cursor-pointer select-none" %>
          </div>
          <p class="mt-2 text-xs text-slate-500">
            Anda dapat menambahkan lebih dari satu peserta. Jika Anda sendiri yang akan mengikuti pelatihan, silakan centang opsi di atas atau tambahkan data Anda sebagai peserta.
          </p>
        </div>
      </div>

      <div class="mt-8">
        <%= f.submit "Kirim Permintaan Pendaftaran", 
                     class: "w-full md:w-auto rounded-2xl bg-slate-900 hover:bg-indigo-600 px-10 py-4 text-sm font-bold text-white transition-colors shadow-sm active:scale-[0.985] cursor-pointer" %>
        <p class="mt-3 text-xs text-slate-500 text-center md:text-left">
          Quotation akan dikirim ke email penanggung jawab yang tertera di atas dan email admin kami.
        </p>
      </div>
    <% end %>
  </div>
</div>
