<article class="rounded-lg border border-slate-200 bg-white p-6">
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-start gap-4">
      <% if schedule.course.logo.attached? %>
        <%= image_tag schedule.course.logo, alt: "#{schedule.course.title} logo", class: "h-12 w-12 rounded-md border border-slate-200 bg-white object-contain p-1.5 shrink-0 shadow-sm" %>
      <% else %>
        <div class="h-12 w-12 rounded-md border border-slate-200 bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0 shadow-sm">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
      <% end %>
      <div>
        <%= local_class_time(schedule, class_name: "text-sm font-semibold text-teal-700") %>
        <h3 class="mt-2 text-xl font-semibold"><%= link_to schedule.course.title, class_schedule_path(schedule), class: "hover:text-teal-700" %></h3>
        <p class="mt-2 text-sm text-slate-500 line-clamp-2"><%= schedule.course.excerpt %></p>
      </div>
    </div>
  </div>
  <p class="mt-4 text-sm text-slate-600"><%= schedule.online? ? "Live online" : schedule.location %></p>
  <p class="mt-2 text-sm text-slate-600"><%= schedule.display_price_for(current_currency) %> · Register by <%= schedule.registration_deadline.to_date.to_fs(:long) %></p>
  <div class="mt-6 flex justify-end gap-3 border-t border-slate-100 pt-5">
    <%= link_to "View details", class_schedule_path(schedule), class: "inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-3.5 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 shadow-sm transition-colors" %>
    <% if current_user&.enrollments&.any? { |e| e.class_schedule_id == schedule.id && e.active? } %>
      <span class="inline-flex items-center justify-center rounded-md bg-emerald-50 px-3.5 py-2 text-sm font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-600/10 shadow-sm">Registered</span>
    <% elsif schedule.available_for_registration? %>
      <%= button_to "Enroll", class_schedule_enrollment_path(schedule), method: :post, form: { class: "inline", data: { turbo: false } }, class: "inline-flex items-center justify-center rounded-md bg-teal-700 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-800 shadow-sm transition-colors cursor-pointer" %>
    <% else %>
      <span class="inline-flex items-center justify-center rounded-md bg-slate-50 px-3.5 py-2 text-sm font-semibold text-slate-500 ring-1 ring-inset ring-slate-500/10 shadow-sm">Closed</span>
    <% end %>
  </div>
</article>
