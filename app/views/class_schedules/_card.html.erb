<article class="rounded-[2rem] border border-slate-200/80 bg-white p-6 sm:p-8 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_45px_-12px_rgba(99,102,241,0.07)] hover:border-purple-500/40 hover:scale-[1.005] transition-all duration-300 group flex flex-col justify-between">
  <div>
    <div class="flex items-start gap-4">
      <% if schedule.course.logo.attached? %>
        <%= image_tag schedule.course.logo, alt: "#{schedule.course.title} logo", class: "h-20 w-20 rounded-2xl border border-slate-100 bg-slate-50/50 object-contain #{local_assigns.fetch(:logo_padding_class, "p-3")} shrink-0 shadow-sm group-hover:scale-105 transition-transform duration-300" %>
      <% else %>
        <div class="h-20 w-20 rounded-2xl border border-slate-100 bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0 shadow-sm group-hover:scale-105 transition-transform duration-300">
          <svg class="h-9 w-9" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
      <% end %>
      <div class="flex-grow min-w-0">
        <h3 class="text-xl font-bold leading-7 text-slate-900 group-hover:text-indigo-600 transition-colors truncate-2-lines">
          <%= link_to schedule.course.title, class_schedule_path(schedule) %>
        </h3>
        <div class="mt-2 flex flex-col gap-0.5">
          <span class="inline-flex items-center gap-1.5 text-xs font-bold text-indigo-600 tracking-wide uppercase">
            <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
            <%= class_schedule_date_part(schedule) %>
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500">
            <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <%= class_schedule_time_part(schedule) %>
          </span>
        </div>
        <p class="mt-2 text-sm text-slate-550 line-clamp-2 leading-relaxed"><%= schedule.course.excerpt %></p>
      </div>
    </div>

    <div class="mt-6 border-t border-slate-100 pt-5 space-y-2 text-sm">
      <div class="flex items-center gap-2 text-slate-600 font-medium">
        <span class="inline-block w-2 h-2 rounded-full <%= schedule.online? ? 'bg-indigo-500 animate-pulse' : 'bg-slate-400' %>"></span>
        <%= schedule.online? ? "Live online (via Zoom/Teams)" : schedule.location %>
      </div>
      <div class="flex items-center justify-between text-slate-600 font-medium">
        <span class="font-bold text-slate-900"><%= schedule.display_price_for(current_currency) %></span>
        <% if schedule.registration_deadline.present? %>
          <span class="text-[10px] text-rose-500 font-bold bg-rose-50 px-2.5 py-1 rounded-md uppercase tracking-wider">Batas Pendaftaran: <%= schedule.registration_deadline.to_date.to_fs(:short) %></span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-6 flex justify-between gap-3 border-t border-slate-100 pt-5 items-center">
    <div>
      <% if schedule.available_for_registration? %>
        <span class="inline-flex items-center rounded-full bg-amber-50 px-3 py-1.5 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-600/15 shadow-sm">
          <%= schedule.remaining_seats %> kursi tersisa
        </span>
      <% end %>
    </div>
    <div class="flex gap-3 items-center">
      <%= link_to "Detail", class_schedule_path(schedule), class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 hover:text-indigo-600 hover:bg-slate-50 hover:border-slate-300 shadow-sm active:scale-[0.98] transition-all cursor-pointer" %>
      <% if current_user&.enrollments&.any? { |e| e.class_schedule_id == schedule.id && e.active? } %>
        <span class="inline-flex items-center justify-center rounded-xl bg-emerald-50 px-4 py-2.5 text-sm font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/10 shadow-sm">Registered</span>
      <% elsif schedule.available_for_registration? %>
        <%= link_to "Daftar", new_class_schedule_registration_path(schedule), class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-5 py-2.5 text-sm font-bold text-white hover:shadow-lg hover:shadow-indigo-500/20 active:scale-[0.98] transition-all cursor-pointer" %>
      <% else %>
        <span class="inline-flex items-center justify-center rounded-xl bg-slate-50 px-4 py-2.5 text-sm font-bold text-slate-500 ring-1 ring-inset ring-slate-500/10 shadow-sm">Closed</span>
      <% end %>
    </div>
  </div>
</article>
