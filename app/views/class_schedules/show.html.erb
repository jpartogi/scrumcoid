<% content_for :title, "#{@class_schedule.course.title} — #{@class_schedule.starts_at.strftime('%d %b %Y')}" %>
<% content_for :description, "Daftar ke kelas #{@class_schedule.course.title} yang dimulai #{@class_schedule.starts_at.strftime('%d %B %Y')}. #{@class_schedule.course.excerpt.presence || 'Pelatihan Scrum bersertifikat resmi dari Scrum.org tersedia untuk tim dan profesional di Indonesia.'}" %>
<% content_for :keywords, @class_schedule.course.meta_keywords if @class_schedule.course.meta_keywords.present? %>

<section class="relative isolate overflow-hidden bg-slate-950 py-16 sm:py-20">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <% if current_user&.admin? %>
      <div class="mb-6 flex justify-end">
        <div class="inline-flex items-center gap-2 rounded-2xl border border-white/10 bg-white/5 px-3 py-2 backdrop-blur-sm">
          <span class="text-[10px] font-bold uppercase tracking-widest text-white/40">Admin</span>
          <div class="h-3 w-px bg-white/20"></div>
          <%= link_to edit_admin_class_schedule_path(@class_schedule),
              class: "group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-2 text-xs font-bold text-white shadow-lg shadow-indigo-500/25 ring-1 ring-inset ring-white/10 hover:from-indigo-500 hover:to-violet-500 hover:shadow-indigo-500/40 hover:-translate-y-0.5 transition-all duration-200" do %>
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-[-8deg]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Edit Schedule
            <span class="ml-0.5 inline-flex h-4 w-4 items-center justify-center rounded-full bg-white/20 text-[9px] font-black tracking-tight">A</span>
          <% end %>
        </div>
      </div>
    <% end %>
    <div class="grid gap-8 lg:grid-cols-[1fr_180px] items-center">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
            Sesi Kelas Langsung
          </span>
          <% if @class_schedule.available_for_registration? %>
            <span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-emerald-400 ring-1 ring-inset ring-emerald-500/30">
              Pendaftaran Dibuka
            </span>
          <% else %>
            <span class="inline-flex items-center rounded-full bg-slate-800 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-slate-400 ring-1 ring-inset ring-slate-700">
              Ditutup
            </span>
          <% end %>
        </div>
        <h1 class="mt-4 text-2xl sm:text-4xl font-black tracking-tight text-white leading-tight">
          <%= @class_schedule.course.title %>
        </h1>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-36 h-36 sm:w-40 sm:h-40 rounded-[2rem] bg-slate-900/40 border border-slate-800/80 p-6 shadow-[0_0_50px_rgba(99,102,241,0.15)] flex items-center justify-center backdrop-blur-md group shrink-0">
          <div class="absolute inset-0 rounded-[2rem] bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-500/15 via-transparent to-transparent opacity-60"></div>
          <% if @class_schedule.course.logo.attached? %>
            <%= image_tag @class_schedule.course.logo, alt: "#{@class_schedule.course.title} logo", class: "h-full w-full object-contain relative z-10 group-hover:scale-105 transition-transform duration-300" %>
          <% else %>
            <div class="text-indigo-400 relative z-10 group-hover:scale-105 transition-transform duration-300">
              <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-12">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1fr_340px]">
      
      <!-- Left side: Course Description -->
      <div class="space-y-6">
        <article class="bg-white rounded-3xl p-8 sm:p-10 border border-slate-200/80 shadow-sm transition-all duration-300 hover:border-purple-500/40">
          <h2 class="text-xl font-bold text-slate-900 border-b border-slate-100 pb-4 mb-6">
            Deskripsi Pelatihan
          </h2>
          <div class="text-slate-700 leading-relaxed space-y-6 prose max-w-none text-base">
            <%= @class_schedule.course.description %>
          </div>
        </article>
      </div>

      <!-- Right side: Class details & Registration widget -->
      <aside class="lg:sticky lg:top-8 space-y-6 self-start">
        <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm transition-all duration-300 hover:border-purple-500/40">
          <h3 class="text-base font-bold text-slate-950 border-b border-slate-100 pb-3 mb-4">Detail Kelas</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="font-bold text-slate-900">Hari & Jam</dt>
              <dd class="mt-2 text-slate-600 leading-relaxed font-medium space-y-1.5 text-sm">
                <span class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-indigo-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                  </svg>
                  <%= class_schedule_date_part(@class_schedule) %>
                </span>
                <span class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <%= class_schedule_time_part(@class_schedule) %>
                </span>
              </dd>
            </div>
            <div>
              <% if @class_schedule.online? %>
                <dt class="font-bold text-slate-900">Format</dt>
                <dd class="mt-1 text-slate-600 leading-relaxed font-medium flex items-center gap-1.5">
                    <span class="inline-block w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
                    Online Langsung (Zoom/Teams)
                </dd>
              <% else %>
                <dt class="font-bold text-slate-900">Lokasi</dt>
                <dd class="mt-1 text-slate-600 leading-relaxed font-medium flex items-center gap-1.5">
                  <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <%= @class_schedule.location %>
                </dd>                 
              <% end %>

            </div>
            <% unless @class_schedule.online? %>
              <div>
                <dt class="font-bold text-slate-900">Tempat Pelatihan</dt>
                <dd class="mt-1 text-slate-600 leading-relaxed font-medium">
                  <span class="block font-bold text-slate-800"><%= @class_schedule.venue_name %></span>
                </dd>
              </div>
            <% end %>
            <div>
              <dt class="font-bold text-slate-900">Biaya Investasi</dt>
              <dd class="mt-1 text-slate-900 text-lg font-black"><%= @class_schedule.display_price_for(current_currency) %></dd>
            </div>
            <% if @class_schedule.registration_deadline.present? %>
              <div>
                <dt class="font-bold text-slate-900 text-xs uppercase tracking-wider text-slate-400">Batas Akhir Pendaftaran</dt>
                <dd class="mt-1 text-xs font-semibold text-rose-600"><%= @class_schedule.registration_deadline.to_date.to_fs(:long) %></dd>
              </div>
            <% end %>
          </dl>

          <div class="mt-6 border-t border-slate-100 pt-6">
            <% if @enrollment&.active? %>
              <div class="rounded-2xl bg-emerald-50 border border-emerald-100 p-4 text-emerald-800 text-sm font-bold mb-4 flex items-start gap-2 shadow-sm">
                <svg class="h-5 w-5 text-emerald-500 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
                <div>
                  Terdaftar untuk Kelas Ini
                  <span class="block text-xs font-normal text-emerald-600 mt-0.5">Kursi Anda telah sepenuhnya aman.</span>
                </div>
              </div>
              <%= button_to "Batalkan Pendaftaran", class_schedule_enrollment_path(@class_schedule), method: :delete, class: "w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm font-bold text-slate-700 hover:border-rose-300 hover:text-rose-600 hover:bg-rose-50/20 transition-all cursor-pointer shadow-sm active:scale-[0.98]" %>
            <% elsif @class_schedule.available_for_registration? %>
              <div class="mb-4 flex items-center justify-between text-xs">
                <span class="font-bold text-slate-500">Kursi tersedia:</span>
                <span class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-600/15 shadow-sm">
                  <%= @class_schedule.remaining_seats %> tersisa
                </span>
              </div>
              <%= link_to "Daftar Kelas Ini", new_class_schedule_registration_path(@class_schedule), class: "w-full inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-4 py-3 text-sm font-bold text-white hover:shadow-lg hover:shadow-indigo-500/15 hover:scale-[1.02] active:scale-[0.98] transition-all" %>
            <% else %>
              <div class="rounded-xl bg-slate-50 border border-slate-100 p-4 text-slate-500 text-sm font-bold text-center">
                Pendaftaran telah ditutup
              </div>
            <% end %>

            <% if current_user&.admin? %>
              <div class="mt-4 border-t border-slate-100 pt-4">
                <%= link_to edit_admin_class_schedule_path(@class_schedule), class: "w-full inline-flex items-center justify-center gap-1.5 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50/10 active:scale-[0.98] transition-all cursor-pointer shadow-sm" do %>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                  </svg>
                  Edit Schedule
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm transition-all duration-300 hover:border-purple-500/40">
          <h4 class="text-sm font-bold text-slate-900">Butuh pendaftaran grup?</h4>
          <p class="mt-2 text-xs text-slate-500 leading-relaxed">
            Tertarik memesan slot untuk seluruh tim Anda? Hubungi kami untuk invoice khusus dan diskon grup perusahaan.
          </p>
          <%= link_to "Hubungi Kami", new_contact_path(jenis_inkuiri: "Pendaftaran Grup", pelatihan: @class_schedule.course.title), class: "mt-4 inline-flex items-center text-xs font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
        </div>
      </aside>
    </div>

    <% if @other_schedules.any? %>
      <div id="other-schedules" class="mt-12 scroll-mt-24">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">Jadwal Lain untuk Pelatihan Ini</h2>
        <p class="mt-2 text-sm text-slate-600">Lihat sesi lain dari pelatihan yang sama yang masih membuka pendaftaran.</p>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          <% @other_schedules.each do |schedule| %>
            <%= render "class_schedules/card", schedule: schedule, logo_padding_class: "p-[2px]" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @related_blog_posts.any? %>
      <div class="mt-12">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">Artikel Terkait</h2>
        <p class="mt-2 text-sm text-slate-600">Baca wawasan dan panduan yang relevan dengan pelatihan ini.</p>
        <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% @related_blog_posts.each do |post| %>
            <article class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:border-indigo-500/30 transition-all group">
              <time datetime="<%= post.published_at&.to_date %>" class="text-xs font-bold uppercase tracking-wider text-slate-400">
                <%= post.published_at&.to_date&.to_fs(:long) %>
              </time>
              <h3 class="mt-3 text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">
                <%= link_to post.title, blog_post_path(post) %>
              </h3>
              <p class="mt-2 text-sm text-slate-600 line-clamp-3"><%= post.excerpt %></p>
            </article>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
