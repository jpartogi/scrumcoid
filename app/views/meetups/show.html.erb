<% content_for :title, @meetup.name %>
<% content_for :description, @meetup.excerpt %>
<% content_for :keywords, @meetup.meta_keywords if @meetup.meta_keywords.present? %>

<section class="relative isolate overflow-hidden bg-slate-950 py-16 sm:py-20">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <% if current_user&.admin? %>
      <div class="mb-6 flex justify-end">
        <%= link_to edit_admin_meetup_path(@meetup), class: "inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-2 text-xs font-bold text-white" do %>
          Edit Meetup
        <% end %>
      </div>
    <% end %>
    <div>

        <% if @meetup.available_for_registration? %>
          <span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-emerald-400 ring-1 ring-inset ring-emerald-500/30">
            Pendaftaran Terbuka
          </span>
        <% end %>

        <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
          Free with Donation
        </span>
      </div>
      <h1 class="mt-4 text-2xl sm:text-4xl font-black tracking-tight text-white leading-tight">
        <%= @meetup.name %>
      </h1>
      <p class="mt-3 text-sm text-slate-400"><%= @meetup.excerpt %></p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-12">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1fr_340px]">
      <article class="bg-white rounded-3xl p-8 sm:p-10 border border-slate-200/80 shadow-sm">
        <h2 class="text-xl font-bold text-slate-900 border-b border-slate-100 pb-4 mb-6">Tentang Meetup Ini</h2>
        <div class="text-slate-700 leading-relaxed prose max-w-none text-base">
          <%= @meetup.description %>
        </div>
      </article>

      <aside class="lg:sticky lg:top-8 self-start space-y-6">
        <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
          <h3 class="text-base font-bold text-slate-950 border-b border-slate-100 pb-3 mb-4">Detail Meetup</h3>
          <div class="space-y-4">
            <!-- Date & Time -->
            <div class="flex items-start gap-2.5 text-sm text-slate-600">
              <div class="h-8 w-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0 shadow-inner">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
              </div>
              <div>
                <p class="font-bold text-slate-800"><%= meetup_date_part(@meetup) %></p>
                <p class="text-xs font-semibold text-slate-400 mt-0.5"><%= meetup_time_part(@meetup) %></p>
              </div>
            </div>

            <!-- Format Info -->
            <% if @meetup.online? %>
              <div class="flex items-start gap-2.5 text-sm text-slate-600 mt-4 pt-4 border-t border-slate-100/80">
                <div class="h-8 w-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0 shadow-inner">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-slate-800">Format</p>
                  <div class="mt-1">
                    <%= meetup_online_pill(@meetup) %>
                  </div>
                  <p class="mt-1.5 text-xs text-slate-400 font-semibold leading-relaxed">
                    Link untuk bergabung ke meetup online akan dikirimkan setelah pendaftaran selesai.
                  </p>
                </div>
              </div>
            <% end %>

            <!-- Registration Deadline -->
            <% if @meetup.registration_deadline.present? %>
              <div class="mt-5">
                <% if @meetup.available_for_registration? %>
                  <div class="flex items-center gap-2.5 rounded-xl bg-amber-50/50 border border-slate-200/50 p-3 text-xs">
                    <svg class="h-4 w-4 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div class="text-amber-800">
                      <span class="font-medium">Batas pendaftaran:</span>
                      <span class="font-bold block mt-0.5"><%= meetup_registration_deadline_part(@meetup) %></span>
                    </div>
                  </div>
                <% else %>
                  <div class="flex items-center gap-2.5 rounded-xl bg-slate-50 border border-slate-200/30 p-3 text-xs text-slate-400">
                    <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                      <span class="font-medium">Pendaftaran telah ditutup</span>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="mt-6 border-t border-slate-100 pt-6">
            <% if @registration&.active? %>
              <div class="rounded-2xl bg-emerald-50 border border-emerald-100 p-4 text-emerald-800 text-sm font-bold mb-4">
                Anda sudah terdaftar untuk meetup ini.
              </div>
            <% elsif @meetup.available_for_registration? %>
              <div class="mb-4 flex items-center justify-between text-xs">
                <span class="font-bold text-slate-500">Kursi tersedia:</span>
                <span class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-600/15">
                  <%= @meetup.remaining_seats %> tersisa
                </span>
              </div>
              <%= link_to "Daftar Meetup", new_meetup_registration_path(@meetup), class: "w-full inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-4 py-3 text-sm font-bold text-white hover:shadow-lg transition-all" %>
            <% else %>
              <div class="rounded-xl bg-slate-50 border border-slate-100 p-4 text-slate-500 text-sm font-bold text-center">
                Pendaftaran telah ditutup
              </div>
            <% end %>
          </div>
        </div>

        <!-- CTA Widget -->
        <div class="rounded-3xl border border-slate-200/80 bg-slate-900 p-6 shadow-xl transition-all duration-300 hover:border-purple-500/40 text-white relative overflow-hidden">
          <!-- Glow details -->
          <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_right,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent opacity-60"></div>
          <div class="absolute -right-10 -top-10 -z-10 h-40 w-40 rounded-full bg-indigo-500/10 blur-2xl"></div>

          <span class="text-[10px] font-bold uppercase tracking-wider text-indigo-400">Pelatihan Live / In-House</span>
          <h3 class="mt-3 text-lg font-black text-white leading-snug">Ingin mempelajari Scrum dari Scrum.org Trainer resmi?</h3>
          <p class="mt-2 text-xs text-slate-400 leading-relaxed font-medium">Pilih jadwal kelas publik terdekat kami atau hubungi kami untuk mendiskusikan kebutuhan pelatihan privat/in-house yang disesuaikan untuk organisasi Anda.</p>
          <div class="mt-6 flex flex-col gap-3">
            <%= link_to "Lihat Jadwal Kelas Publik", class_schedules_path, class: "w-full inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-4 py-3 text-xs font-bold text-white shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:scale-[1.02] active:scale-[0.98] transition-all text-center" %>
            <%= link_to "https://wa.me/6285643428348", target: "_blank", rel: "noopener", class: "w-full inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-xs font-bold text-white hover:bg-emerald-700 shadow-lg shadow-emerald-500/20 hover:shadow-emerald-500/40 hover:scale-[1.02] active:scale-[0.98] transition-all text-center" do %>
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.739-1.456L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.963C16.48 2.012 14.005.992 11.37.992c-5.447 0-9.87 4.37-9.874 9.8.001 1.95.518 3.854 1.502 5.561l-.987 3.606 3.702-.97c1.644.896 3.23 1.365 4.834 1.365zm10.638-7.468c-.287-.143-1.696-.838-1.959-.933-.262-.095-.453-.143-.644.143-.19.287-.738.933-.905 1.124-.167.19-.333.214-.62.071-.287-.143-1.21-.446-2.305-1.424-.853-.76-1.428-1.7-1.595-1.986-.167-.286-.018-.44.125-.581.129-.127.287-.333.43-.5.143-.167.19-.286.287-.476.095-.19.047-.357-.024-.5-.071-.143-.644-1.547-.882-2.12-.232-.559-.467-.483-.644-.492-.167-.008-.358-.01-.55-.01-.19 0-.5.071-.762.357-.262.287-1 .977-1 2.38 0 1.405 1.023 2.762 1.166 2.953.143.19 2.013 3.074 4.877 4.31.681.294 1.213.47 1.627.601.684.218 1.307.187 1.8.114.55-.082 1.696-.692 1.935-1.36.239-.667.239-1.24.167-1.36-.072-.119-.262-.19-.549-.333z"/>
              </svg>
              Chat Jessica via WhatsApp
            <% end %>
            <%= link_to "Hubungi Kami (Kelas Privat)", new_contact_path(jenis_inkuiri: "Quotation Pelatihan Privat"), class: "w-full inline-flex items-center justify-center rounded-xl border border-slate-700 bg-slate-800/40 px-4 py-3 text-xs font-bold text-slate-300 hover:text-white hover:bg-slate-800 hover:border-slate-600 transition-all text-center" %>
          </div>
        </div>
      </aside>
    </div>
  </div>
</div>