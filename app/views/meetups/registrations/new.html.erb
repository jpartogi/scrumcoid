<section class="relative isolate overflow-hidden bg-slate-950 py-12 sm:py-16">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-3xl px-6">
    <!-- Back Link to Meetup#show -->
    <%= link_to meetup_path(@meetup), class: "inline-flex items-center gap-1.5 text-xs font-bold text-indigo-400 hover:text-indigo-300 transition-colors mb-6 group" do %>
      <svg class="h-4.5 w-4.5 transform group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Kembali ke Detail Meetup
    <% end %>

    <div>
      <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
        Pendaftaran Meetup
      </span>
      <h1 class="mt-4 text-2xl sm:text-3xl font-black tracking-tight text-white leading-tight">
        <%= meetup_display_name(@meetup) %>
      </h1>
      <p class="mt-2 text-sm text-slate-400 flex flex-wrap items-center gap-x-4 gap-y-1">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4 text-indigo-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          <%= meetup_date_part(@meetup) %>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= meetup_time_part(@meetup) %>
        </span>
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-12">
  <div class="max-w-3xl mx-auto px-6">
    <% if @registration.errors.any? %>
      <div class="mb-6 rounded-2xl border border-rose-100 bg-rose-50/70 p-4 text-sm font-semibold text-rose-800 shadow-sm flex items-center gap-2">
        <svg class="h-5 w-5 text-rose-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        <span><%= @registration.errors.full_messages.to_sentence %></span>
      </div>
    <% end %>

    <!-- Beautiful Information Callout Banner -->
    <div class="mb-8 rounded-2xl border border-indigo-100 bg-indigo-50/40 p-5 shadow-sm flex items-start gap-3">
      <div class="rounded-xl bg-indigo-500/10 p-2.5 text-indigo-600 shrink-0">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 111.063.852l-.708 2.836a.75.75 0 001.063.852l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
        </svg>
      </div>
      <div>
        <h3 class="text-sm font-bold text-slate-900">Konfirmasi via Email</h3>
        <p class="text-xs text-slate-600 mt-1 leading-relaxed">
          Setelah mendaftar, Anda akan menerima email konfirmasi resmi beserta tautan/join link untuk bergabung ke sesi meetup.
        </p>
      </div>
    </div>

    <%= form_with model: @registration, url: meetup_registrations_path(@meetup), local: true, class: "bg-white border border-slate-200/80 rounded-3xl p-8 shadow-sm space-y-6 transition-all duration-300 hover:border-purple-500/40" do |f| %>
      <div>
        <%= f.label :visitor_name, "Nama Lengkap", class: "block text-sm font-bold text-slate-700" %>
        <%= f.text_field :visitor_name, required: true, placeholder: "Nama lengkap Anda...", class: "mt-1.5 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all placeholder:text-slate-400" %>
      </div>

      <div>
        <%= f.label :visitor_email, "Email", class: "block text-sm font-bold text-slate-700" %>
        <%= f.email_field :visitor_email, required: true, placeholder: "alamat@email.com", class: "mt-1.5 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all placeholder:text-slate-400" %>
      </div>

      <%= f.submit "Daftar Meetup", class: "w-full rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-4 text-sm font-bold text-white shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:scale-[1.01] active:scale-[0.99] transition-all cursor-pointer text-center" %>
    <% end %>
  </div>
</div>