<% content_for :title, "Meetup Scrum, Agile dan Manajemen Produk" %>
<% content_for :description, "Ikuti meetup gratis Scrum dan Agile dari Scrum.co.id. Daftar online dan bergabung langsung dari mana saja." %>

<section class="relative isolate overflow-hidden bg-slate-950 py-16 sm:py-20">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
      Komunitas
    </span>
    <h1 class="mt-4 text-3xl sm:text-5xl font-black tracking-tight text-white leading-tight">
      Meetup Scrum, Agile dan Manajemen Produk
    </h1>
    <p class="mt-4 max-w-2xl text-base text-slate-400">
      Sesi meetup gratis untuk berbagi pengalaman, praktik, dan wawasan seputar Scrum, Agile dan Manajemen Produk di Indonesia bersama praktisi lainnya.
    </p>
  </div>
</section>

<div class="bg-slate-50 py-12">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <% if @meetups.any? %>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% @meetups.each do |meetup| %>
          <article class="flex flex-col justify-between rounded-3xl border border-slate-200/80 bg-white p-8 shadow-sm hover:shadow-md hover:border-indigo-500/30 transition-all duration-300">
            <div>
              <!-- Title at the Top -->
              <h2 class="text-xl font-bold text-slate-900 leading-snug">
                <%= link_to meetup.name, meetup_path(meetup), class: "hover:text-indigo-600 transition-colors" %>
              </h2>
              
              <!-- Excerpt -->
              <p class="mt-3 text-sm text-slate-500 line-clamp-3 leading-relaxed"><%= meetup.excerpt %></p>
              
              <!-- Date & Time details (intuitive layout) -->
              <div class="mt-5 space-y-3">
                <!-- Date & Time -->
                <div class="flex items-start gap-2.5 text-sm text-slate-600">
                  <div class="h-8 w-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0 shadow-inner">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-bold text-slate-800"><%= meetup_date_part(meetup) %></p>
                    <p class="text-xs font-semibold text-slate-400 mt-0.5"><%= meetup_time_part(meetup) %></p>
                  </div>
                </div>

                <!-- Registration Deadline -->
                <% if meetup.available_for_registration? %>
                  <div class="flex items-center gap-2.5 rounded-xl bg-amber-50/50 border border-slate-200/50 p-3 text-xs">
                    <svg class="h-4 w-4 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div class="text-amber-800">
                      <span class="font-medium">Batas pendaftaran:</span>
                      <span class="font-bold"><%= meetup_registration_deadline_part(meetup) %></span>
                    </div>
                  </div>
                <% else %>
                  <div class="flex items-center gap-2.5 rounded-xl bg-slate-50 border border-slate-200/30 p-3 text-xs text-slate-400">
                    <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                      <span class="font-medium">Pendaftaran telah ditutup</span>
                    </div>
                  </div>
                <% end %>
              </div>

              <!-- Status & Format Pills (below details) -->
              <div class="mt-6 flex flex-wrap gap-2">
                <% if meetup.available_for_registration? %>
                  <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-bold text-emerald-700 ring-1 ring-inset ring-emerald-600/10 shadow-sm">
                    Pendaftaran Terbuka
                  </span>
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-bold text-slate-500 ring-1 ring-inset ring-slate-300/60 shadow-sm">
                    Pendaftaran Ditutup
                  </span>
                <% end %>
                <%= meetup_online_pill(meetup) %>
                <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-bold text-indigo-700 ring-1 ring-inset ring-indigo-700/10 shadow-sm">
                  Free with Donation
                </span>
                <% if meetup.available_for_registration? %>
                  <span class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-600/15 shadow-sm">
                    <%= meetup.remaining_seats %> kursi tersisa
                  </span>
                <% end %>
              </div>
            </div>
            <div class="mt-8 grid <%= meetup.available_for_registration? ? 'grid-cols-2' : 'grid-cols-1' %> gap-3 border-t border-slate-100 pt-6">
              <%= link_to "Detail", meetup_path(meetup), class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-xs font-bold text-slate-700 hover:bg-slate-50 hover:border-slate-300 transition-all text-center" %>
              <% if meetup.available_for_registration? %>
                <%= link_to "Daftar", new_meetup_registration_path(meetup), class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-4 py-2.5 text-xs font-bold text-white hover:bg-indigo-500 hover:scale-[1.02] shadow-md shadow-indigo-600/10 hover:shadow-indigo-600/20 transition-all text-center" %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-3xl border border-slate-200 bg-white p-12 text-center">
        <h2 class="text-xl font-bold text-slate-900">Belum ada meetup yang dijadwalkan</h2>
        <p class="mt-2 text-sm text-slate-600">Silakan kembali lagi nanti atau hubungi kami untuk informasi lebih lanjut.</p>
        <%= link_to "Hubungi Kami", new_contact_path, class: "mt-6 inline-flex rounded-xl bg-indigo-600 px-5 py-3 text-sm font-bold text-white hover:bg-indigo-500 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>