<% content_for :title, @about_page&.title.presence || "Tentang Kami" %>
<% content_for :description, @about_page&.summary.presence || "scrum.co.id adalah pelopor pelatihan Professional Scrum resmi di Indonesia sejak 2012. Mitra resmi Scrum.org dan anggota Professional Training Network (PTN)." %>

<section class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-20 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-82 w-82 rounded-full bg-violet-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-5xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-flex items-center rounded-full bg-violet-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-violet-400 ring-1 ring-inset ring-violet-500/30 shadow-[0_0_15px_rgba(139,92,246,0.1)]">
        Tentang Kami
      </span>
      <h1 class="mt-6 text-4xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        <%= @about_page.title %>
      </h1>
      <p class="mt-6 text-xl leading-8 text-slate-350 font-medium">
        <%= @about_page.summary %>
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-5xl px-6">
    <div class="bg-white rounded-[2.5rem] p-8 sm:p-12 border border-slate-200/80 shadow-[0_4px_30px_-10px_rgba(0,0,0,0.02)]">
      <div class="text-slate-800 leading-relaxed space-y-6 prose max-w-none text-lg">
        <%= @about_page.body %>
      </div>

      <!-- Keunggulan / Pillars Section -->
      <div class="mt-16 pt-12 border-t border-slate-100">
        <h3 class="text-2xl font-bold text-slate-950 mb-10 text-center sm:text-left">Mengapa Memilih Kami?</h3>
        <dl class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          
          <!-- Card 1 -->
          <div class="flex flex-col bg-slate-50 p-6 rounded-2xl border border-slate-200/70 transition-all hover:bg-white hover:shadow-[0_15px_30px_-5px_rgba(99,102,241,0.05)] hover:border-purple-500/40 duration-200">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 ring-1 ring-indigo-500/20 mb-4 shadow-sm">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <dt class="font-bold text-slate-950 text-base">Pertama di Indonesia</dt>
              <dd class="mt-2 text-sm leading-relaxed text-slate-600">Pelopor pelatihan Scrum profesional sejak tahun 2012.</dd>
            </div>
          </div>
          
          <!-- Card 2 -->
          <div class="flex flex-col bg-slate-50 p-6 rounded-2xl border border-slate-200/70 transition-all hover:bg-white hover:shadow-[0_15px_30px_-5px_rgba(99,102,241,0.05)] hover:border-purple-500/40 duration-200">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-purple-50 text-purple-600 ring-1 ring-purple-500/20 mb-4 shadow-sm">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <dt class="font-bold text-slate-950 text-base">Official Scrum.org PTN</dt>
              <dd class="mt-2 text-sm leading-relaxed text-slate-600"><a href="https://www.scrum.org/pt-scrum-asia-pasifik">Professional Training Network</a> official resmi dari Scrum.org.</dd>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="flex flex-col bg-slate-50 p-6 rounded-2xl border border-slate-200/70 transition-all hover:bg-white hover:shadow-[0_15px_30px_-5px_rgba(99,102,241,0.05)] hover:border-purple-500/40 duration-200">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-teal-50 text-teal-600 ring-1 ring-teal-500/20 mb-4 shadow-sm">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </div>
            <div>
              <dt class="font-bold text-slate-950 text-base">Pengalaman Indonesia & Global</dt>
              <dd class="mt-2 text-sm leading-relaxed text-slate-600">Memiliki portofolio luas membimbing tim dalam negeri maupun berskala global.</dd>
            </div>
          </div>

          <!-- Card 4 -->
          <div class="flex flex-col bg-slate-50 p-6 rounded-2xl border border-slate-200/70 transition-all hover:bg-white hover:shadow-[0_15px_30px_-5px_rgba(99,102,241,0.05)] hover:border-purple-500/40 duration-200">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 ring-1 ring-indigo-500/20 mb-4 shadow-sm">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <div>
              <dt class="font-bold text-slate-950 text-base">Mission Driven</dt>
              <dd class="mt-2 text-sm leading-relaxed text-slate-600">Berfokus pada misi penyebaran pemahaman Scrum yang benar, bukan sekadar mengejar angka sales.</dd>
            </div>
          </div>

          <!-- Card 5 -->
          <div class="flex flex-col bg-slate-50 p-6 rounded-2xl border border-slate-200/70 transition-all hover:bg-white hover:shadow-[0_15px_30px_-5px_rgba(99,102,241,0.05)] hover:border-purple-500/40 duration-200">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-purple-50 text-purple-600 ring-1 ring-purple-500/20 mb-4 shadow-sm">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.168.477 4 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.168.477-4 1.253" />
              </svg>
            </div>
            <div>
              <dt class="font-bold text-slate-950 text-base">Immersive Learning</dt>
              <dd class="mt-2 text-sm leading-relaxed text-slate-600">Proses belajar yang mendalam (immersive) berdasarkan psikologi adult learning.</dd>
            </div>
          </div>

          <!-- Card 6 -->
          <div class="flex flex-col bg-slate-50 p-6 rounded-2xl border border-slate-200/70 transition-all hover:bg-white hover:shadow-[0_15px_30px_-5px_rgba(99,102,241,0.05)] hover:border-purple-500/40 duration-200">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-teal-50 text-teal-600 ring-1 ring-teal-500/20 mb-4 shadow-sm">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 10h4.757a2 2 0 110 4h-1.071a8.001 8.001 0 01-14.142 0H2.243a2 2 0 110-4H7M14 10V4a2 2 0 10-4 0v6m4 0H10" />
              </svg>
            </div>
            <div>
              <dt class="font-bold text-slate-950 text-base">Feedback Positif Konsisten</dt>
              <dd class="mt-2 text-sm leading-relaxed text-slate-600">Pelatihan kami secara konsisten menerima tanggapan positif dari para peserta dan alumni.</dd>
            </div>
          </div>
          
        </dl>
      </div>
    </div>
  </div>
</div>
