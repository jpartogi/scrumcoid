<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "scrum.co.id — Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="scrum.co.id">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png" sizes="512x512">
    <link rel="shortcut icon" href="/icon.png">
    <link rel="apple-touch-icon" sizes="512x512" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex font-['Inter',sans-serif] antialiased bg-slate-950 text-slate-900">

    <%# ── Left branding panel ── %>
    <div class="hidden lg:flex lg:w-[420px] xl:w-[480px] shrink-0 flex-col justify-between bg-gradient-to-br from-slate-900 via-indigo-950/60 to-slate-950 border-r border-white/5 px-10 py-12 relative overflow-hidden">

      <%# Subtle dot grid %>
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(rgba(255,255,255,0.8) 1px, transparent 0); background-size: 28px 28px;" aria-hidden="true"></div>
      <%# Indigo glow blob %>
      <div class="absolute -top-24 -left-24 h-72 w-72 rounded-full bg-indigo-600/20 blur-3xl" aria-hidden="true"></div>
      <div class="absolute bottom-0 right-0 h-64 w-64 rounded-full bg-violet-600/10 blur-3xl" aria-hidden="true"></div>

      <%# Brand logo %>
      <div class="relative z-10">
        <%= link_to root_path, class: "inline-flex items-center gap-2.5" do %>
          <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 shadow-lg shadow-indigo-500/30 ring-1 ring-white/10">
            <span class="text-base font-black text-white">S</span>
          </div>
          <span class="text-xl font-black tracking-tighter text-white">scrum<span class="text-indigo-400">.co.id</span></span>
        <% end %>
      </div>

      <%# Central tagline %>
      <div class="relative z-10 space-y-6">
        <div class="inline-flex items-center gap-2 rounded-full border border-indigo-500/30 bg-indigo-500/10 px-3.5 py-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
          <span class="text-xs font-bold tracking-widest text-indigo-300 uppercase">Admin Portal</span>
        </div>
        <h2 class="text-3xl xl:text-4xl font-extrabold tracking-tight text-white leading-tight">
          Professional Scrum<br>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-violet-400">Training Platform</span>
        </h2>
        <p class="text-sm leading-relaxed text-slate-400 max-w-xs">
          Manage courses, class schedules, registrations, and learner records — all in one place.
        </p>

        <%# Feature pills %>
        <div class="flex flex-wrap gap-2">
          <% [
            ["📅", "Class Schedules"],
            ["📝", "Registrations"],
            ["📚", "Courses"],
            ["👥", "CRM"]
          ].each do |icon, label| %>
            <span class="inline-flex items-center gap-1.5 rounded-lg bg-white/5 px-3 py-1.5 text-xs font-semibold text-slate-300 ring-1 ring-inset ring-white/10">
              <%= icon %> <%= label %>
            </span>
          <% end %>
        </div>
      </div>

      <%# Footer quote %>
      <div class="relative z-10 border-t border-white/8 pt-6">
        <p class="text-xs text-slate-500 leading-relaxed italic">
          "Empiricism asserts that knowledge comes from experience and making decisions based on what is known."
        </p>
        <p class="mt-1 text-[10px] font-bold uppercase tracking-widest text-slate-600">— The Scrum Guide</p>
      </div>
    </div>

    <%# ── Right: auth form panel ── %>
    <div class="flex flex-1 flex-col min-h-screen bg-slate-50 overflow-y-auto">

      <%# Top bar (mobile brand + nav) %>
      <header class="flex items-center justify-between px-6 py-5 lg:px-10 border-b border-slate-200 bg-white shadow-sm lg:hidden">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-gradient-to-br from-indigo-500 to-violet-600">
            <span class="text-sm font-black text-white">S</span>
          </div>
          <span class="text-base font-black tracking-tighter text-slate-900">scrum<span class="text-indigo-600">.co.id</span></span>
        <% end %>
        <%= link_to root_path, class: "text-xs font-bold text-slate-500 hover:text-slate-700 transition-colors" do %>
          ← Back to site
        <% end %>
      </header>

      <%# Alert banners %>
      <% if notice.present? || alert.present? %>
        <div class="px-6 pt-6 lg:px-10">
          <% if notice.present? %>
            <div class="rounded-xl border border-indigo-100 bg-indigo-50/70 p-4 text-sm font-semibold text-indigo-900 shadow-sm flex items-center gap-2">
              <svg class="h-5 w-5 text-indigo-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span><%= notice %></span>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="mt-3 rounded-xl border border-rose-100 bg-rose-50/70 p-4 text-sm font-semibold text-rose-900 shadow-sm flex items-center gap-2">
              <svg class="h-5 w-5 text-rose-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <span><%= alert %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Form slot %>
      <main class="flex flex-1 items-center justify-center px-6 py-12 lg:px-10">
        <div class="w-full max-w-md">
          <%= yield %>
        </div>
      </main>

      <%# Footer %>
      <footer class="px-6 pb-8 text-center text-xs text-slate-400 font-medium">
        &copy; <%= Time.current.year %> scrum.co.id &mdash;
        <%= link_to "Back to site", root_path, class: "text-indigo-500 hover:text-indigo-600 font-bold transition-colors" %>
      </footer>
    </div>

  </body>
</html>
