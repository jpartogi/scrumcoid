<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin Center - scrum.co.id" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="scrum.co.id Admin">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex bg-slate-50 font-['Inter',sans-serif] text-slate-900 antialiased">
    <!-- Left Sidebar -->
    <aside class="w-64 bg-slate-900 text-slate-300 flex flex-col shrink-0 min-h-screen border-r border-slate-800 shadow-xl">
      <!-- Brand Logo -->
      <div class="h-20 flex items-center px-6 border-b border-slate-800 bg-slate-950">
        <%= link_to admin_root_path, class: "text-xl font-black tracking-tighter text-white flex items-center gap-2" do %>
          scrum<span class="text-indigo-400">coid</span>
          <span class="rounded bg-indigo-500/10 px-2 py-0.5 text-xs font-bold text-indigo-400 uppercase tracking-widest ring-1 ring-inset ring-indigo-500/20">Admin</span>
        <% end %>
      </div>

      <!-- Navigation Menu -->
      <nav class="flex-grow p-4 space-y-1.5 overflow-y-auto">
        <!-- Dashboard Link -->
        <%= link_to admin_root_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all #{controller_name == 'dashboard' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'hover:bg-slate-800 hover:text-white'}" do %>
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          Dashboard
        <% end %>

        <!-- Courses Link -->
        <%= link_to admin_courses_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all #{controller_name == 'courses' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'hover:bg-slate-800 hover:text-white'}" do %>
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
          Courses
        <% end %>

        <!-- Class Schedules Link -->
        <%= link_to admin_class_schedules_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all #{controller_name == 'class_schedules' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'hover:bg-slate-800 hover:text-white'}" do %>
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
          </svg>
          Schedules
        <% end %>

        <!-- Blog Posts Link -->
        <%= link_to admin_blog_posts_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all #{controller_name == 'blog_posts' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'hover:bg-slate-800 hover:text-white'}" do %>
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
          Blog Posts
        <% end %>

        <!-- About Page Link -->
        <%= link_to edit_admin_about_page_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all #{controller_name == 'about_pages' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'hover:bg-slate-800 hover:text-white'}" do %>
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" />
          </svg>
          About Page
        <% end %>

        <!-- Admin Emails Link -->
        <%= link_to admin_admin_emails_path, class: "flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all #{controller_name == 'admin_emails' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'hover:bg-slate-800 hover:text-white'}" do %>
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          Admin Emails
        <% end %>

        <!-- Contact Messages Link -->
        <%= link_to admin_contact_messages_path, class: "flex items-center justify-between px-4 py-3 rounded-lg text-sm font-semibold transition-all #{controller_name == 'contact_messages' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'hover:bg-slate-800 hover:text-white'}" do %>
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <span>Messages</span>
          </div>
          <% unread_count = ContactMessage.unread.count %>
          <% if unread_count > 0 %>
            <span class="rounded-full bg-rose-500/20 px-2 py-0.5 text-xs font-bold text-rose-400 ring-1 ring-inset ring-rose-500/30"><%= unread_count %></span>
          <% end %>
        <% end %>
      </nav>

      <!-- Footer navigation links -->
      <div class="p-4 border-t border-slate-800 bg-slate-950/40 text-xs">
        <%= link_to root_path, class: "flex items-center gap-2 px-4 py-3 rounded-lg hover:bg-slate-800 hover:text-white transition-colors" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
          View Visitor Site
        <% end %>
      </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-grow flex flex-col min-h-screen overflow-x-hidden">
      <!-- Top Bar -->
      <header class="h-20 bg-white border-b border-slate-200 px-8 flex items-center justify-between sticky top-0 z-40 shadow-sm/50">
        <div>
          <nav class="flex text-xs font-medium text-slate-500" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-2">
              <li class="inline-flex items-center">
                <%= link_to "Admin", admin_root_path, class: "hover:text-indigo-600 transition-colors" %>
              </li>
              <li>
                <div class="flex items-center">
                  <svg class="h-4.5 w-4.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                  <span class="ml-1 text-slate-800 font-semibold md:ml-2 uppercase tracking-wide text-xs"><%= controller_name.humanize %></span>
                </div>
              </li>
            </ol>
          </nav>
        </div>

        <div class="flex items-center gap-6">
          <% if current_user.present? %>
            <div id="admin-nav-content" class="flex items-center gap-4">
              <div class="flex items-center gap-3">
                <div class="h-9 w-9 rounded-full bg-indigo-100 border border-indigo-200 text-indigo-700 flex items-center justify-center font-bold text-sm select-none">
                  <%= current_user.name.present? ? current_user.name[0].upcase : current_user.email[0].upcase %>
                </div>
                <div class="hidden sm:block text-left">
                  <p class="text-sm font-semibold text-slate-900 leading-none"><%= current_user.name.presence || "Administrator" %></p>
                  <p class="text-xs text-slate-500 mt-1 leading-none"><%= current_user.email %></p>
                </div>
              </div>
              <%= link_to "Account settings", edit_user_registration_path, class: "text-xs font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
            </div>
            <%= button_to destroy_user_session_path, method: :delete, class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-bold text-slate-700 hover:text-rose-600 hover:border-rose-300 hover:bg-rose-50/30 transition-all shadow-sm cursor-pointer" do %>
              Sign out
            <% end %>
          <% end %>
        </div>
      </header>

      <!-- Alert Notification Banners -->
      <% if notice.present? || alert.present? %>
        <div class="px-8 pt-6">
          <% if notice.present? %>
            <div class="rounded-xl border border-indigo-100 bg-indigo-50/70 p-4 text-sm font-semibold text-indigo-900 shadow-sm flex items-center gap-2 transition-all">
              <svg class="h-5 w-5 text-indigo-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span><%= notice %></span>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="rounded-xl border border-rose-100 bg-rose-50/70 p-4 text-sm font-semibold text-rose-900 shadow-sm flex items-center gap-2 transition-all">
              <svg class="h-5 w-5 text-rose-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <span><%= alert %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Main Slot Content -->
      <main class="flex-grow">
        <%= yield %>
      </main>

      <!-- Admin Footer -->
      <footer class="bg-white border-t border-slate-200 py-6 px-8 text-center text-xs font-medium text-slate-500">
        <p>&copy; <%= Time.current.year %> scrum.co.id Admin. Trainer Administration Dashboard.</p>
      </footer>
    </div>
  </body>
</html>
