<!DOCTYPE html>
<html>
  <head>
    <% page_title = content_for(:title).presence %>
    <title><%= page_title ? "#{page_title} | scrum.co.id" : "scrum.co.id — Pelatihan Professional Scrum & Sertifikasi Resmi di Indonesia" %></title>
    <meta name="description" content="<%= content_for(:description).presence || "scrum.co.id adalah mitra resmi Scrum.org di Indonesia yang menyediakan pelatihan PSM, PSPO, dan pelatihan Agile bersertifikat internasional untuk tim dan organisasi." %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="scrum.co.id">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex flex-col bg-white font-['Inter',sans-serif] text-slate-950 antialiased">
    <!-- Premium Top Accent Line -->
    <div class="h-1.5 w-full bg-gradient-to-r from-indigo-600 via-purple-600 to-teal-400"></div>

    <header class="sticky top-0 z-50 border-b border-slate-100/60 bg-white/90 backdrop-blur-md shadow-[0_2px_20px_-3px_rgba(0,0,0,0.02)]">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
        <%= link_to root_path, class: "text-2xl font-black tracking-tighter text-slate-900 group" do %>
          Scrum<span class="text-indigo-600 group-hover:text-indigo-500 transition-colors">.co.id</span>
        <% end %>
        <div class="hidden lg:flex lg:gap-x-10">
          <%= link_to courses_path, class: "relative py-1.5 text-sm font-bold leading-6 text-slate-700 hover:text-indigo-600 transition-colors group" do %>
            Pelatihan
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-indigo-600 transition-all duration-300 group-hover:w-full"></span>
          <% end %>
          <%= link_to class_schedules_path, class: "relative py-1.5 text-sm font-bold leading-6 text-slate-700 hover:text-indigo-600 transition-colors group" do %>
            Jadwal
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-indigo-600 transition-all duration-300 group-hover:w-full"></span>
          <% end %>
          <%= link_to about_path, class: "relative py-1.5 text-sm font-bold leading-6 text-slate-700 hover:text-indigo-600 transition-colors group" do %>
            Tentang
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-indigo-600 transition-all duration-300 group-hover:w-full"></span>
          <% end %>
          <%= link_to blog_posts_path, class: "relative py-1.5 text-sm font-bold leading-6 text-slate-700 hover:text-indigo-600 transition-colors group" do %>
            Blog
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-indigo-600 transition-all duration-300 group-hover:w-full"></span>
          <% end %>
          <%= link_to new_contact_path, class: "relative py-1.5 text-sm font-bold leading-6 text-slate-700 hover:text-indigo-600 transition-colors group" do %>
            Kontak
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-indigo-600 transition-all duration-300 group-hover:w-full"></span>
          <% end %>
        </div>
        <div class="flex items-center gap-x-6">
          <% if current_user&.admin? %>
            <%= link_to "Dasbor Admin", admin_root_path, class: "text-sm font-bold text-slate-700 hover:text-indigo-600 transition-colors" %>
            <%= button_to "Keluar", destroy_user_session_path, method: :delete, class: "text-sm font-bold text-slate-700 hover:text-rose-600 transition-colors" %>
          <% end %>
        </div>
      </nav>
    </header>

    <% if notice.present? || alert.present? %>
      <div class="fixed top-24 right-6 z-50 max-w-md w-full flex flex-col gap-3 animate-in slide-in-from-top-4 duration-300">
        <% if notice.present? %>
          <div class="rounded-2xl border border-indigo-100 bg-white/95 backdrop-blur-md px-5 py-4 text-sm font-semibold text-indigo-900 shadow-[0_10px_35px_-5px_rgba(99,102,241,0.2)] flex items-start justify-between gap-3">
            <div class="flex items-start gap-3">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-600 text-white text-[10px] font-black shadow-sm">✓</span>
              <p><%= notice %></p>
            </div>
            <button type="button" onclick="this.parentElement.remove()" class="ml-auto -mx-1.5 -my-1.5 rounded-lg p-1.5 text-slate-400 hover:text-slate-900 hover:bg-slate-100 inline-flex items-center justify-center h-8 w-8 shrink-0 cursor-pointer" aria-label="Close">
              <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
              </svg>
            </button>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="rounded-2xl border border-rose-100 bg-white/95 backdrop-blur-md px-5 py-4 text-sm font-semibold text-rose-900 shadow-[0_10px_35px_-5px_rgba(244,63,94,0.2)] flex items-start justify-between gap-3">
            <div class="flex items-start gap-3">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-rose-600 text-white text-[10px] font-black shadow-sm">!</span>
              <p><%= alert %></p>
            </div>
            <button type="button" onclick="this.parentElement.remove()" class="ml-auto -mx-1.5 -my-1.5 rounded-lg p-1.5 text-slate-400 hover:text-slate-900 hover:bg-slate-100 inline-flex items-center justify-center h-8 w-8 shrink-0 cursor-pointer" aria-label="Close">
              <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
              </svg>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="flex-grow">
      <%= yield %>
    </main>

    <% if controller_path.start_with?("admin/") %>
      <%= render "shared/admin_footer" %>
    <% else %>
      <%= render "shared/visitor_footer" %>
    <% end %>
  </body>
</html>
