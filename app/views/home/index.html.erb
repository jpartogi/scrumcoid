<% content_for :title, "Pelatihan Professional Scrum & Sertifikasi Resmi di Indonesia" %>
<% content_for :description, "Tingkatkan kemampuan tim Anda dengan pelatihan Scrum bersertifikasi resmi dari Scrum.org. PSM, PSPO, dan pelatihan Agile untuk organisasi di Indonesia." %>

<div class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <!-- Interactive radial glow & grid backdrop -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-indigo-950/60 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-30 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute inset-y-0 right-1/2 -z-10 mr-16 w-[200%] origin-bottom-left skew-x-[-30deg] bg-slate-950 shadow-xl shadow-indigo-600/5 ring-1 ring-slate-900/10" aria-hidden="true"></div>
  
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Premium Top Badge Capsule containing the h1 for SEO and HomeControllerTest -->
      <div class="mx-auto mb-8 flex max-w-fit items-center justify-center rounded-full bg-slate-900/90 px-4 py-1.5 ring-1 ring-indigo-500/30 backdrop-blur-sm shadow-inner transition-all hover:ring-indigo-400/50 shadow-[0_0_15px_rgba(99,102,241,0.1)]">
        <h1 class="text-xs font-bold uppercase tracking-widest text-indigo-400">
          Kuasai Profesional Scrum bersama Pelopor Scrum di Indonesia
        </h1>
      </div>

      <!-- High-impact typographic hierarchy -->
      <div class="text-4xl sm:text-6xl font-black tracking-tight text-white space-y-4 leading-[1.12]">
        <div class="bg-clip-text text-transparent bg-gradient-to-b from-white to-slate-200">Improve competitive advantage</div>
        <div class="bg-clip-text text-transparent bg-gradient-to-b from-white to-slate-200">Challenge the status quo</div>
        <div class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 via-purple-400 to-teal-300 font-extrabold pb-2">
          Lead by serving
        </div>
      </div>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-400">
        Memberdayakan Scrum Master, Product Owner, pengembang, dan pemimpin di Indonesia untuk berkolaborasi secara mandiri, meningkatkan efisiensi, dan menghadirkan nilai bisnis yang berkelanjutan.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <%= link_to "Lihat Pelatihan", courses_path, class: "w-full sm:w-auto rounded-full bg-gradient-to-r from-indigo-600 to-purple-600 px-8 py-4 text-sm font-bold text-white shadow-[0_0_20px_rgba(99,102,241,0.25)] hover:shadow-[0_0_35px_rgba(99,102,241,0.45)] hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 text-center" %>
        <%= link_to "Lihat Jadwal", class_schedules_path, class: "w-full sm:w-auto rounded-full border border-slate-800 bg-slate-900/60 px-8 py-4 text-sm font-bold text-slate-300 hover:text-white hover:bg-slate-900 hover:border-slate-700 backdrop-blur transition-all duration-200 text-center" %>
      </div>
    </div>
  </div>

  <!-- Additional absolute blur highlight -->
  <div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]" aria-hidden="true">
    <div class="relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 bg-gradient-to-tr from-indigo-500 to-teal-500 opacity-10 sm:left-[calc(50%+36rem)] sm:w-[72.187rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
  </div>
</div>

<div class="bg-slate-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-xs font-bold leading-7 text-indigo-600 uppercase tracking-widest">Ekosistem Pelatihan</h2>
      <p class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">Pelatihan komprehensif untuk tim Scrum di Indonesia</p>
    </div>
    <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none">
      <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-12 lg:max-w-none lg:grid-cols-3">
        
        <!-- Pillar 1 -->
        <div class="flex flex-col bg-white p-8 rounded-3xl border border-slate-200/80 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_-10px_rgba(99,102,241,0.06)] hover:-translate-y-1.5 hover:border-purple-500/40 transition-all duration-300">
          <dt class="text-lg font-bold leading-7 text-slate-900">
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-2xl bg-indigo-600 text-white shadow-[0_0_20px_rgba(79,70,229,0.3)]">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            Sertifikasi Resmi Scrum.org
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-slate-600">
            <p class="flex-auto leading-relaxed">Pelatihan bersertifikat global (seperti PSM, PSPO) untuk memvalidasi kompetensi kepemimpinan agile Anda.</p>
          </dd>
        </div>

        <!-- Pillar 2 -->
        <div class="flex flex-col bg-white p-8 rounded-3xl border border-slate-200/80 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_-10px_rgba(147,51,234,0.06)] hover:-translate-y-1.5 hover:border-purple-500/40 transition-all duration-300">
          <dt class="text-lg font-bold leading-7 text-slate-900">
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-2xl bg-purple-600 text-white shadow-[0_0_20px_rgba(147,51,234,0.3)]">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.998 5.998 0 00-12 0m12 0c0-1.24-.316-2.406-.867-3.414m-11.133 3.414a5.996 5.996 0 01-.867-3.414m1.954-4.819A5.991 5.991 0 0012 15h0a5.991 5.991 0 004.914-2.481m-9.828 0A5.996 5.996 0 0112 10h0c1.955 0 3.716.94 4.828 2.406m-9.656 0a6.012 6.012 0 001.666 1.71m9.656-1.71c-.562-.733-1.28-1.328-2.112-1.71" />
              </svg>
            </div>
            Pelatihan Tim Privat
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-slate-600">
            <p class="flex-auto leading-relaxed">Sesi pelatihan mendalam yang dirancang khusus menyesuaikan kebutuhan produk, tantangan, dan budaya organisasi Anda.</p>
          </dd>
        </div>

        <!-- Pillar 3 -->
        <div class="flex flex-col bg-white p-8 rounded-3xl border border-slate-200/80 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_-10px_rgba(13,148,136,0.06)] hover:-translate-y-1.5 hover:border-purple-500/40 transition-all duration-300">
          <dt class="text-lg font-bold leading-7 text-slate-900">
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-2xl bg-teal-600 text-white shadow-[0_0_20px_rgba(13,148,136,0.3)]">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.33.018.658.058.982.121m-17.73 0c.324-.063.651-.103.982-.121m15.766 0a48.374 48.374 0 00-15.766 0m15.766 0c.33.019.658.058.982.121m-17.73 0c.324-.063.651-.103.982-.121m15.766 0A48.536 48.536 0 0112 9.75c-5.263 0-10.308-.433-15.234-1.239m19.71 0a48.536 48.536 0 00-19.71 0" />
              </svg>
            </div>
            Dukungan Berkelanjutan
          </dt>
          <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-slate-600">
            <p class="flex-auto leading-relaxed">Komunitas Alumni pelatihan Professional Scrum yang besar dan saling mendukung satu sama lain.</p>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</div>

<section class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="flex flex-col items-start justify-between gap-y-6 sm:flex-row sm:items-end border-b border-slate-100 pb-8">
      <div>
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">Jadwal Pelatihan</h2>
        <p class="mt-2 text-lg text-slate-600">Ikuti pelatihan langsung interaktif dan penuh energi berikutnya bersama kami.</p>
      </div>
      <%= link_to class_schedules_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-700 flex items-center gap-1 group/link" do %>
        Jadwal Lengkap <span class="group-hover/link:translate-x-1 transition-transform duration-200">&rarr;</span>
      <% end %>
    </div>
    <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-10 sm:mt-16 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      <% @featured_schedules.each do |schedule| %>
        <article class="flex flex-col justify-between rounded-3xl border border-slate-200/80 bg-white p-8 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:shadow-[0_25px_50px_-12px_rgba(99,102,241,0.08)] hover:-translate-y-1.5 hover:border-purple-500/40 transition-all duration-300 relative group">
          <div>
            <div class="flex items-start gap-4">
              <% if schedule.course.logo.attached? %>
                <%= image_tag schedule.course.logo, alt: "#{schedule.course.title} logo", class: "h-20 w-20 rounded-2xl border border-slate-100 bg-slate-50/50 object-contain p-[2px] shrink-0 shadow-sm group-hover:scale-105 transition-transform duration-300" %>
              <% else %>
                <div class="h-20 w-20 rounded-2xl border border-slate-100 bg-indigo-50 text-indigo-600 flex items-center justify-center shrink-0 shadow-sm group-hover:scale-105 transition-transform duration-300">
                  <svg class="h-9 w-9" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                  </svg>
                </div>
              <% end %>
              <div class="flex-grow min-w-0">
                <h3 class="text-xl font-bold leading-7 text-slate-900 group-hover:text-indigo-600 transition-colors line-clamp-2 relative z-20">
                  <%= link_to schedule.course.title, class_schedule_path(schedule) %>
                </h3>
                <div class="mt-2 flex flex-col gap-0.5">
                  <span class="inline-flex items-center gap-1.5 text-xs font-bold text-indigo-600 tracking-wide uppercase">
                    <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                    </svg>
                    <%= class_schedule_date_part(schedule) %>
                  </span>
                  <span class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500">
                    <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <%= class_schedule_time_part(schedule) %>
                  </span>
                </div>
              </div>
            </div>
            <p class="mt-4 text-sm text-slate-500 line-clamp-3 leading-relaxed"><%= schedule.course.excerpt %></p>
          </div>
          <div class="mt-8 flex w-full items-center justify-between border-t border-slate-100 pt-6">
            <span class="inline-flex items-center rounded-full bg-amber-50 px-3 py-1.5 text-xs font-bold text-amber-700 ring-1 ring-inset ring-amber-600/15 shadow-sm">
              <%= schedule.remaining_seats %> kursi tersisa
            </span>
            <div class="flex items-center gap-2 relative z-20">
              <%= link_to "Detail", class_schedule_path(schedule), class: "rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-bold text-slate-700 hover:bg-slate-50 transition-all shadow-sm active:scale-95" %>
              <%= link_to new_class_schedule_registration_path(schedule), class: "inline-flex items-center gap-1 rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-bold text-white hover:bg-indigo-700 transition-all shadow-sm active:scale-95 group/btn" do %>
                Daftar <span class="group-hover/btn:translate-x-0.5 transition-transform duration-200">&rarr;</span>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>

<section class="bg-gradient-to-b from-slate-900 to-slate-950 py-24 sm:py-32 rounded-[3rem] mx-4 my-8 overflow-hidden relative shadow-2xl border border-slate-800">
  <div class="absolute inset-0 -z-10 opacity-30 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.1) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="flex flex-col items-start justify-between gap-y-6 sm:flex-row sm:items-end border-b border-slate-850 pb-8">
      <div>
        <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">Wawasan Terbaru</h2>
        <p class="mt-2 text-lg text-slate-400">Pemikiran kepemimpinan tentang Scrum dan manajemen produk.</p>
      </div>
      <%= link_to blog_posts_path, class: "text-sm font-bold text-indigo-400 hover:text-indigo-300 flex items-center gap-1 group/link" do %>
        Baca Blog <span class="group-hover/link:translate-x-1 transition-transform duration-200">&rarr;</span>
      <% end %>
    </div>
    <div class="mx-auto mt-12 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 sm:mt-16 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      <% @recent_posts.each do |post| %>
        <article class="group relative flex flex-col items-start justify-between rounded-3xl bg-slate-950/60 p-8 border border-slate-800/80 transition-all hover:bg-slate-900/90 hover:border-indigo-500/20 hover:shadow-[0_10px_30px_-10px_rgba(99,102,241,0.1)]">
          <!-- Entire card is clickable -->
          <%= link_to blog_post_path(post), class: "absolute inset-0 z-10 rounded-3xl", aria: { label: "Baca #{post.title}" } do %>
          <% end %>

          <div class="flex items-center gap-x-4 text-xs">
            <time datetime="<%= post.published_at&.to_date %>" class="text-slate-500 font-bold uppercase tracking-widest">
              <%= post.published_at&.to_date&.to_fs(:long) %>
            </time>
          </div>

          <div class="w-full">
            <h3 class="mt-4 text-xl font-bold leading-7 text-white group-hover:text-indigo-400 transition-colors">
              <%= link_to post.title, blog_post_path(post), class: "relative z-20" %>
            </h3>
            <p class="mt-4 text-sm leading-6 text-slate-400 line-clamp-3">
              <%= post.excerpt %>
            </p>
          </div>

          <div class="relative z-20 mt-8">
            <%= link_to blog_post_path(post), class: "inline-flex items-center gap-1 text-indigo-400 text-sm font-bold group-hover:text-indigo-300 transition-colors group/btn" do %>
              Selengkapnya <span class="group-hover/btn:translate-x-1 transition-transform duration-200">&rarr;</span>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>
