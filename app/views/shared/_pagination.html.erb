<%# locals: (paginated:, path:, extra_params: {}, include_per_page: true, previous_label: "Prev", next_label: "Next") %>
<nav class="flex items-center justify-end gap-1.5" aria-label="Pagination">
  <ul class="inline-flex items-center gap-1.5">
    <% unless paginated.first_page? %>
      <li>
        <%= link_to paginated_path(path, paginated, page: 1, include_per_page: include_per_page, **extra_params), class: "inline-flex min-w-9 h-9 items-center justify-center rounded-xl border border-slate-200 bg-white px-3 text-xs font-bold text-slate-600 hover:border-indigo-500/30 hover:bg-indigo-50/50 hover:text-indigo-600 shadow-sm active:scale-95 transition-all duration-200", title: "Halaman Pertama" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18.75 19.5l-7.5-7.5 7.5-7.5m-6 15L5.25 12l7.5-7.5" />
          </svg>
        <% end %>
      </li>
      <li>
        <%= link_to paginated_path(path, paginated, page: paginated.current_page - 1, include_per_page: include_per_page, **extra_params), class: "inline-flex h-9 items-center gap-1.5 rounded-xl border border-slate-200 bg-white px-3.5 text-xs font-bold text-slate-600 hover:border-indigo-500/30 hover:bg-indigo-50/50 hover:text-indigo-600 shadow-sm active:scale-95 transition-all duration-200", rel: "prev" do %>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
          <%= local_assigns.fetch(:previous_label, "Sebelumnya") %>
        <% end %>
      </li>
    <% end %>

    <% previous_page = nil %>
    <% pagination_window(paginated).each do |page| %>
      <% if previous_page && page > previous_page + 1 %>
        <li>
          <span class="inline-flex min-w-9 h-9 items-center justify-center px-2 text-xs font-bold text-slate-400 select-none">&hellip;</span>
        </li>
      <% end %>
      <li>
        <% if page == paginated.current_page %>
          <span class="inline-flex min-w-9 h-9 items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-3.5 text-xs font-black text-white shadow-[0_4px_12px_rgba(99,102,241,0.25)] select-none" aria-current="page"><%= page %></span>
        <% else %>
          <%= link_to page, paginated_path(path, paginated, page: page, include_per_page: include_per_page, **extra_params), class: "inline-flex min-w-9 h-9 items-center justify-center rounded-xl border border-slate-200 bg-white px-3 text-xs font-bold text-slate-600 hover:border-indigo-500/30 hover:bg-indigo-50/50 hover:text-indigo-600 shadow-sm active:scale-95 transition-all duration-200" %>
        <% end %>
      </li>
      <% previous_page = page %>
    <% end %>

    <% unless paginated.last_page? %>
      <li>
        <%= link_to paginated_path(path, paginated, page: paginated.current_page + 1, include_per_page: include_per_page, **extra_params), class: "inline-flex h-9 items-center gap-1.5 rounded-xl border border-slate-200 bg-white px-3.5 text-xs font-bold text-slate-600 hover:border-indigo-500/30 hover:bg-indigo-50/50 hover:text-indigo-600 shadow-sm active:scale-95 transition-all duration-200", rel: "next" do %>
          <%= local_assigns.fetch(:next_label, "Berikutnya") %>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        <% end %>
      </li>
      <li>
        <%= link_to paginated_path(path, paginated, page: paginated.total_pages, include_per_page: include_per_page, **extra_params), class: "inline-flex min-w-9 h-9 items-center justify-center rounded-xl border border-slate-200 bg-white px-3 text-xs font-bold text-slate-600 hover:border-indigo-500/30 hover:bg-indigo-50/50 hover:text-indigo-600 shadow-sm active:scale-95 transition-all duration-200", title: "Halaman Terakhir" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 4.5l7.5 7.5-7.5 7.5m-6-15l7.5 7.5-7.5 7.5" />
          </svg>
        <% end %>
      </li>
    <% end %>
  </ul>
</nav>