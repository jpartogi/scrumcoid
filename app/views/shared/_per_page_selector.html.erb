<%# locals: (paginated:, url:) %>
<%= form_with url: url, method: :get, class: "inline-flex items-center gap-2" do |form| %>
  <%= form.label :per_page, "Items per page", class: "text-xs font-semibold text-slate-500 whitespace-nowrap" %>
  <%= form.number_field :per_page,
    value: paginated.per_page,
    min: PaginatedScope::MIN_PER_PAGE,
    max: PaginatedScope::MAX_PER_PAGE,
    class: "w-16 rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-semibold text-slate-900 shadow-sm focus:border-teal-600 focus:ring-2 focus:ring-teal-600/10 transition-all",
    onchange: "this.form.requestSubmit()" %>
<% end %>