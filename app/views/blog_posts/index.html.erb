<% content_for :title, "Blog — Wawasan Scrum, Agile & Business Agility" %>
<% content_for :description, "Baca artikel terbaru tentang Scrum, Agile, Business Agility, dan Evidence Based Management. Panduan praktis dan studi kasus dari tim scrum.co.id." %>

<section class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-20 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-82 w-82 rounded-full bg-teal-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl lg:mx-0">
      <span class="inline-flex items-center rounded-full bg-teal-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-teal-400 ring-1 ring-inset ring-teal-500/30 shadow-[0_0_15px_rgba(20,184,166,0.1)]">
        Wawasan & Perspektif
      </span>
      <h1 class="mt-6 text-4xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        Scrum, Manajemen Produk, dan <br class="hidden sm:inline" />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-indigo-400">Evidence Based Management</span>
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-350">
        <% if @current_tag.present? %>
          Artikel dengan tag <span class="text-teal-400 font-bold"><%= @current_tag %></span>.
        <% else %>
          Panduan praktis, studi kasus, dan pemikiran kepemimpinan untuk memandu transformasi agile dan meningkatkan efektivitas tim produk Anda di Indonesia.
        <% end %>
      </p>
      <% if @current_tag.present? %>
        <div class="mt-6">
          <%= link_to blog_posts_path, class: "text-sm font-bold text-indigo-400 hover:text-indigo-300 transition-colors" do %>
            &larr; Lihat semua artikel
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <%= render "tag_filter", all_tags: @all_tags, current_tag: @current_tag %>

    <% if @blog_posts.any? %>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <% @blog_posts.each do |post| %>
          <article class="relative isolate flex flex-col justify-between bg-white rounded-[2rem] p-8 border border-slate-200/80 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_45px_-12px_rgba(99,102,241,0.07)] hover:border-purple-500/40 hover:scale-[1.005] transition-all duration-300 group">

            <div>
              <div class="flex items-center gap-x-4 text-xs">
                <time datetime="<%= post.published_at&.to_date %>" class="text-slate-400 font-bold uppercase tracking-wider">
                  <%= post.published_at&.to_date&.to_fs(:long) %>
                </time>
              </div>

              <div class="relative z-20">
                <h3 class="mt-4 text-xl font-bold leading-7 text-slate-900 group-hover:text-indigo-600 transition-colors">
                  <%= link_to post.title, blog_post_path(post), class: "relative z-20" %>
                </h3>
                <p class="mt-4 text-sm leading-relaxed text-slate-600 line-clamp-4">
                  <%= post.excerpt %>
                </p>
              </div>

              <%= render "tags", post: post, wrapper_class: "mt-4" %>
            </div>

            <div class="relative z-20 mt-6 pt-4 border-t border-slate-100 flex items-center justify-between">
              <%= link_to blog_post_path(post), class: "text-indigo-600 text-sm font-bold hover:text-indigo-700 transition-colors flex items-center gap-1 group/btn" do %>
                Selengkapnya <span class="group-hover/btn:translate-x-1 transition-transform duration-200">&rarr;</span>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>

      <% if @blog_posts.total_pages > 1 %>
        <div class="mt-16 flex flex-col gap-4 rounded-[2rem] border border-slate-200/80 bg-white px-8 py-6 shadow-[0_8px_30px_rgb(0,0,0,0.015)] sm:flex-row sm:items-center sm:justify-between animate-fade-in">
          <p class="text-sm font-medium text-slate-500 flex items-center gap-2.5">
            <span class="inline-block h-2 w-2 rounded-full bg-teal-500 shadow-sm shadow-teal-500/25"></span>
            <%= page_entries_info_for(@blog_posts, entry_name: "artikel", locale: :id) %>
          </p>
          <%= render "shared/pagination",
            paginated: @blog_posts,
            path: method(:blog_posts_path),
            extra_params: { tag: @current_tag.presence },
            include_per_page: false,
            previous_label: "Sebelumnya",
            next_label: "Berikutnya" %>
        </div>
      <% end %>
    <% else %>
      <div class="rounded-[2rem] border-2 border-dashed border-slate-200 bg-white py-12 px-6 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-400 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <h3 class="mt-4 text-base font-bold text-slate-900">
          <%= @current_tag.present? ? "Tidak ada artikel dengan tag ini" : "Belum ada artikel blog" %>
        </h3>
        <p class="mt-2 text-sm text-slate-500">
          <% if @current_tag.present? %>
            Coba tag lain atau <%= link_to "lihat semua artikel", blog_posts_path, class: "font-bold text-indigo-600 hover:text-indigo-700" %>.
          <% else %>
            Silakan periksa kembali nanti untuk pembaruan wawasan terbaru dari kami.
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
</div>
