<section class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-82 w-82 rounded-full bg-teal-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl lg:mx-0">
      <span class="inline-flex items-center rounded-full bg-teal-500/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-teal-400 ring-1 ring-inset ring-teal-500/30">
        Wawasan & Perspektif
      </span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-black tracking-tight text-white">
        Scrum, Ketangkasan, dan <br class="hidden sm:inline" />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-indigo-400">Pengiriman Berbasis Bukti</span>
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-400">
        Panduan praktis, studi kasus, dan pemikiran kepemimpinan untuk memandu transformasi agile dan meningkatkan efektivitas tim produk Anda di Indonesia.
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <% if @blog_posts.any? %>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <% @blog_posts.each do |post| %>
          <article class="flex flex-col bg-white rounded-3xl p-8 border border-slate-200/60 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md">
            <div class="flex items-center gap-x-4 text-xs">
              <time datetime="<%= post.published_at&.to_date %>" class="text-slate-400 font-bold uppercase tracking-wider">
                <%= post.published_at&.to_date&.to_fs(:long) %>
              </time>
            </div>
            <div class="group relative flex-grow">
              <h3 class="mt-4 text-xl font-bold leading-6 text-slate-900 group-hover:text-indigo-600 transition-colors">
                <%= link_to blog_post_path(post) do %>
                  <span class="absolute inset-0"></span>
                  <%= post.title %>
                <% end %>
              </h3>
              <p class="mt-4 text-sm leading-6 text-slate-600 line-clamp-4">
                <%= post.excerpt %>
              </p>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-100 flex items-center justify-between">
              <span class="text-indigo-600 text-sm font-bold group-hover:text-indigo-500">Baca artikel &rarr;</span>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-2xl border-2 border-dashed border-slate-200 bg-white py-12 px-4 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <h3 class="mt-4 text-sm font-bold text-slate-900">Belum ada artikel blog</h3>
        <p class="mt-1 text-sm text-slate-500">Silakan periksa kembali nanti untuk pembaruan wawasan terbaru dari kami.</p>
      </div>
    <% end %>
  </div>
</div>
