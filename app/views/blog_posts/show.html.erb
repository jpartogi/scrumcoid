<% content_for :title, @blog_post.title %>
<% content_for :description, @blog_post.excerpt.presence || "Baca artikel #{@blog_post.title} di blog scrum.co.id — wawasan Scrum, Agile, dan Business Agility untuk profesional Indonesia." %>
<% content_for :keywords, @blog_post.meta_keywords if @blog_post.meta_keywords.present? %>

<section class="relative isolate overflow-hidden bg-slate-950 py-16 sm:py-20">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-20 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <% if current_user&.admin? %>
      <div class="mb-6 flex justify-end">
        <div class="inline-flex items-center gap-2 rounded-2xl border border-white/10 bg-white/5 px-3 py-2 backdrop-blur-sm">
          <span class="text-[10px] font-bold uppercase tracking-widest text-white/40">Admin</span>
          <div class="h-3 w-px bg-white/20"></div>
          <%= render "admin_edit_link", blog_post: @blog_post %>
        </div>
      </div>
    <% end %>
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-flex items-center rounded-full bg-teal-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-teal-400 ring-1 ring-inset ring-teal-500/30 shadow-[0_0_15px_rgba(20,184,166,0.1)]">
        Detail Artikel
      </span>
      <h1 class="mt-6 text-3xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        <%= @blog_post.title %>
      </h1>
      <div class="mt-6 flex items-center justify-center gap-x-4 text-sm text-slate-350">
        <time datetime="<%= @blog_post.published_at&.to_date %>" class="font-bold uppercase tracking-wider text-teal-400">
          <%= @blog_post.published_at&.to_date&.to_fs(:long) %>
        </time>
        <span class="text-slate-700">&bull;</span>
        <span class="font-medium">Oleh Redaksi scrum.co.id</span>
      </div>
      <% if @blog_post.tag_list.any? %>
        <div class="mt-6 flex flex-col items-center gap-2">
          <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Topik</p>
          <%= render "tags", post: @blog_post, wrapper_class: "justify-center", link_class: blog_post_tag_link_class_on_dark %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<article class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1fr_340px]">
      
      <!-- Left side: Blog Post Card -->
      <div class="space-y-6">
        <div class="bg-white rounded-[2.5rem] p-8 sm:p-12 border border-slate-200/80 shadow-[0_4px_30px_-10px_rgba(0,0,0,0.02)]">
          <div class="max-w-3xl mx-auto">
            <div class="text-xl sm:text-2xl font-semibold leading-relaxed text-slate-800 border-l-4 border-teal-500 pl-6 mb-10 italic bg-teal-50/30 py-4 pr-4 rounded-r-xl">
              <%= @blog_post.excerpt %>
            </div>
            
            <div class="text-slate-800 leading-relaxed space-y-6 prose max-w-none text-lg">
              <%= @blog_post.body %>
            </div>
          </div>

          <div class="mt-16 pt-8 border-t border-slate-100 flex flex-wrap items-center justify-between gap-4">
            <%= link_to blog_posts_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-700 flex items-center gap-1 group/back" do %>
              <span class="group-hover/back:-translate-x-1 transition-transform duration-200">&larr;</span> Kembali ke Blog
            <% end %>
            <div class="flex items-center gap-4">
              <% if current_user&.admin? %>
                <%= render "admin_edit_link", blog_post: @blog_post %>
              <% end %>
              <span class="text-xs text-slate-400 font-bold uppercase tracking-wider">scrum.co.id</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right side: Sidebar -->
      <aside class="lg:sticky lg:top-8 space-y-6 self-start">
        <!-- Topic/Hashtag card -->
        <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm transition-all duration-300 hover:border-purple-500/40">
          <h3 class="text-xs font-bold text-slate-950 border-b border-slate-100 pb-3 mb-4 uppercase tracking-widest text-slate-400">Topik Artikel</h3>
          <div class="flex flex-wrap gap-2">
            <% BlogPost.all_tags.each do |tag| %>
              <%= link_to blog_posts_path(tag: tag), class: "inline-flex items-center rounded-xl bg-slate-50 border border-slate-200/60 px-3 py-1.5 text-xs font-bold text-slate-600 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50/10 active:scale-[0.98] transition-all cursor-pointer shadow-sm" do %>
                <span class="text-indigo-400 font-bold mr-0.5">#</span><%= tag %>
              <% end %>
            <% end %>
          </div>
        </div>

        <!-- CTA Widget -->
        <div class="rounded-3xl border border-slate-200/80 bg-slate-900 p-6 shadow-xl transition-all duration-300 hover:border-purple-500/40 text-white relative overflow-hidden">
          <!-- Glow details -->
          <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_right,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent opacity-60"></div>
          <div class="absolute -right-10 -top-10 -z-10 h-40 w-40 rounded-full bg-indigo-500/10 blur-2xl"></div>

          <span class="text-[10px] font-bold uppercase tracking-wider text-indigo-400">Pelatihan Live / In-House</span>
          <h3 class="mt-3 text-lg font-black text-white leading-snug">Ingin mempelajari Scrum dari Scrum.org Trainer resmi?</h3>
          <p class="mt-2 text-xs text-slate-400 leading-relaxed font-medium">Pilih jadwal kelas publik terdekat kami atau hubungi kami untuk mendiskusikan kebutuhan pelatihan privat/in-house yang disesuaikan untuk organisasi Anda.</p>
          <div class="mt-6 flex flex-col gap-3">
            <%= link_to "Lihat Jadwal Kelas Publik", class_schedules_path, class: "w-full inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-4 py-3 text-xs font-bold text-white shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:scale-[1.02] active:scale-[0.98] transition-all text-center" %>
            <%= link_to "https://wa.me/6285643428348", target: "_blank", rel: "noopener", class: "w-full inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-xs font-bold text-white hover:bg-emerald-700 shadow-lg shadow-emerald-500/20 hover:shadow-emerald-500/40 hover:scale-[1.02] active:scale-[0.98] transition-all text-center" do %>
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.739-1.456L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.963C16.48 2.012 14.005.992 11.37.992c-5.447 0-9.87 4.37-9.874 9.8.001 1.95.518 3.854 1.502 5.561l-.987 3.606 3.702-.97c1.644.896 3.23 1.365 4.834 1.365zm10.638-7.468c-.287-.143-1.696-.838-1.959-.933-.262-.095-.453-.143-.644.143-.19.287-.738.933-.905 1.124-.167.19-.333.214-.62.071-.287-.143-1.21-.446-2.305-1.424-.853-.76-1.428-1.7-1.595-1.986-.167-.286-.018-.44.125-.581.129-.127.287-.333.43-.5.143-.167.19-.286.287-.476.095-.19.047-.357-.024-.5-.071-.143-.644-1.547-.882-2.12-.232-.559-.467-.483-.644-.492-.167-.008-.358-.01-.55-.01-.19 0-.5.071-.762.357-.262.287-1 .977-1 2.38 0 1.405 1.023 2.762 1.166 2.953.143.19 2.013 3.074 4.877 4.31.681.294 1.213.47 1.627.601.684.218 1.307.187 1.8.114.55-.082 1.696-.692 1.935-1.36.239-.667.239-1.24.167-1.36-.072-.119-.262-.19-.549-.333z"/>
              </svg>
              Chat Jessica via WhatsApp
            <% end %>
            <%= link_to "Hubungi Kami (Kelas Privat)", new_contact_path(jenis_inkuiri: "Quotation Pelatihan Privat"), class: "w-full inline-flex items-center justify-center rounded-xl border border-slate-700 bg-slate-800/40 px-4 py-3 text-xs font-bold text-slate-300 hover:text-white hover:bg-slate-800 hover:border-slate-600 transition-all text-center" %>
          </div>
        </div>
      </aside>

    </div>

    <!-- Related articles (full width at the bottom) -->
    <% if @related_posts.any? %>
      <div class="mt-16 pt-12 border-t border-slate-200/80">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">Artikel Terkait</h2>
        <p class="mt-2 text-sm text-slate-600">Baca wawasan dan panduan lain yang relevan dengan topik ini.</p>
        <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% @related_posts.each do |post| %>
            <article class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:border-indigo-500/30 hover:shadow-md transition-all group">
              <time datetime="<%= post.published_at&.to_date %>" class="text-xs font-bold uppercase tracking-wider text-slate-400">
                <%= post.published_at&.to_date&.to_fs(:long) %>
              </time>
              <h3 class="mt-3 text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">
                <%= link_to post.title, blog_post_path(post) %>
              </h3>
              <p class="mt-2 text-sm text-slate-600 line-clamp-3"><%= post.excerpt %></p>
              <%= render "tags", post: post, wrapper_class: "mt-4" %>
            </article>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</article>
