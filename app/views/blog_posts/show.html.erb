<section class="relative isolate overflow-hidden bg-slate-950 py-16 sm:py-20">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-3xl px-6 lg:px-8">
    <div class="text-center">
      <span class="inline-flex items-center rounded-full bg-teal-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-teal-400 ring-1 ring-inset ring-teal-500/30">
        Detail Artikel
      </span>
      <h1 class="mt-4 text-3xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        <%= @blog_post.title %>
      </h1>
      <div class="mt-6 flex items-center justify-center gap-x-4 text-sm text-slate-400">
        <time datetime="<%= @blog_post.published_at&.to_date %>" class="font-bold uppercase tracking-wider text-teal-400">
          <%= @blog_post.published_at&.to_date&.to_fs(:long) %>
        </time>
        <span class="text-slate-600">&bull;</span>
        <span>Oleh Redaksi scrum.co.id</span>
      </div>
    </div>
  </div>
</section>

<article class="bg-slate-50 py-16">
  <div class="mx-auto max-w-3xl px-6">
    <div class="bg-white rounded-3xl p-8 sm:p-12 border border-slate-200/60 shadow-sm">
      <p class="text-xl sm:text-2xl font-medium leading-9 text-slate-800 border-l-4 border-teal-500 pl-6 mb-8 italic">
        <%= @blog_post.excerpt %>
      </p>
      
      <div class="text-slate-800 leading-relaxed space-y-6 prose max-w-none text-lg">
        <%= @blog_post.body %>
      </div>

      <div class="mt-12 pt-8 border-t border-slate-100 flex items-center justify-between">
        <%= link_to "&larr; Kembali ke Blog".html_safe, blog_posts_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
        <span class="text-xs text-slate-400 font-semibold uppercase tracking-wider">scrum.co.id</span>
      </div>
    </div>
  </div>
</article>
