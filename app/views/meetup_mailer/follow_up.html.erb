<div style="background-color: #f8fafc; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; margin: 0; padding: 40px 20px; color: #334155; line-height: 1.6;">
  <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.03);">
    <div style="height: 6px; background: linear-gradient(to right, #4f46e5, #0ea5e9);"></div>

    <div style="padding: 32px 40px;">
      <div style="margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid #f1f5f9;">
        <span style="font-size: 16px; font-weight: 800; color: #0f172a; letter-spacing: -0.5px;">Scrum<span style="color: #4f46e5;">.co.id</span></span>
        <div style="font-size: 11px; color: #64748b; margin-top: 2px;">PT. Adaptiva Sinergi Asia</div>
      </div>

      <p style="font-size: 15px; margin-top: 0; color: #0f172a; font-weight: 600;">Halo <%= @registration.visitor_name %>,</p>

      <p style="font-size: 14px; color: #475569; margin-bottom: 20px;">
        Terima kasih telah menghadiri meetup pada <strong><%= meetup_display_name(@meetup) %></strong>. Kami harap Anda mendapatkan wawasan yang bermanfaat dari sesi ini.
      </p>

      <p style="font-size: 14px; color: #475569; margin-bottom: 20px;">
        Jika Anda merasa meetup ini bermanfaat, pertimbangkan untuk mendukung komunitas kami melalui donasi PayPal. Kontribusi Anda membantu kami menyelenggarakan lebih banyak meetup gratis di masa mendatang.
      </p>

      <% if @donation_url.present? %>
        <div style="text-align: center; margin-bottom: 24px;">
          <a href="<%= @donation_url %>" style="display: inline-block; background: #0070ba; color: #ffffff; text-decoration: none; font-size: 14px; font-weight: 700; padding: 14px 28px; border-radius: 12px;">
            Donasi via PayPal
          </a>
        </div>
        <p style="font-size: 12px; color: #94a3b8; word-break: break-all;">
          Atau salin tautan ini: <%= @donation_url %>
        </p>
      <% end %>

      <p style="font-size: 13px; color: #64748b; margin-top: 32px; margin-bottom: 0;">
        Terima kasih atas dukungan Anda!
      </p>
    </div>
  </div>
</div>