<% content_for :title, @course.title %>
<% content_for :description, @course.excerpt.presence || "Pelajari lebih lanjut tentang #{@course.title} — pelatihan Scrum bersertifikat resmi dari Scrum.org yang tersedia di Indonesia." %>
<% content_for :keywords, @course.meta_keywords if @course.meta_keywords.present? %>

<section class="relative isolate overflow-hidden bg-slate-950 py-20 sm:py-24">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-20 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1fr_360px] items-center">
      <div>
        <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30 shadow-[0_0_15px_rgba(99,102,241,0.1)]">
          Pelatihan Profesional
        </span>
        <h1 class="mt-6 text-3xl sm:text-5xl font-black tracking-tight text-white leading-tight">
          <%= @course.title %>
        </h1>
        <p class="mt-6 text-lg leading-7 text-slate-300">
          <%= @course.excerpt %>
        </p>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-48 h-48 sm:w-56 sm:h-56 rounded-[2rem] bg-slate-900/40 border border-slate-800/80 p-8 shadow-[0_0_50px_rgba(99,102,241,0.15)] flex items-center justify-center backdrop-blur-md group">
          <div class="absolute inset-0 rounded-[2rem] bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-500/15 via-transparent to-transparent opacity-60"></div>
          <% if @course.logo.attached? %>
            <%= image_tag @course.logo, alt: "#{@course.title} logo", class: "h-full w-full object-contain relative z-10 group-hover:scale-105 transition-transform duration-300" %>
          <% else %>
            <div class="text-indigo-400 relative z-10 group-hover:scale-105 transition-transform duration-300">
              <svg class="h-20 w-20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1fr_340px]">
      <!-- Course Description Body -->
      <article class="bg-white rounded-[2.5rem] p-8 sm:p-10 border border-slate-200/80 shadow-[0_4px_30px_-10px_rgba(0,0,0,0.02)]">
        <h2 class="text-2xl font-bold text-slate-950 mb-6 pb-4 border-b border-slate-100">
          Deskripsi Pelatihan & Sasaran Pembelajaran
        </h2>
        <div class="text-slate-700 leading-relaxed space-y-6 prose max-w-none text-base">
          <%= @course.description %>
        </div>
      </article>

      <!-- Sidebar Pricing -->
      <aside class="lg:sticky lg:top-8 space-y-6 self-start">
        <div class="rounded-3xl border border-slate-200/80 bg-white p-8 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:border-purple-500/40 transition-all duration-300">
          <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Investasi Kelas</span>
          <div class="mt-2 flex items-baseline gap-x-2">
            <span class="text-2xl font-black tracking-tight text-slate-900 leading-tight"><%= @course.display_price_for(current_currency) %></span>
          </div>
          <p class="mt-4 text-xs text-slate-555 leading-relaxed">
            Biaya standar per peserta. Diskon tersedia untuk pendaftaran grup atau early-bird. Periksa detail kartu jadwal kelas di bawah.
          </p>
          <div class="mt-6">
            <a href="#schedules" class="w-full inline-flex justify-center items-center rounded-xl bg-slate-950 px-4 py-3 text-sm font-bold text-white hover:bg-indigo-600 transition-colors shadow-sm cursor-pointer hover:shadow-lg hover:shadow-indigo-500/10 active:scale-[0.985]">
              Lihat Jadwal Kelas
            </a>
          </div>
        </div>

        <div class="rounded-3xl border border-slate-200/80 bg-white p-8 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:border-purple-500/40 transition-all duration-300">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900">Butuh pelatihan privat?</h3>
          <p class="mt-2 text-xs text-slate-600 leading-relaxed">
            Kami menyelenggarakan coaching dan pelatihan privat khusus yang disesuaikan dengan produk, tools, dan tantangan tim Anda.
          </p>
          <%= link_to new_contact_path(subject: "Pelatihan privat: #{@course.title}"), class: "mt-4 inline-flex items-center text-xs font-bold text-indigo-600 hover:text-indigo-700 transition-colors group/link" do %>
            Tanyakan tentang kelas privat <span class="group-hover/link:translate-x-1 transition-transform duration-200">&rarr;</span>
          <% end %>
        </div>
      </aside>
    </div>

    <% if @related_blog_posts.any? %>
      <div class="mt-20">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Artikel Terkait</h2>
        <p class="mt-2 text-sm text-slate-600">Baca wawasan dan panduan yang relevan dengan pelatihan ini.</p>
        <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% @related_blog_posts.each do |post| %>
            <article class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:border-indigo-500/30 transition-all group">
              <time datetime="<%= post.published_at&.to_date %>" class="text-xs font-bold uppercase tracking-wider text-slate-400">
                <%= post.published_at&.to_date&.to_fs(:long) %>
              </time>
              <h3 class="mt-3 text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">
                <%= link_to post.title, blog_post_path(post) %>
              </h3>
              <p class="mt-2 text-sm text-slate-600 line-clamp-3"><%= post.excerpt %></p>
            </article>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Available Schedules -->
    <div id="schedules" class="mt-20 scroll-mt-24">
      <div class="border-t border-slate-200 pt-16">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Jadwal Kelas Tersedia</h2>
        <p class="mt-2 text-sm text-slate-600">Amankan slot Anda di salah satu sesi interaktif yang dipandu langsung oleh trainer kami.</p>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          <% if @class_schedules.any? %>
            <% @class_schedules.each do |schedule| %>
              <%= render "class_schedules/card", schedule: schedule, logo_padding_class: "p-[2px]" %>
            <% end %>
          <% else %>
            <div class="col-span-full rounded-[2rem] border-2 border-dashed border-slate-200 bg-white py-12 px-6 text-center">
              <svg class="mx-auto h-12 w-12 text-slate-400 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <h3 class="mt-4 text-base font-bold text-slate-900">Belum ada kelas publik yang dijadwalkan</h3>
              <p class="mt-2 text-sm text-slate-500">Hubungi kami untuk meminta sesi baru atau merancang pelatihan khusus perusahaan.</p>
              <div class="mt-6">
                <%= link_to new_contact_path(subject: "Tertarik pada: #{@course.title}"), class: "inline-flex items-center rounded-xl bg-indigo-50 px-5 py-3 text-sm font-bold text-indigo-700 hover:bg-indigo-100 transition-all shadow-sm active:scale-[0.98]" do %>
                  Hubungi kami &rarr;
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
</div>
