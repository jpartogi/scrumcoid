<section class="relative isolate overflow-hidden bg-slate-950 py-20 sm:py-24">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1fr_360px] items-center">
      <div>
        <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
          Kursus Profesional
        </span>
        <h1 class="mt-4 text-3xl sm:text-5xl font-black tracking-tight text-white leading-tight">
          <%= @course.title %>
        </h1>
        <p class="mt-6 text-lg leading-7 text-slate-300">
          <%= @course.excerpt %>
        </p>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-48 h-48 sm:w-56 sm:h-56 rounded-3xl bg-slate-900/60 border border-slate-800 p-8 shadow-2xl flex items-center justify-center backdrop-blur-md">
          <div class="absolute inset-0 rounded-3xl bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent opacity-60"></div>
          <% if @course.logo.attached? %>
            <%= image_tag @course.logo, alt: "#{@course.title} logo", class: "h-full w-full object-contain relative z-10" %>
          <% else %>
            <div class="text-indigo-400 relative z-10">
              <svg class="h-20 w-20" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1fr_360px]">
      <!-- Course Description Body -->
      <article class="bg-white rounded-3xl p-8 sm:p-10 border border-slate-200/60 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-900 mb-6 pb-4 border-b border-slate-100">
          Deskripsi Kursus & Sasaran Pembelajaran
        </h2>
        <div class="text-slate-700 leading-relaxed space-y-6 prose max-w-none text-base">
          <%= @course.description %>
        </div>
      </article>

      <!-- Sidebar Pricing -->
      <aside class="space-y-6">
        <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
          <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Investasi Kelas</span>
          <div class="mt-2 flex items-baseline gap-x-2">
            <span class="text-4xl font-extrabold tracking-tight text-slate-900"><%= @course.display_price_for(current_currency) %></span>
          </div>
          <p class="mt-4 text-xs text-slate-500 leading-relaxed">
            Biaya standar per peserta. Diskon tersedia untuk pendaftaran grup atau early-bird. Periksa detail kartu jadwal kelas di bawah.
          </p>
          <div class="mt-6">
            <a href="#schedules" class="w-full inline-flex justify-center items-center rounded-xl bg-slate-900 px-4 py-3 text-sm font-bold text-white hover:bg-indigo-600 transition-colors shadow-sm cursor-pointer">
              Lihat Jadwal Kelas
            </a>
          </div>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900">Butuh pelatihan privat?</h3>
          <p class="mt-2 text-xs text-slate-600 leading-relaxed">
            Kami menyelenggarakan coaching dan pelatihan privat khusus yang disesuaikan dengan produk, tools, dan tantangan tim Anda.
          </p>
          <%= link_to "Tanyakan tentang kelas privat", new_contact_path(subject: "Pelatihan privat: #{@course.title}"), class: "mt-4 inline-flex items-center text-xs font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
        </div>
      </aside>
    </div>

    <!-- Available Schedules -->
    <div id="schedules" class="mt-20 scroll-mt-24">
      <div class="border-t border-slate-200 pt-16">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Jadwal Kelas Tersedia</h2>
        <p class="mt-2 text-sm text-slate-600">Amankan slot Anda di salah satu sesi interaktif yang dipandu langsung oleh trainer kami.</p>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          <% if @class_schedules.any? %>
            <% @class_schedules.each do |schedule| %>
              <%= render "class_schedules/card", schedule: schedule %>
            <% end %>
          <% else %>
            <div class="col-span-full rounded-2xl border-2 border-dashed border-slate-200 bg-white py-12 px-4 text-center">
              <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <h3 class="mt-4 text-sm font-bold text-slate-900">Belum ada kelas publik yang dijadwalkan</h3>
              <p class="mt-1 text-sm text-slate-500">Hubungi kami untuk meminta sesi baru atau merancang pelatihan khusus perusahaan.</p>
              <div class="mt-6">
                <%= link_to "Hubungi kami &rarr;".html_safe, new_contact_path(subject: "Tertarik pada: #{@course.title}"), class: "inline-flex items-center rounded-xl bg-indigo-50 px-4 py-2.5 text-sm font-bold text-indigo-700 hover:bg-indigo-100 transition-all" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
