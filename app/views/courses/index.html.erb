<section class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_right,_var(--tw-gradient-stops))] from-indigo-950/50 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-20 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute -right-40 -top-40 -z-10 h-96 w-96 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl lg:mx-0">
      <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30 shadow-[0_0_15px_rgba(99,102,241,0.1)]">
        Kurikulum Kami
      </span>
      <h1 class="mt-6 text-4xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        Pelatihan Scrum Resmi <br class="hidden sm:inline" />
        dengan <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 via-purple-400 to-teal-300">Sertifikasi Global</span>
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-350">
        Tingkatkan efisiensi kerja tim Anda dengan kerangka kerja tangkas (agile) yang diakui dunia. Pilih kelas publik bersertifikat resmi dari Scrum.org atau rancang sesi tim privat khusus perusahaan.
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <div id="course-container" class="mx-auto mt-12 flex flex-col gap-8 lg:mx-0 max-w-4xl">
      <% @courses.each do |course| %>
        <article class="relative isolate flex flex-col gap-8 rounded-[2rem] bg-white p-6 sm:p-8 border border-slate-150 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_45px_-12px_rgba(99,102,241,0.07)] hover:border-indigo-500/15 hover:scale-[1.005] transition-all duration-300 lg:flex-row group">
          
          <div class="relative shrink-0 w-full lg:w-48 h-48 rounded-2xl bg-slate-50/50 border border-slate-100 p-6 flex items-center justify-center overflow-hidden">
            <% if course.logo.attached? %>
              <%= image_tag course.logo, alt: "#{course.title} logo", class: "h-full w-full object-contain group-hover:scale-105 transition-transform duration-300" %>
            <% else %>
              <div class="text-indigo-600 group-hover:scale-105 transition-transform duration-300">
                <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
              </div>
            <% end %>
          </div>

          <div class="flex-1 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-x-4">
                <span class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-700 ring-1 ring-inset ring-indigo-600/10 shadow-sm">Pelatihan Resmi</span>
              </div>
              <div id="course-desc" class="relative w-full">
                <h3 class="mt-4 text-2xl font-bold leading-8 text-slate-900 group-hover:text-indigo-600 transition-colors">
                  <%= link_to course_path(course) do %>
                    <span class="absolute inset-0"></span>
                    <%= course.title %>
                  <% end %>
                </h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-600"><%= course.excerpt %></p>
              </div>
            </div>

            <div class="mt-6 flex items-center justify-between border-t border-slate-100 pt-6">
              <div class="text-sm">
                <span class="text-slate-400 block text-xs font-semibold uppercase tracking-wider">Investasi Mulai</span>
                <span class="font-bold text-slate-900 text-base">
                  <%= course.display_price_for(current_currency) %>
                </span>
              </div>
              <%= link_to course_path(course), class: "text-sm font-bold text-indigo-600 hover:text-indigo-700 flex items-center gap-1 group/btn relative z-20" do %>
                Lihat detail <span class="group-hover/btn:translate-x-1 transition-transform duration-200">&rarr;</span>
              <% end %>
            </div>
          </div>

        </article>
      <% end %>
    </div>
  </div>
</div>

