<section class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <!-- Spotlight backgrounds -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_right,_var(--tw-gradient-stops))] from-indigo-950/50 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -right-40 -top-40 -z-10 h-96 w-96 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl lg:mx-0">
      <span class="inline-flex items-center rounded-full bg-indigo-500/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-indigo-400 ring-1 ring-inset ring-indigo-500/30">
        Kurikulum Kami
      </span>
      <h1 class="mt-4 text-4xl sm:text-5xl font-black tracking-tight text-white">
        Pelatihan Scrum Profesional <br class="hidden sm:inline" />
        dengan <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-teal-300">Sertifikasi Global</span>
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-400">
        Tingkatkan efisiensi kerja tim Anda dengan kerangka kerja tangkas (agile) yang diakui dunia. Pilih kelas publik bersertifikat resmi dari Scrum.org atau rancang sesi tim privat khusus perusahaan.
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <div id="course-container" class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-12 lg:mx-0 lg:max-w-none">
      <% @courses.each do |course| %>
        <article class="relative isolate flex flex-col gap-8 rounded-3xl bg-white p-8 ring-1 ring-slate-200 shadow-sm transition-all hover:shadow-lg lg:flex-row">
          <div class="relative aspect-[16/9] sm:aspect-[2/1] lg:aspect-square lg:w-64 lg:shrink-0">
            <% if course.logo.attached? %>
              <%= image_tag course.logo, alt: "#{course.title} logo", class: "absolute inset-0 h-full w-full rounded-2xl bg-slate-50 object-contain p-4" %>
            <% else %>
              <div class="absolute inset-0 flex items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
                <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
              </div>
            <% end %>
          </div>
          <div class="flex-1 w-full flex flex-col justify-center">
            <div class="flex items-center gap-x-4 text-xs">
              <span class="rounded-full bg-indigo-50 px-3 py-1.5 font-semibold text-indigo-600 ring-1 ring-inset ring-indigo-600/10">Pelatihan Resmi</span>
            </div>
            <div id="course-desc" class="group relative w-full">
              <h3 class="mt-3 text-2xl font-bold leading-6 text-slate-900 group-hover:text-indigo-600 transition-colors">
                <%= link_to course_path(course) do %>
                  <span class="absolute inset-0"></span>
                  <%= course.title %>
                <% end %>
              </h3>
              <p class="mt-5 text-sm leading-6 text-slate-600"><%= course.excerpt %></p>
            </div>
            <div class="mt-6 flex items-center gap-x-4 border-t border-slate-100 pt-6">
              <div class="text-sm leading-6">
                <p class="font-bold text-slate-900">
                  Mulai dari <%= course.display_price_for(current_currency) %>
                </p>
              </div>
              <%= link_to "Lihat detail &rarr;".html_safe, course_path(course), class: "ml-auto text-sm font-semibold text-indigo-600 hover:text-indigo-500 transition-colors" %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</div>
