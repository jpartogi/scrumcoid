<% content_for :title, "Resources — Materi Softcopy Scrum & Agile" %>
<% content_for :description, "Temukan materi softcopy berkualitas tentang Scrum, Agile, dan Product Management. Tersedia dalam format PDF dan Excel." %>

<section class="relative isolate overflow-hidden bg-slate-950 py-24 sm:py-32">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-20 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-82 w-82 rounded-full bg-teal-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl lg:mx-0">
      <span class="inline-flex items-center rounded-full bg-teal-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-teal-400 ring-1 ring-inset ring-teal-500/30 shadow-[0_0_15px_rgba(20,184,166,0.1)]">
        Materi Digital
      </span>
      <h1 class="mt-6 text-4xl sm:text-5xl font-black tracking-tight text-white leading-tight">
        Resources <br class="hidden sm:inline" />
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-indigo-400">Scrum & Agile</span>
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-350">
        <% if @current_tag.present? %>
          Resource dengan tag <span class="text-teal-400 font-bold"><%= @current_tag %></span>.
        <% else %>
          Koleksi materi softcopy berkualitas dalam format PDF dan Excel untuk mendukung pembelajaran Scrum, Agile, dan Product Management Anda.
        <% end %>
      </p>
      <%= render "tag_filter", all_tags: @all_tags, current_tag: @current_tag, on_hero: true %>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <% if @resources.any? %>
      <div class="grid gap-6 lg:grid-cols-2">
        <% @resources.each do |resource| %>
          <article class="relative isolate flex overflow-hidden bg-white rounded-[2rem] border border-slate-200/80 shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_45px_-12px_rgba(99,102,241,0.07)] hover:border-purple-500/40 hover:scale-[1.005] transition-all duration-300 group">
            <div class="w-28 sm:w-36 shrink-0 bg-slate-50 border-r border-slate-100 flex items-center justify-center p-4">
              <%= link_to resource_path(resource), class: "block w-full shadow rounded-lg overflow-hidden border border-slate-200/40 aspect-[3/4]" do %>
                <% if resource.thumbnail.attached? %>
                  <%= image_tag resource.thumbnail, alt: resource.title, class: "h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" %>
                <% else %>
                  <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-100 via-indigo-50/40 to-slate-200 text-slate-300 group-hover:scale-105 transition-transform duration-500">
                    <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                    </svg>
                  </div>
                <% end %>
              <% end %>
            </div>

            <div class="flex min-w-0 flex-1 flex-col p-6 sm:p-7">
              <div class="flex items-center justify-between gap-3">
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold ring-1 ring-inset <%= resource_price_badge_class(resource) %>">
                  <%= resource.free? ? "Gratis" : resource.display_price %>
                </span>
                <% if resource.page_count.present? %>
                  <span class="text-xs font-bold text-slate-400 uppercase tracking-wider"><%= resource.page_count %> halaman</span>
                <% end %>
              </div>

              <h3 class="mt-3 text-lg sm:text-xl font-bold leading-snug text-slate-900 group-hover:text-indigo-600 transition-colors">
                <%= link_to resource.title, resource_path(resource), class: "relative z-20" %>
              </h3>

              <% if resource.meta_description.present? %>
                <p class="mt-3 text-sm leading-relaxed text-slate-600 line-clamp-3">
                  <%= resource.meta_description %>
                </p>
              <% end %>

              <%= render "tags", resource: resource, wrapper_class: "mt-3" %>

              <div class="relative z-20 mt-auto pt-4 border-t border-slate-100 flex flex-wrap items-center justify-between gap-3">
                <%= link_to resource_path(resource), class: "text-indigo-600 text-sm font-bold hover:text-indigo-700 transition-colors flex items-center gap-1 group/btn" do %>
                  Selengkapnya <span class="group-hover/btn:translate-x-1 transition-transform duration-200">&rarr;</span>
                <% end %>

                <% if resource.available_for_email_download? %>
                  <%= link_to new_resource_download_request_path(resource), class: "inline-flex items-center gap-1.5 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-3.5 py-2 text-xs font-bold text-white shadow-md shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:scale-[1.02] transition-all" do %>
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                    Download
                  <% end %>
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>

      <% if @resources.total_pages > 1 %>
        <div class="mt-16 flex flex-col gap-4 rounded-[2rem] border border-slate-200/80 bg-white px-8 py-6 shadow-[0_8px_30px_rgb(0,0,0,0.015)] sm:flex-row sm:items-center sm:justify-between">
          <p class="text-sm font-medium text-slate-500 flex items-center gap-2.5">
            <span class="inline-block h-2 w-2 rounded-full bg-teal-500 shadow-sm shadow-teal-500/25"></span>
            <%= page_entries_info_for(@resources, entry_name: "resource", locale: :id) %>
          </p>
          <%= render "shared/pagination",
            paginated: @resources,
            path: method(:resources_path),
            extra_params: { tag: @current_tag.presence },
            include_per_page: false,
            previous_label: "Sebelumnya",
            next_label: "Berikutnya" %>
        </div>
      <% end %>
    <% else %>
      <div class="rounded-[2rem] border-2 border-dashed border-slate-200 bg-white py-12 px-6 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
        </svg>
        <h3 class="mt-4 text-base font-bold text-slate-900">
          <%= @current_tag.present? ? "Tidak ada resource dengan tag ini" : "Belum ada resource tersedia" %>
        </h3>
        <p class="mt-2 text-sm text-slate-500">
          <% if @current_tag.present? %>
            Coba tag lain atau <%= link_to "lihat semua resource", resources_path, class: "font-bold text-indigo-600 hover:text-indigo-700" %>.
          <% else %>
            Silakan periksa kembali nanti untuk materi softcopy terbaru dari kami.
          <% end %>
        </p>
      </div>
    <% end %>
  </div>
</div>