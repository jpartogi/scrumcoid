<% content_for :title, "Dapatkan #{@resource.title}" %>
<% content_for :description, "Isi formulir untuk menerima link download #{@resource.title} langsung ke email Anda." %>

<section class="relative isolate overflow-hidden bg-slate-950 py-12 sm:py-16">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_left,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-3xl px-6">
    <%= link_to resource_path(@resource), class: "inline-flex items-center gap-1.5 text-xs font-bold text-indigo-400 hover:text-indigo-300 transition-colors mb-6 group" do %>
      <svg class="h-4.5 w-4.5 transform group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Kembali ke Detail Resource
    <% end %>

    <div>
      <span class="inline-flex items-center rounded-full bg-teal-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-teal-400 ring-1 ring-inset ring-teal-500/30">
        Download via Email
      </span>
      <h1 class="mt-4 text-2xl sm:text-3xl font-black tracking-tight text-white leading-tight">
        <%= @resource.title %>
      </h1>
      <p class="mt-3 text-sm text-slate-400 leading-relaxed">
        Isi formulir di bawah ini. Kami akan mengirimkan link download file langsung ke email Anda.
      </p>
    </div>
  </div>
</section>

<div class="bg-slate-50 py-12">
  <div class="max-w-3xl mx-auto px-6">
    <% if @download_request.errors.any? %>
      <div class="mb-6 rounded-2xl border border-rose-100 bg-rose-50/70 p-4 text-sm font-semibold text-rose-800 shadow-sm flex items-center gap-2">
        <svg class="h-5 w-5 text-rose-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        <span><%= @download_request.errors.full_messages.to_sentence %></span>
      </div>
    <% end %>

    <div class="mb-8 rounded-2xl border border-emerald-100 bg-emerald-50/50 p-5 shadow-sm flex items-start gap-3">
      <div class="rounded-xl bg-emerald-500/10 p-2.5 text-emerald-600 shrink-0">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
        </svg>
      </div>
      <div>
        <h3 class="text-sm font-bold text-slate-900">Privasi email Anda aman</h3>
        <p class="text-xs text-slate-600 mt-1 leading-relaxed">
          Email Anda hanya digunakan untuk mengirimkan link download resource ini dan keperluan <strong>internal continuous improvement</strong> agar kami dapat terus meningkatkan kualitas materi dan layanan. Kami <strong>tidak akan mengirim spam</strong> dan <strong>tidak akan menjual data Anda</strong> ke pihak ketiga mana pun.
        </p>
      </div>
    </div>

    <%= form_with model: @download_request, url: resource_download_requests_path(@resource), local: true, class: "bg-white border border-slate-200/80 rounded-3xl p-8 shadow-sm space-y-6 transition-all duration-300 hover:border-purple-500/40" do |f| %>
      <div>
        <%= f.label :visitor_name, "Nama Lengkap", class: "block text-sm font-bold text-slate-700" %>
        <%= f.text_field :visitor_name, required: true, placeholder: "Nama lengkap Anda...", class: "mt-1.5 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all placeholder:text-slate-400" %>
      </div>

      <div>
        <%= f.label :visitor_email, "Email", class: "block text-sm font-bold text-slate-700" %>
        <%= f.email_field :visitor_email, required: true, placeholder: "alamat@email.com", class: "mt-1.5 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all placeholder:text-slate-400" %>
        <p class="mt-1.5 text-xs text-slate-500">Link download akan dikirim ke alamat email ini.</p>
      </div>

      <div>
        <%= f.label :job_title, "Jabatan di Perusahaan", class: "block text-sm font-bold text-slate-700" %>
        <%= f.select :job_title, ResourceDownloadRequest.job_title_options, { prompt: "Pilih jabatan Anda..." }, required: true, class: "mt-1.5 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all" %>
      </div>

      <%= f.submit "Kirim Link Download ke Email Saya", class: "w-full rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-4 text-sm font-bold text-white shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:scale-[1.01] active:scale-[0.99] transition-all cursor-pointer text-center" %>
    <% end %>
  </div>
</div>