<% content_for :title, @resource.title %>
<% content_for :description, @resource.meta_description.presence || "Dapatkan #{@resource.title} — materi softcopy Scrum & Agile dari scrum.co.id." %>
<% content_for :keywords, @resource.meta_keywords if @resource.meta_keywords.present? %>

<section class="relative isolate overflow-hidden bg-slate-950 py-16 sm:py-20">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-indigo-950/40 via-slate-950 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10 opacity-20 mix-blend-overlay" style="background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 0); background-size: 24px 24px;" aria-hidden="true"></div>
  <div class="absolute -left-20 -top-20 -z-10 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <% if current_user&.admin? %>
      <div class="mb-6 flex justify-end">
        <div class="inline-flex items-center gap-2 rounded-2xl border border-white/10 bg-white/5 px-3 py-2 backdrop-blur-sm">
          <span class="text-[10px] font-bold uppercase tracking-widest text-white/40">Admin</span>
          <div class="h-3 w-px bg-white/20"></div>
          <%= render "admin_edit_link", resource: @resource %>
        </div>
      </div>
    <% end %>

    <div class="flex flex-col items-center gap-8 sm:flex-row sm:items-start sm:gap-10 lg:gap-14">
      <div class="w-40 sm:w-48 shrink-0">
        <div class="aspect-[9/16] overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 shadow-[0_20px_50px_-20px_rgba(99,102,241,0.45)] ring-1 ring-inset ring-white/10">
          <% if @resource.thumbnail.attached? %>
            <%= image_tag @resource.thumbnail, alt: @resource.title, class: "h-full w-full object-cover" %>
          <% else %>
            <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-800 via-indigo-950/60 to-slate-900 text-slate-500">
              <svg class="h-14 w-14" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
          <% end %>
        </div>
      </div>

      <div class="min-w-0 flex-1 text-center sm:text-left">
        <span class="inline-flex items-center rounded-full bg-teal-500/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-teal-400 ring-1 ring-inset ring-teal-500/30 shadow-[0_0_15px_rgba(20,184,166,0.1)]">
          Detail Resource
        </span>
        <h1 class="mt-6 text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-white leading-tight">
          <%= @resource.title %>
        </h1>
        <div class="mt-6 flex flex-wrap items-center justify-center sm:justify-start gap-x-4 gap-y-2 text-sm text-slate-350">
          <span class="inline-flex items-center rounded-full px-4 py-1.5 text-sm font-bold ring-1 ring-inset <%= @resource.free? ? 'bg-emerald-500/10 text-emerald-400 ring-emerald-500/30' : 'bg-indigo-500/10 text-indigo-300 ring-indigo-500/30' %>">
            <%= @resource.free? ? "Gratis" : @resource.display_price %>
          </span>
          <% if @resource.page_count.present? %>
            <span class="font-bold uppercase tracking-wider text-teal-400"><%= @resource.page_count %> halaman</span>
          <% end %>
          <% if @resource.published_at.present? %>
            <span class="text-slate-500 hidden sm:inline">&bull;</span>
            <time datetime="<%= @resource.published_at.to_date %>" class="font-medium">
              <%= @resource.published_at.to_date.to_fs(:long) %>
            </time>
          <% end %>
        </div>
        <% if @resource.tag_list.any? %>
          <div class="mt-6 flex flex-col items-center sm:items-start gap-2">
            <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Topik</p>
            <%= render "tags", resource: @resource, wrapper_class: "justify-center sm:justify-start", link_class: resource_tag_link_class_on_dark %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<article class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1fr_340px]">
      <div class="space-y-6">
        <div class="bg-white rounded-[2.5rem] p-8 sm:p-12 border border-slate-200/80 shadow-[0_4px_30px_-10px_rgba(0,0,0,0.02)]">
          <div class="max-w-3xl mx-auto">
            <% if @resource.meta_description.present? %>
              <div class="text-xl sm:text-2xl font-semibold leading-relaxed text-slate-800 border-l-4 border-teal-500 pl-6 mb-10 italic bg-teal-50/30 py-4 pr-4 rounded-r-xl">
                <%= @resource.meta_description %>
              </div>
            <% end %>

            <div class="text-slate-800 leading-relaxed space-y-6 prose max-w-none text-lg">
              <%= @resource.description %>
            </div>
          </div>

          <div class="mt-16 pt-8 border-t border-slate-100 flex flex-wrap items-center justify-between gap-4">
            <%= link_to resources_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-700 flex items-center gap-1 group/back" do %>
              <span class="group-hover/back:-translate-x-1 transition-transform duration-200">&larr;</span> Kembali ke Resources
            <% end %>
            <div class="flex items-center gap-4">
              <% if current_user&.admin? %>
                <%= render "admin_edit_link", resource: @resource, on_light: true %>
              <% end %>
              <span class="text-xs text-slate-400 font-bold uppercase tracking-wider">scrum.co.id</span>
            </div>
          </div>
        </div>
      </div>

      <aside class="lg:sticky lg:top-8 space-y-6 self-start">
        <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
          <h3 class="text-xs font-bold text-slate-400 border-b border-slate-100 pb-3 mb-4 uppercase tracking-widest">Informasi Resource</h3>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="text-xs font-bold uppercase tracking-wider text-slate-400">Harga</dt>
              <dd class="mt-1 text-lg font-black text-slate-900"><%= @resource.free? ? "Gratis" : @resource.display_price %></dd>
            </div>
            <% if @resource.page_count.present? %>
              <div>
                <dt class="text-xs font-bold uppercase tracking-wider text-slate-400">Jumlah Halaman</dt>
                <dd class="mt-1 font-bold text-slate-700"><%= @resource.page_count %> halaman</dd>
              </div>
            <% end %>
            <% if @resource.file_attachment.attached? %>
              <div>
                <dt class="text-xs font-bold uppercase tracking-wider text-slate-400">Format File</dt>
                <dd class="mt-1 font-bold text-slate-700">
                  <%= @resource.file_attachment.content_type == "application/pdf" ? "PDF" : "Excel" %>
                </dd>
              </div>
            <% end %>
          </dl>
        </div>

        <div class="rounded-3xl border border-slate-200/80 bg-slate-900 p-6 shadow-xl text-white relative overflow-hidden">
          <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_right,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent opacity-60"></div>

          <% if @resource.paid? %>
            <span class="text-[10px] font-bold uppercase tracking-wider text-indigo-400">Resource Berbayar</span>
            <h3 class="mt-3 text-lg font-black text-white leading-snug">Tertarik dengan materi ini?</h3>
            <p class="mt-2 text-xs text-slate-400 leading-relaxed font-medium">Hubungi kami untuk proses pembelian dan pengiriman file softcopy setelah pembayaran dikonfirmasi.</p>
            <div class="mt-6 flex flex-col gap-3">
              <%= link_to "https://wa.me/6285643428348", target: "_blank", rel: "noopener", class: "w-full inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-xs font-bold text-white hover:bg-emerald-700 shadow-lg shadow-emerald-500/20 hover:scale-[1.02] transition-all text-center" do %>
                <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.739-1.456L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.963C16.48 2.012 14.005.992 11.37.992c-5.447 0-9.87 4.37-9.874 9.8.001 1.95.518 3.854 1.502 5.561l-.987 3.606 3.702-.97c1.644.896 3.23 1.365 4.834 1.365zm10.638-7.468c-.287-.143-1.696-.838-1.959-.933-.262-.095-.453-.143-.644.143-.19.287-.738.933-.905 1.124-.167.19-.333.214-.62.071-.287-.143-1.21-.446-2.305-1.424-.853-.76-1.428-1.7-1.595-1.986-.167-.286-.018-.44.125-.581.129-.127.287-.333.43-.5.143-.167.19-.286.287-.476.095-.19.047-.357-.024-.5-.071-.143-.644-1.547-.882-2.12-.232-.559-.467-.483-.644-.492-.167-.008-.358-.01-.55-.01-.19 0-.5.071-.762.357-.262.287-1 .977-1 2.38 0 1.405 1.023 2.762 1.166 2.953.143.19 2.013 3.074 4.877 4.31.681.294 1.213.47 1.627.601.684.218 1.307.187 1.8.114.55-.082 1.696-.692 1.935-1.36.239-.667.239-1.24.167-1.36-.072-.119-.262-.19-.549-.333z"/>
                </svg>
                Beli via WhatsApp
              <% end %>
              <%= link_to new_contact_path(jenis_inkuiri: "Pembelian Resource"), class: "w-full inline-flex items-center justify-center rounded-xl border border-slate-700 bg-slate-800/40 px-4 py-3 text-xs font-bold text-slate-300 hover:text-white hover:bg-slate-800 transition-all text-center" do %>
                Hubungi Kami
              <% end %>
            </div>
          <% elsif @resource.available_for_email_download? %>
            <span class="text-[10px] font-bold uppercase tracking-wider text-emerald-400">Resource Gratis</span>
            <h3 class="mt-3 text-lg font-black text-white leading-snug">Dapatkan materi ini secara gratis</h3>
            <p class="mt-2 text-xs text-slate-400 leading-relaxed font-medium">Isi formulir singkat dan kami akan mengirimkan link download langsung ke email Anda.</p>
            <div class="mt-6">
              <%= link_to new_resource_download_request_path(@resource), class: "w-full inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 px-4 py-3 text-xs font-bold text-white shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:scale-[1.02] transition-all text-center" do %>
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                Dapatkan lewat Email
              <% end %>
            </div>
          <% else %>
            <span class="text-[10px] font-bold uppercase tracking-wider text-emerald-400">Resource Gratis</span>
            <h3 class="mt-3 text-lg font-black text-white leading-snug">Segera hadir</h3>
            <p class="mt-2 text-xs text-slate-400 leading-relaxed font-medium">File softcopy untuk resource ini sedang disiapkan.</p>
          <% end %>
        </div>

        <% if @resource.free? %>
          <div class="rounded-3xl border border-slate-200/80 bg-white p-6 shadow-sm">
            <h3 class="text-xs font-bold text-slate-400 border-b border-slate-100 pb-3 mb-4 uppercase tracking-widest">Butuh Bantuan?</h3>
            <p class="text-xs text-slate-600 leading-relaxed font-medium">
              Lebih suka bertanya langsung? Hubungi Jessica Stella via WhatsApp untuk pertanyaan seputar resource ini.
            </p>
            <%= link_to "https://wa.me/6285643428348", target: "_blank", rel: "noopener", class: "mt-4 w-full inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-xs font-bold text-white hover:bg-emerald-700 shadow-lg shadow-emerald-500/20 hover:scale-[1.02] transition-all text-center" do %>
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.739-1.456L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.963C16.48 2.012 14.005.992 11.37.992c-5.447 0-9.87 4.37-9.874 9.8.001 1.95.518 3.854 1.502 5.561l-.987 3.606 3.702-.97c1.644.896 3.23 1.365 4.834 1.365zm10.638-7.468c-.287-.143-1.696-.838-1.959-.933-.262-.095-.453-.143-.644.143-.19.287-.738.933-.905 1.124-.167.19-.333.214-.62.071-.287-.143-1.21-.446-2.305-1.424-.853-.76-1.428-1.7-1.595-1.986-.167-.286-.018-.44.125-.581.129-.127.287-.333.43-.5.143-.167.19-.286.287-.476.095-.19.047-.357-.024-.5-.071-.143-.644-1.547-.882-2.12-.232-.559-.467-.483-.644-.492-.167-.008-.358-.01-.55-.01-.19 0-.5.071-.762.357-.262.287-1 .977-1 2.38 0 1.405 1.023 2.762 1.166 2.953.143.19 2.013 3.074 4.877 4.31.681.294 1.213.47 1.627.601.684.218 1.307.187 1.8.114.55-.082 1.696-.692 1.935-1.36.239-.667.239-1.24.167-1.36-.072-.119-.262-.19-.549-.333z"/>
              </svg>
              Chat Jessica via WhatsApp
            <% end %>
            <p class="mt-3 text-center text-xs font-semibold text-slate-500">
              Jessica Stella · <a href="https://wa.me/6285643428348" target="_blank" rel="noopener" class="text-emerald-600 hover:text-emerald-700 transition-colors">+62 856 4342 8348</a>
            </p>
          </div>
        <% end %>

      </aside>
    </div>

    <% if @related_resources.any? %>
      <div class="mt-16 pt-12 border-t border-slate-200/80">
        <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">Resource Terkait</h2>
        <p class="mt-2 text-sm text-slate-600">Materi lain yang relevan dengan topik ini.</p>
        <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% @related_resources.each do |resource| %>
            <article class="rounded-2xl border border-slate-200/80 bg-white overflow-hidden shadow-[0_4px_25px_-5px_rgba(0,0,0,0.02)] hover:border-indigo-500/30 hover:shadow-md transition-all group">
              <% if resource.thumbnail.attached? %>
                <%= link_to resource_path(resource), class: "block bg-slate-50 py-6 flex justify-center border-b border-slate-100" do %>
                  <div class="w-24 shadow rounded overflow-hidden border border-slate-200/40 aspect-[3/4]">
                    <%= image_tag resource.thumbnail, alt: resource.title, class: "h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" %>
                  </div>
                <% end %>
              <% end %>
              <div class="p-6">
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-bold ring-1 ring-inset <%= resource_price_badge_class(resource) %>">
                  <%= resource.free? ? "Gratis" : resource.display_price %>
                </span>
                <h3 class="mt-3 text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">
                  <%= link_to resource.title, resource_path(resource) %>
                </h3>
                <% if resource.meta_description.present? %>
                  <p class="mt-2 text-sm text-slate-600 line-clamp-2"><%= resource.meta_description %></p>
                <% end %>
                <%= render "tags", resource: resource, wrapper_class: "mt-4" %>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</article>