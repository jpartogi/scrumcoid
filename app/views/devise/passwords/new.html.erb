<%# Forgot Password %>
<div class="space-y-8">
  <div>
    <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">Reset your password</h1>
    <p class="mt-1 text-sm text-slate-500">Enter your email and we'll send you reset instructions.</p>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>

      <div>
        <%= f.label :email, class: "block text-sm font-bold text-slate-700 mb-1.5" %>
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
            <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "you@example.com",
              class: "w-full rounded-lg border border-slate-300 bg-slate-50 pl-10 pr-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 transition-all outline-none" %>
        </div>
      </div>

      <%= f.submit "Send reset instructions",
          class: "w-full rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-500/25 hover:from-indigo-500 hover:to-violet-500 hover:-translate-y-px transition-all duration-200 cursor-pointer" %>
    <% end %>
  </div>

  <p class="text-center text-sm text-slate-500">
    Remember your password?
    <%= link_to "Sign in", new_session_path(resource_name),
        class: "font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
  </p>
</div>
