<%# Sign In %>
<div class="space-y-8">
  <%# Header %>
  <div>
    <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">Welcome back</h1>
    <p class="mt-1 text-sm text-slate-500">Sign in to your scrum.co.id account.</p>
  </div>

  <%# Form card %>
  <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>

      <%# Email %>
      <div>
        <%= f.label :email, class: "block text-sm font-bold text-slate-700 mb-1.5" %>
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
            <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "you@example.com",
              class: "w-full rounded-lg border border-slate-300 bg-slate-50 pl-10 pr-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 transition-all outline-none" %>
        </div>
      </div>

      <%# Password %>
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <%= f.label :password, class: "block text-sm font-bold text-slate-700" %>
          <% if devise_mapping.recoverable? %>
            <%= link_to "Forgot password?", new_password_path(resource_name),
                class: "text-xs font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
          <% end %>
        </div>
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
            <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <%= f.password_field :password, autocomplete: "current-password",
              placeholder: "••••••••",
              class: "w-full rounded-lg border border-slate-300 bg-slate-50 pl-10 pr-3.5 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-indigo-500 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 transition-all outline-none" %>
        </div>
      </div>

      <%# Remember me %>
      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2.5 cursor-pointer select-none">
          <%= f.check_box :remember_me,
              class: "h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 transition-colors" %>
          <span class="text-sm text-slate-600 font-medium">Remember me on this device</span>
        </label>
      <% end %>

      <%# Submit %>
      <%= f.submit "Sign in",
          class: "w-full rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 px-4 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-500/25 hover:from-indigo-500 hover:to-violet-500 hover:shadow-indigo-500/40 hover:-translate-y-px transition-all duration-200 cursor-pointer" %>

    <% end %>
  </div>

  <%# Sign up link %>
  <% if devise_mapping.registerable? %>
    <p class="text-center text-sm text-slate-500">
      Don't have an account?
      <%= link_to "Create one", new_registration_path(resource_name),
          class: "font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
    </p>
  <% end %>
</div>
