#!/usr/bin/env bash
#
# bin/fly-setup
#
# Interactive helper script to set up a new Fly.io deployment for this app.
# This automates the most error-prone parts of the initial setup.
#
# Usage:
#   ./bin/fly-setup
#
# Requirements:
#   - flyctl installed and authenticated (`fly auth login`)
#   - A Brevo account (https://www.brevo.com)

set -e

APP_NAME="scrumcoid"
DB_NAME="scrumcoid-db"   # Your production Postgres app name on Fly.io
REGION="sjc"   # Change this if you prefer a different default region
VOLUME_NAME="storage"

echo "🚀 ScrumCoid Fly.io Initial Setup Wizard"
echo "========================================"
echo

# --- 1. Check flyctl ---
if ! command -v flyctl &> /dev/null; then
  echo "❌ flyctl is not installed."
  echo "   Install it from: https://fly.io/docs/hands-on/install-flyctl/"
  exit 1
fi

echo "✅ flyctl found"

# --- 2. Login check ---
if ! flyctl auth whoami &> /dev/null; then
  echo "🔐 You are not logged into Fly.io."
  flyctl auth login
fi

echo "✅ Authenticated with Fly.io"
echo

# --- 3. App name ---
read -p "Fly app name (default: $APP_NAME): " INPUT_APP
APP_NAME=${INPUT_APP:-$APP_NAME}

read -p "Primary region (default: $REGION): " INPUT_REGION
REGION=${INPUT_REGION:-$REGION}

echo
echo "This script will perform the following:"
echo "  1. Launch Fly app '$APP_NAME' (if it doesn't exist)"
echo "  2. Create/verify legacy Postgres database '$DB_NAME' (your production DB)"
echo "  3. Attach the database"
echo "  4. Create a 1GB volume for Active Storage"
echo "  5. Prompt for Brevo SMTP secrets"
echo "  6. Optionally deploy"
echo
read -p "Continue? (y/N) " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
  echo "Aborted."
  exit 1
fi

# --- 4. Launch app (idempotent) ---
echo
echo "📦 Ensuring Fly app exists..."
if flyctl apps list | grep -q "$APP_NAME"; then
  echo "✅ App '$APP_NAME' already exists"
else
  flyctl launch --dockerfile Dockerfile --name "$APP_NAME" --region "$REGION" --now --yes || true
  echo "✅ App created"
fi

# --- 5. Create Postgres (legacy) ---
echo
echo "🐘 Setting up legacy Postgres database..."
if flyctl postgres list | grep -q "$DB_NAME"; then
  echo "✅ Postgres app '$DB_NAME' already exists"
else
  flyctl postgres create \
    --name "$DB_NAME" \
    --region "$REGION" \
    --vm-size shared-cpu-1x \
    --initial-cluster-size 1 \
    --yes
  echo "✅ Postgres database created"
fi

# --- 6. Attach database ---
echo
echo "🔗 Attaching database to app..."
flyctl postgres attach "$DB_NAME" --app "$APP_NAME" --yes || echo "⚠️  Database may already be attached"

# --- 7. Create volume ---
echo
echo "💾 Creating persistent volume for Active Storage..."
if flyctl volumes list --app "$APP_NAME" | grep -q "$VOLUME_NAME"; then
  echo "✅ Volume '$VOLUME_NAME' already exists"
else
  flyctl volumes create "$VOLUME_NAME" \
    --app "$APP_NAME" \
    --size 1 \
    --region "$REGION" \
    --yes
  echo "✅ Volume created"
fi

# --- 8. Brevo SMTP secrets ---
echo
echo "📧 Brevo SMTP configuration"
echo "   Get your SMTP credentials from: https://app.brevo.com/settings/keys/smtp"
echo

read -p "Brevo SMTP Login: " BREVO_USER
read -s -p "Brevo SMTP Key: " BREVO_PASS
echo

if [[ -n "$BREVO_USER" && -n "$BREVO_PASS" ]]; then
  flyctl secrets set \
    BREVO_HOST="smtp-relay.brevo.com" \
    BREVO_PORT="587" \
    BREVO_USERNAME="$BREVO_USER" \
    BREVO_PASSWORD="$BREVO_PASS" \
    --app "$APP_NAME"
  echo "✅ Brevo SMTP secrets set"
else
  echo "⚠️  Skipped Brevo SMTP secrets (you can set them later with 'fly secrets set')"
fi

# --- 9. Optional: Custom domain / from address ---
echo
read -p "Do you want to set a custom APP_HOST and MAILER_FROM now? (y/N) " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
  read -p "APP_HOST (e.g. scrumcoid.com): " APP_HOST
  read -p "MAILER_FROM (e.g. no-reply@scrumcoid.com): " MAILER_FROM

  if [[ -n "$APP_HOST" && -n "$MAILER_FROM" ]]; then
    flyctl secrets set APP_HOST="$APP_HOST" MAILER_FROM="$MAILER_FROM" --app "$APP_NAME"
    echo "✅ Custom domain secrets set"
  fi
fi

# --- 10. Final deploy prompt ---
echo
echo "🎉 Initial infrastructure setup complete!"
echo
read -p "Deploy the application now? (y/N) " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
  echo "🚀 Deploying to Fly.io..."
  flyctl deploy --app "$APP_NAME"
  echo
  echo "✅ Deployment finished!"
  echo "   Visit: https://$APP_NAME.fly.dev"
else
  echo "You can deploy later with: fly deploy --app $APP_NAME"
fi

echo
echo "Next steps:"
echo "  • Test password reset emails"
echo "  • Upload a course logo in the admin area"
echo "  • (Optional) Add a custom domain: fly certs create yourdomain.com --app $APP_NAME"
echo "  • See FLY_DEPLOY.md for advanced topics (workers, Tigris, etc.)"
echo
echo "Done! 🎉"
