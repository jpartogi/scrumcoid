#!/bin/bash -e

APP_USER="rails"

run_as_app_user() {
  if [[ "$(id -u)" -eq 0 ]]; then
    exec gosu "${APP_USER}" "$@"
  else
    exec "$@"
  fi
}

# Railway volumes mount as root; ensure the app user can write uploads.
storage_path="${ACTIVE_STORAGE_ROOT:-/rails/storage}"
mkdir -p "${storage_path}"
if [[ "$(id -u)" -eq 0 ]]; then
  chown -R "${APP_USER}:${APP_USER}" "${storage_path}"
fi

# If we are starting the web server, run pending migrations before boot.
# Railway runs ./bin/rails db:migrate via preDeployCommand before each deploy;
# this is a fallback for local Docker and non-Railway environments.
# Set SKIP_DB_PREPARE=true when restoring a database dump before first boot.
if [[ "${SKIP_DB_PREPARE:-}" != "true" ]] && [[ "${@}" == *"rails server"* ]]; then
  if [[ "$(id -u)" -eq 0 ]]; then
    gosu "${APP_USER}" ./bin/rails db:migrate
  else
    ./bin/rails db:migrate
  fi
fi

run_as_app_user "$@"