# =============================================================================
# Railway Environment Variables - Copy values into the Railway dashboard
#
# Usage:
#   1. Create a Railway project with a PostgreSQL plugin
#   2. Add a service from this GitHub repo (Railway detects the Dockerfile)
#   3. Paste these variables into the service Variables tab (Raw Editor)
#
# NEVER commit real secrets. This file is safe to commit as an example.
# =============================================================================

# --- Application Identity ---
APP_HOST=scrum.co.id
# Railway preview domain example: APP_HOST=scrumcoid-production.up.railway.app

MAILER_FROM="ScrumAI Training <jessica.stella@scrum.co.id>"

# --- Rails / Logging ---
RAILS_ENV=production
RAILS_LOG_LEVEL=info
RAILS_SERVE_STATIC_FILES=true
RAILS_MAX_THREADS=5

# --- Secrets (set in Railway, never commit) ---
# RAILS_MASTER_KEY=...          # From config/master.key

# --- Database (scrumcoid project → Postgres service) ---
# On the scrumcoid web service:
DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# For local restore/migration from your laptop, use the public proxy URL
# from the Postgres service variables tab (DATABASE_PUBLIC_URL), e.g.:
# DATABASE_URL=postgresql://postgres:...@....proxy.rlwy.net:.../railway

# --- Brevo SMTP (required for password reset emails) ---
BREVO_USERNAME=your_brevo_smtp_login_here
BREVO_PASSWORD=your_brevo_smtp_key_here
BREVO_HOST=smtp-relay.brevo.com
BREVO_PORT=587

# --- Solid Queue ---
# true  = run Solid Queue inside the web Puma process (recommended to start)
# false = run Solid Queue on a dedicated Railway worker service (bin/jobs)
SOLID_QUEUE_IN_PUMA=true

# --- Active Storage ---
# Local disk storage on a Railway volume (recommended for Course logos/thumbnails).
# Mount a volume at /rails/storage in the Railway service settings.
# The Docker entrypoint chowns this path for the rails user on boot (volumes mount as root).
ACTIVE_STORAGE_SERVICE=local
ACTIVE_STORAGE_ROOT=/rails/storage
# For object storage instead, set ACTIVE_STORAGE_SERVICE=r2 and the R2_* vars below.
# ACTIVE_STORAGE_SERVICE=r2
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_ACCOUNT_ID=...
# R2_BUCKET=scrumcoid-production

# --- PayPal donation link (fallback for post-meetup follow-up emails) ---
# PAYPAL_DONATION_URL=https://www.paypal.com/donate/?hosted_button_id=...

# --- Database migrations ---
# railway.json runs ./bin/rails db:migrate as a preDeployCommand on every deploy.
# The Docker entrypoint also runs db:migrate on web server boot as a fallback.
#
# --- Initial database restore ---
# Set to true for the first deploy if you are restoring a SQL dump manually
# and want to skip automatic db:migrate on boot.
# SKIP_DB_PREPARE=true

# --- Thruster / Puma (usually leave unset on Railway) ---
# Railway injects PORT automatically. bin/server-start maps it to HTTP_PORT.
# PUMA_PORT=3000